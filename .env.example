# =============================================================================
#  Research Assistant · environment template
# =============================================================================
#  Copy this file to `.env` and fill in the values marked REQUIRED.
#  Everything else is optional with sensible defaults baked into settings.py.
#
#  Precedence:
#   1. data/memory/llm_config.json   (saved from the in-app Settings page)
#   2. .env values                    (this file, after rename)
#   3. settings.py defaults
#
#  Delete data/memory/llm_config.json if you want .env to be the source of truth.
# =============================================================================


# ── LLM provider (REQUIRED) ─────────────────────────────────────────────────
# Any agent without a *_AGENT_LLM_PROVIDER override falls back to LLM_PROVIDER.
# Without this line settings.py defaults to ollama/llama3.
LLM_PROVIDER=qwen

# ── Provider API keys & defaults ────────────────────────────────────────────
# Fill in at least one (the one you set as LLM_PROVIDER above).
# Qwen (Alibaba DashScope, OpenAI-compatible)
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Doubao / Volcengine Ark (OpenAI-compatible)
ARK_API_KEY=
DOUBAO_MODEL=doubao-seed-1-6-251015
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# OpenAI / DeepSeek / any OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Gemini (Google AI, OpenAI-compatible mode)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# ── Per-agent LLM overrides (OPTIONAL) ──────────────────────────────────────
# Only override an agent if you really want a DIFFERENT provider / model from
# LLM_PROVIDER above. Otherwise leave it blank and the agent uses the default.
#
# Recognised agent names: intent_agent, general_agent, research_agent, rag_agent,
# literature_agent, retrieval_agent, reading_agent, web_agent, writing_agent,
# note_agent, summary_agent, chat_agent, evaluator_agent.
#
# Example: pin Intent Agent to a specific Qwen revision for routing stability:
#   INTENT_AGENT_LLM_PROVIDER=qwen
#   INTENT_AGENT_LLM_MODEL=qwen-plus-2025-07-28
#
# Example: use Doubao's character model for chat tone:
#   CHAT_AGENT_LLM_PROVIDER=doubao
#   CHAT_AGENT_LLM_MODEL=doubao-seed-character-251128


# ── Storage / database (REQUIRED for multi-user) ────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGEME@localhost:5432/research_assistant
USE_MOCK_STORAGE=false
DATA_DIR=./data
DEBUG=false


# ── Search backends ─────────────────────────────────────────────────────────
# Paper search — Semantic Scholar API key improves rate limits (optional).
DEFAULT_SEARCH_SOURCES=semantic,arxiv
DEFAULT_SEARCH_MAX_RESULTS=20
SEMANTIC_SCHOLAR_API_KEY=
USE_SCIHUB=false

# Web search — Tavily (default) + Serper (fallback). Pick whichever you have.
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=

# Proxy for Tavily + Serper (境外 API；境内访问需要走代理). Leave empty if your
# network can reach api.tavily.com / google.serper.dev directly.
#   WEB_SEARCH_PROXY=http://127.0.0.1:7890   (Clash / Verge HTTP)
#   WEB_SEARCH_PROXY=socks5://127.0.0.1:1080 (SOCKS5)
WEB_SEARCH_PROXY=


# ── PDF / RAG ───────────────────────────────────────────────────────────────
# LlamaParse for high-quality PDF parsing (falls back to PyMuPDF if blank).
LLAMA_CLOUD_API_KEY=

# Reranker — flashrank is local and free; cross_encoder needs sentence-transformers.
RERANKER_TYPE=flashrank
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2


# ── RAG quality evaluation (sidecar) ────────────────────────────────────────
EVAL_ENABLED=true
EVAL_BACKEND=llm            # custom | llm | ragas
EVAL_MODE=sync
EVAL_MIN_CONTEXTS=1
EVAL_FAITHFULNESS_WARNING_THRESHOLD=0.7
EVAL_RELEVANCY_WARNING_THRESHOLD=0.65
EVAL_PRECISION_WARNING_THRESHOLD=0.6


# ── Image / figure generation ───────────────────────────────────────────────
# LLM that turns a user request into an image-generation prompt
FIGURE_PROMPT_LLM_PROVIDER=qwen
FIGURE_PROMPT_LLM_MODEL=qvq-max-2025-03-25
# Image model that renders the final raster image
FIGURE_IMAGE_PROVIDER=doubao
FIGURE_IMAGE_MODEL=doubao-seedream-4-5-251128


# ── Vision (image understanding) ────────────────────────────────────────────
VLM_PROVIDER=qwen_vl
QWEN_VL_MODEL=qwen-vl-plus-latest
# Optional overrides for self-hosted vLLM / LM Studio / etc.
# VLM_MODEL_NAME=qwen-vl
# VLM_BASE_URL=http://localhost:8000/v1
# VLM_API_KEY=EMPTY
VLM_TEMPERATURE=0.2
VLM_MAX_TOKENS=2048


# ============================================================================
#  Auth — user accounts, JWT, SMTP, admin bootstrap
# ============================================================================

# ── Core auth ───────────────────────────────────────────────────────────────
# REQUIRED for production. Generate a real secret with:
#   python -c "import secrets; print(secrets.token_hex(64))"
AUTH_JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
# Cookie domain — leave blank for current host; in production set to your apex domain
AUTH_COOKIE_DOMAIN=
# In production must be true (requires HTTPS); on localhost set to false
AUTH_COOKIE_SECURE=false
# Public site URL used to build email activation / reset links
AUTH_PUBLIC_BASE_URL=http://localhost:8000

# ── Email (SMTP) ────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in dev to print activation links to the console.
# For QQ mail: SMTP_HOST=smtp.qq.com, port 465, password = 16-char authcode (not your QQ password)
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@example.com
SMTP_FROM_NAME=paipai

# ── QQ OAuth (PR-3) — distinct from QQ_BOT_* below ─────────────────────────
# Apply at https://connect.qq.com — needs an ICP-registered domain
QQ_OAUTH_APP_ID=
QQ_OAUTH_APP_KEY=
QQ_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/qq/callback

# ── Admin bootstrap ─────────────────────────────────────────────────────────
# On startup the app ensures this account exists, marks it is_admin=true,
# and claims orphan sessions / files / libraries for it. If the user already
# exists, the password below is IGNORED (existing credentials are not touched).
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_INITIAL_PASSWORD=
AUTH_ADMIN_DISPLAY_NAME=Admin

# ── Storage quota ───────────────────────────────────────────────────────────
# 500 MB total per non-admin user; admin is exempt.
AUTH_STORAGE_LIMIT_BYTES=524288000
# 100 MB single-file cap
AUTH_MAX_UPLOAD_BYTES=104857600

# ── Forgot-password rate limits (per email) ────────────────────────────────
AUTH_RESET_COOLDOWN_SECONDS=300
AUTH_RESET_DAILY_LIMIT=2


# ============================================================================
#  Frontend error tracking (Sentry — optional)
# ============================================================================
# DSN is a public project id, not a secret. Leave empty to disable.
# Get one at https://sentry.io → Settings → Projects → [project] → Client Keys
SENTRY_DSN=


# ============================================================================
#  QQ bot (optional — only if you expose the assistant via a QQ group bot)
# ============================================================================

QQ_BOT_APP_ID=your_app_id
# QQ_BOT_TOKEN is kept only for old gateway-style integrations. The v2 webhook
# sender uses QQ_BOT_APP_ID + QQ_BOT_SECRET to fetch app access tokens.
QQ_BOT_TOKEN=
QQ_BOT_SECRET=your_app_secret
QQ_BOT_SANDBOX=true

QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_SANDBOX_API_BASE_URL=https://sandbox.api.sgroup.qq.com

# Event mode: websocket is the intended production mode; webhook is reserved.
QQ_EVENT_MODE=websocket

# Message control
QQ_REPLY_TIMEOUT_SECONDS=50
QQ_MAX_REPLY_LENGTH=1800
QQ_ENABLE_MESSAGE_DEDUP=true

# Optional whitelist
QQ_ENABLE_USER_WHITELIST=false
QQ_ALLOWED_USERS=openid_1,openid_2
QQ_ALLOWED_GROUPS=group_openid_1
