# QQ Bot basic config
QQ_BOT_APP_ID=your_app_id
# QQ_BOT_TOKEN is kept only for old gateway-style integrations. The v2 webhook
# sender uses QQ_BOT_APP_ID + QQ_BOT_SECRET to fetch app access tokens.
QQ_BOT_TOKEN=
QQ_BOT_SECRET=your_app_secret
QQ_BOT_SANDBOX=true

# QQ OpenAPI
QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_SANDBOX_API_BASE_URL=https://sandbox.api.sgroup.qq.com

# Event mode: websocket is the intended production mode; webhook is reserved.
QQ_EVENT_MODE=websocket

# Message control
QQ_REPLY_TIMEOUT_SECONDS=50
QQ_MAX_REPLY_LENGTH=1800
QQ_ENABLE_MESSAGE_DEDUP=true

# Optional whitelist
QQ_ENABLE_USER_WHITELIST=false
QQ_ALLOWED_USERS=openid_1,openid_2
QQ_ALLOWED_GROUPS=group_openid_1

# Optional: improves citation graph rate limits for Semantic Scholar requests.
SEMANTIC_SCHOLAR_API_KEY=
