    <span class="nav-icon">馃挰</span>瀵硅瘽
  </div>
  <div class="nav-item" id="nav-library" onclick="showLibraryManager(this)">
    <span class="nav-icon">馃搫</span>鏂囩尞绠＄悊
  </div>
  <div class="nav-item" onclick="toast('鍐欎綔鍔╂墜鍔熻兘鍗冲皢涓婄嚎')">
    <span class="nav-icon">鉁嶏笍</span>鍐欎綔鍔╂墜
  </div>
