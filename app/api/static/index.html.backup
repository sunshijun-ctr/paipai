            </div>
          </div>
        </div>
        <!-- Outline -->
        <div id="nv-panel-outline" style="display:none">
          <div id="nv-outline" class="nv-outline"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Input -->
  <div id="input-wrap">
    <div id="compress-bar" class="compress-bar">
      <span id="compress-text"></span>
      <button class="sm-btn" onclick="compressCurrentSession()">鍘嬬缉瀵硅瘽</button>
    </div>
    <div class="input-box">
      <textarea id="user-input" rows="1" placeholder="鏈変綍闂灏界闂垜鈥?></textarea>
      <div style="display:flex;align-items:center;gap:4px">
        <input type="file" id="file-input" accept=".pdf,.pptx,.txt,.md,.text,.rst"
          style="display:none" onchange="uploadFile(this)">
        <input type="file" id="image-input" accept="image/png,image/jpeg,image/webp,image/bmp"
          style="display:none" onchange="uploadImage(this)">
        <button class="itool" title="涓婁紶鏂囨。 (PDF/PPTX/TXT/MD)" onclick="document.getElementById('file-input').click()">馃搸</button>
        <button class="itool" title="浠ｇ爜" onclick="toast('浠ｇ爜鍔熻兘鍗冲皢涓婄嚎')">銆?銆?/button>
        <button class="itool" title="涓婁紶鍥剧墖" onclick="document.getElementById('image-input').click()">馃柤锔?/button>
        <button id="stop-btn" title="鍋滄鍥炲" onclick="stopGeneration()">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <rect x="6" y="6" width="12" height="12" rx="2"/>
          </svg>
        </button>
        <button id="send-btn" title="鍙戦€?(Enter)" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="input-foot">鍐呭鐢?AI 鐢熸垚锛岃娉ㄦ剰鏍告煡閲嶈淇℃伅銆?/div>
  </div>
</main>

<!-- Built-in document reader -->
<div id="reader-overlay" class="reader-overlay" onclick="closeReader(event)">
  <div class="reader-shell" onclick="event.stopPropagation()">
    <div class="reader-head">
      <div id="reader-title" class="reader-title">鏂囩尞闃呰</div>
      <button class="sm-btn" onclick="openReaderInNewWindow()">鏂扮獥鍙?/button>
      <button class="sm-btn pri" onclick="closeReader()">鍏抽棴</button>
    </div>
    <iframe id="reader-frame" class="reader-frame" title="鏂囩尞闃呰鍣?></iframe>
    <div id="reader-fallback" class="reader-fallback">
      濡傛灉娴忚鍣ㄦ病鏈夋樉绀哄唴瀹癸紝璇蜂娇鐢ㄢ€滄柊绐楀彛鈥濇墦寮€锛汸DF 浠嶇敱娴忚鍣ㄥ唴缃槄璇诲櫒娓叉煋銆?
    </div>
  </div>
</div>

<!-- 鈹€鈹€ Right panel 鈹€鈹€ -->
<!-- Indexed chunk viewer -->
<div id="chunk-overlay" class="reader-overlay" onclick="closeChunkViewer(event)">
  <div class="reader-shell" onclick="event.stopPropagation()">
    <div class="reader-head">
      <div id="chunk-title" class="reader-title">Chunk 鏌ョ湅</div>
      <button class="sm-btn pri" onclick="closeChunkViewer()">鍏抽棴</button>
    </div>
    <div class="chunk-toolbar">
      <input id="chunk-filter" class="paper-search" style="min-width:240px"
             placeholder="绛涢€?chunk 鏂囨湰銆乻ection銆佺被鍨? oninput="renderChunks()">
      <span id="chunk-stat" class="chunk-stat"></span>
    </div>
    <div id="chunk-list" class="chunk-list"></div>
  </div>
</div>

<aside id="panel">

  <!-- Research board -->
  <div>
    <div class="ps-title">鐮旂┒鐪嬫澘</div>
    <div class="stats">
      <div class="stat">
        <div class="stat-icon">馃攳</div>
        <div class="stat-n" id="st-found">0</div>
        <div class="stat-l">鎼滅储缁撴灉</div>
      </div>
      <div class="stat">
        <div class="stat-icon">馃摜</div>
        <div class="stat-n" id="st-dl">0</div>
        <div class="stat-l">宸蹭笅杞?/div>
      </div>
      <div class="stat">
        <div class="stat-icon">馃摎</div>
        <div class="stat-n" id="st-lib">0</div>
        <div class="stat-l">鐭ヨ瘑搴?/div>
      </div>
    </div>
  </div>

  <!-- Found papers -->
  <div id="sec-found" style="display:none">
    <div class="ps-title">
      鎼滅储缁撴灉
      <span class="ps-more" onclick="sendText('涓嬭浇鍏ㄩ儴')">鍏ㄩ儴涓嬭浇 鈥?/span>
    </div>
    <select id="found-sort" class="form-select" style="width:100%;margin-bottom:8px" onchange="renderFound()">
      <option value="relevance">鎸夌浉浼煎害鎺掑簭</option>
      <option value="citations">鎸夊紩鐢ㄦ暟鎺掑簭</option>
      <option value="year">鎸夊勾浠芥帓搴?/option>
      <option value="original">鍘熷椤哄簭</option>
    </select>
    <div id="found-list"></div>
  </div>

  <!-- Downloaded -->
  <div id="sec-dl" style="display:none">
    <div class="ps-title">宸蹭笅杞芥枃鐚?/div>
    <div id="dl-list"></div>
  </div>

  <!-- Library management -->
  <div id="sec-lib">
    <div class="ps-title">
      涓汉鐭ヨ瘑搴?
      <span class="ps-more" onclick="showCreateLib()">+ 鏂板缓</span>
    </div>
    <!-- Create library inline form (hidden by default) -->
    <div id="lib-create" style="display:none;margin-bottom:8px">
      <div style="display:flex;gap:6px">
        <input id="lib-name-inp" type="text" placeholder="鐭ヨ瘑搴撳悕绉扳€?
          style="flex:1;border:1.5px solid var(--border);border-radius:8px;
                 padding:5px 10px;font-size:13px;outline:none;font-family:inherit"
          onkeydown="if(event.key==='Enter')confirmCreateLib()">
        <button class="sm-btn pri" onclick="confirmCreateLib()">纭</button>
        <button class="sm-btn" onclick="cancelCreateLib()">鍙栨秷</button>
      </div>
    </div>
    <!-- Library tabs -->
    <div id="lib-tabs" style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px"></div>
    <!-- Document list for active library -->
    <div id="lib-doc-list"></div>
    <!-- Upload to library button -->
    <div style="margin-top:6px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:6px">
        <label class="paper-meta">Chunk size
          <input id="lib-chunk-size" class="paper-search" type="number" min="200" max="4000" step="50" value="2000"
                 style="width:100%;min-width:0;padding:6px 8px">
        </label>
        <label class="paper-meta">Overlap
          <input id="lib-chunk-overlap" class="paper-search" type="number" min="0" max="3999" step="10" value="200"
                 style="width:100%;min-width:0;padding:6px 8px">
        </label>
      </div>
      <input type="file" id="lib-file-input" accept=".pdf,.pptx,.txt,.md,.text,.rst"
        style="display:none" onchange="uploadToLibrary(this)">
      <button class="sm-btn" style="width:100%;justify-content:center;display:flex;gap:5px"
        onclick="document.getElementById('lib-file-input').click()">
        馃摛 涓婁紶鏂囨。鑷虫搴?
      </button>
    </div>
  </div>

  <!-- Tools -->
  <div>
    <div class="ps-title">甯哥敤宸ュ叿</div>
    <div class="tools">
      <button class="tool" onclick="draftText('甯垜鎼滅储鍏充簬锛?)">
        <span class="tool-i">馃攳</span>鏂囩尞鎼滅储
      </button>
      <button class="tool" onclick="openCalculator()">
        <span class="tool-i">馃М</span>璁＄畻鍣?
      </button>
      <button class="tool" onclick="openCalendarTool()">
        <span class="tool-i">馃搮</span>鏃ュ巻
      </button>
      <button class="tool" onclick="openWordCounter()">
        <span class="tool-i">馃敜</span>瀛楁暟缁熻
      </button>
      <button class="tool" onclick="openDateTimeTool()">
        <span class="tool-i">馃晵</span>鏃ユ湡鏃堕棿
      </button>
      <button class="tool" onclick="sendText('娓呴櫎涓存椂鏂囨。')">
        <span class="tool-i">馃棏锔?/span>娓呴櫎缂撳瓨
      </button>
    </div>
  </div>

  <div id="tool-modal" class="tool-modal-overlay" onclick="closeToolModal(event)">
    <div class="tool-modal">
      <div class="tool-modal-head">
        <div>
          <div id="tool-modal-title" class="tool-modal-title">宸ュ叿</div>
          <div id="tool-modal-sub" class="tool-modal-sub">鏈湴灏忓伐鍏凤紝涓嶅崰鐢?Agent 浠诲姟</div>
        </div>
        <button class="tool-modal-close" onclick="closeToolModal()">脳</button>
      </div>
      <div id="tool-modal-body" class="tool-modal-body"></div>
    </div>
  </div>

  <!-- Quote -->
  <div>
    <div class="ps-title">浠婃棩涓€鍙?/div>
    <div class="quote-card">
      <div class="quote-text" id="q-text"></div>
      <div class="quote-by" id="q-by"></div>
    </div>
  </div>

</aside>
</div>

<script>
marked.setOptions({breaks:true,gfm:true});

// 鈹€鈹€ Constants 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
const INTENT_LABELS = {
  literature_search:           '文献检索',
  paper_download:              '下载论文',
  research_literature_reading: '阅读文献',
  paper_qa:                    '论文问答',
  add_to_library:              '加入知识库',
  library_qa:                  '知识库查询',
  clear_temp_rag:              '清除缓存',
  summarize_session:           '生成摘要',
  general_chat:                '对话',
};

INTENT_LABELS.paper_writing = '论文写作';

const QUOTES = [
  {t:'"Science is the pursuit of truth, knowledge is its reward."',by:'鈥?Li Ka Shing'},
  {t:'"Research is seeing what everybody has seen and thinking what nobody has thought."',by:'鈥?Albert Szent-Gy枚rgyi'},
  {t:'"An investment in knowledge pays the best interest."',by:'鈥?Benjamin Franklin'},
  {t:'"The art of research is finding the signal in the noise."',by:'鈥?Anonymous'},
  {t:'"In the middle of difficulty lies opportunity."',by:'鈥?Albert Einstein'},
  {t:'"A problem well stated is a problem half solved."',by:'鈥?Charles Kettering'},
  {t:'"Equipped with his five senses, man explores the universe around him and calls the adventure Science."',by:'鈥?Edwin Hubble'},
];

// 鈹€鈹€ State 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
let ws         = null;
let reconnTimer= null;
let thinkingEl = null;
let generating = false;
let storedPapers = [];
let foundPapers = [];
let progressSteps = [];
let progressTimer = null;
let compressionState = null;
let chatStarted  = false;
let turnCount    = 0;
let currentSid   = null;   // active session id
let sessions     = [];     // [{session_id, title, message_count, updated_at}]
let pendingImage = null;   // {image_path, image_url, filename}

// 鈹€鈹€ WebSocket 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
function connect() {
  setDot('conn');
  ws = new WebSocket(`ws://${location.host}/ws`);
  ws.onopen    = () => { setDot(''); clearTimeout(reconnTimer); setSend(true); refreshPanel(); };
  ws.onclose   = () => { setDot('off'); setGenerating(false); setSend(false); reconnTimer = setTimeout(connect,3000); };
  ws.onerror   = () => setDot('off');
  ws.onmessage = e  => onMsg(JSON.parse(e.data));
}

function onMsg(d) {
  if (d.type === 'status') { showThinking(d); return; }
  removeThinking();
  setGenerating(false);
  if (d.type === 'stopped') { toast(d.text || '已停止回复'); return; }
  if (d.type === 'error') { addMsg('assistant', `**错误：** ${d.text}`, null); return; }
  if (d.type === 'reply') {
    addMsg('assistant', d.reply || '（无回复）', d.intent, d.evaluation || null);
    if (d.papers_found?.length)  updateFound(d.papers_found);
    if (d.stored_papers)         updateDownloaded(d.stored_papers);
    if (d.compression)           updateCompression(d.compression);
    if (['add_to_library','clear_temp_rag'].includes(d.intent)) { refreshPanel(); loadLibraries(); }
    if (d.intent && d.intent.includes('note')) loadNotes();
    if (d.intent === 'clear_temp_rag') clearPanels();
  }
}

// 鈹€鈹€ Session management 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
const ACTIVE_VIEW_KEY = 'research-agent-active-view';

async function initSessions() {
  try {
    const r = await fetch('/api/sessions');
    const d = await r.json();
    sessions = d.sessions || [];
    if (sessions.length > 0) {
      await switchSession(sessions[0].session_id, false, true);
    } else {
      await createSession(true);
    }
  } catch(e) {
    console.warn('initSessions failed', e);
    await createSession(true);
  }
}

async function createSession(preserveView = false) {
  try {
    const r = await fetch('/api/sessions', {method:'POST'});
    const d = await r.json();
    currentSid = d.session_id;
    sessions.unshift({session_id: d.session_id, title:'鏂板缓瀵硅瘽', message_count:0, updated_at:''});
    sessions = sessions.slice(0, 30);
    renderSessionList();
    resetChatUI();
    if (!preserveView) showChatView(document.getElementById('nav-chat'));
  } catch(e) {
    console.warn('createSession failed', e);
  }
}

async function switchSession(sid, scrollBottom = true, preserveView = false) {
  currentSid = sid;
  resetChatUI();
  if (!preserveView) showChatView(document.getElementById('nav-chat'));
  try {
    const r = await fetch(`/api/sessions/${sid}`);
    const d = await r.json();
    const hist = d.conversation_history || [];
    if (hist.length > 0) {
      chatStarted = true;
      document.getElementById('welcome').classList.add('gone');
      document.getElementById('chat-view').classList.add('on');
      hist.forEach(m => addMsg(m.role, m.content, null));
      if (scrollBottom) {
        const wrap = document.getElementById('messages');
        wrap.scrollTop = wrap.scrollHeight;
      }
    }
    updateFound(d.found_papers   || []);
    updateDownloaded(d.stored_papers || []);
    updateLibrary(d.library || []);
    updateCompression(d.compression || null);
  } catch(e) {
    console.warn('switchSession failed', e);
  }
  renderSessionList();
}

async function deleteSession(sid, ev) {
  ev.stopPropagation();
  if (!confirm('删除这条对话记录？')) return;
  try {
    await fetch(`/api/sessions/${sid}`, {method:'DELETE'});
  } catch(e) {}
  sessions = sessions.filter(s => s.session_id !== sid);
  if (currentSid === sid) {
    if (sessions.length > 0) {
      await switchSession(sessions[0].session_id);
    } else {
      await createSession();
    }
  } else {
    renderSessionList();
  }
}

async function refreshPanel() {
  if (!currentSid) return;
  try {
    const r = await fetch(`/api/sessions/${currentSid}`);
    const d = await r.json();
    updateFound(d.found_papers   || []);
    updateDownloaded(d.stored_papers || []);
    updateLibrary(d.library || []);
  } catch(e) {}
}

function resetChatUI() {
  document.getElementById('messages').innerHTML = '';
  document.getElementById('welcome').classList.remove('gone');
  document.getElementById('chat-view').classList.remove('on');
  chatStarted  = false;
  storedPapers = [];
  pendingImage = null;
  updateCompression(null);
  clearPanels();
}

function renderSessionList() {
  const el = document.getElementById('recent-list');
  if (!sessions.length) {
    el.innerHTML = '<div class="recent-empty">鏆傛棤鍘嗗彶瀵硅瘽</div>';
    return;
  }
  el.innerHTML = sessions.map(s => `
    <div class="recent-item${s.session_id === currentSid ? ' active' : ''}"
         onclick="switchSession('${esc(s.session_id)}')">
      <span class="recent-title">${esc(s.title||'鏂板缓瀵硅瘽')}</span>
      <button class="recent-del" title="鍒犻櫎" onclick="deleteSession('${esc(s.session_id)}',event)">鉁?/button>
    </div>`
  ).join('');
}

// 鈹€鈹€ Send 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
function send() {
  const inp = document.getElementById('user-input');
  const txt = inp.value.trim();
  if (!txt || !ws || ws.readyState !== WebSocket.OPEN) return;
  sendText(txt);
  inp.value = '';
  autoResize(inp);
}

function sendText(txt) {
  if (!txt || !currentSid) return;
  if (!chatStarted) startChat();
  removeThinking();
  addMsg('user', txt, null);
  setGenerating(true);
  if (ws?.readyState === WebSocket.OPEN) {
    const payload = {session_id: currentSid, message: txt};
    if (pendingImage?.image_path) payload.image_path = pendingImage.image_path;
    ws.send(JSON.stringify(payload));
  }
  pendingImage = null;
  turnCount++;
  updateUsage();
  // Update cached title on first user message
  const s = sessions.find(x => x.session_id === currentSid);
  if (s && s.message_count === 0) {
    s.title = txt.slice(0, 50);
    renderSessionList();
  }
  if (s) s.message_count++;
}

function startChat() {
  chatStarted = true;
  document.getElementById('welcome').classList.add('gone');
  document.getElementById('chat-view').classList.add('on');
}

async function newChat() {
  await createSession();
}

// 鈹€鈹€ Math-safe Markdown renderer 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
// Extracts math blocks BEFORE marked.parse() so underscores/backslashes inside
// formulas are never misinterpreted as Markdown syntax.
function _mdToHtml(text) {
  let s = (text || '')
    .replace(/\\\[([\s\S]*?)\\\]/g, (_, m) => `$$${m}$$`)
    .replace(/\\\(([\s\S]*?)\\\)/g, (_, m) => `$${m}$`);

  const _ms = [];
  // Block math first ($$...$$)
  s = s.replace(/\$\$([\s\S]*?)\$\$/g, (_, m) => {
    _ms.push({ d: true, t: m });
    return `<span class="__km" data-i="${_ms.length - 1}"></span>`;
  });
  // Inline math ($...$) 鈥?no newlines, no nested $
  s = s.replace(/\$([^$\n]+?)\$/g, (_, m) => {
    _ms.push({ d: false, t: m });
    return `<span class="__km" data-i="${_ms.length - 1}"></span>`;
  });

  const wrap = document.createElement('div');
  wrap.innerHTML = (typeof marked !== 'undefined') ? marked.parse(s) : s.replace(/\n/g,'<br>');

  if (_ms.length) {
    if (typeof katex !== 'undefined') {
      wrap.querySelectorAll('.__km').forEach(el => {
        const { d, t } = _ms[+el.dataset.i];
        try {
          const tmp = document.createElement('span');
          tmp.innerHTML = katex.renderToString(t, { displayMode: d, throwOnError: false });
          el.replaceWith(...tmp.childNodes);
        } catch(e) { el.outerHTML = d ? `$$${t}$$` : `$${t}$`; }
      });
    } else {
      // KaTeX not ready 鈥?restore raw delimiters so auto-render can pick them up
      wrap.querySelectorAll('.__km').forEach(el => {
        const { d, t } = _ms[+el.dataset.i];
        el.outerHTML = d ? `$$${t}$$` : `$${t}$`;
      });
    }
  }

  return wrap.innerHTML;
}

// 鈹€鈹€ Messages 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
function addMsg(role, text, intent, evaluation=null) {
  const wrap = document.getElementById('messages');
  const row  = mk('div', `msg ${role}`);
  const av   = mk('div', 'av');
  if (role === 'user') {
    av.classList.add('user-msg-av');
    renderAvatar(av, currentProfile.avatar, currentProfile.display_name || '研究者');
  } else {
    av.textContent = 'AI';
  }

  const body = mk('div', 'msg-body');
  if (role === 'assistant' && intent && INTENT_LABELS[intent]) {
    const lbl = mk('span','intent-lbl');
    lbl.textContent = INTENT_LABELS[intent];
    body.appendChild(lbl);
  }
  const bub   = mk('div','bubble');
  const inner = mk('div');
  inner.innerHTML = _mdToHtml(text);
  bub.appendChild(inner);
  if (role === 'assistant' && evaluation) {
    bub.appendChild(renderEvaluation(evaluation));
  }
  body.appendChild(bub);
  row.appendChild(av);
  row.appendChild(body);
  wrap.appendChild(row);
  wrap.scrollTop = wrap.scrollHeight;
}

function renderEvaluation(ev) {
  const strip = mk('div','eval-strip');
  const label = mk('span', `eval-chip ${evalClass(Math.min(ev.faithfulness ?? 0, ev.answer_relevancy ?? 0, ev.context_precision ?? 0))}`);
  label.textContent = `${ev.label || 'RAG评测'} · ${ev.backend || 'eval'}`;
  strip.appendChild(label);
  [
    ['忠实', ev.faithfulness, 'Faithfulness：回答是否被上下文支持'],
    ['相关', ev.answer_relevancy, 'Answer Relevancy：回答是否切题'],
    ['检索', ev.context_precision, 'Context Precision：检索片段是否相关'],
  ].forEach(([name, val, title]) => {
    if (typeof val !== 'number') return;
    const chip = mk('span', `eval-chip ${evalClass(val)}`);
    chip.title = title || name;
    chip.textContent = `${name} ${val.toFixed(2)}`;
    strip.appendChild(chip);
  });
  if (ev.warning) {
    const warn = mk('div','eval-warning');
    warn.textContent = ev.warning;
    strip.appendChild(warn);
  }
  if (ev.rationale) {
    const why = mk('div','eval-warning');
    why.textContent = ev.rationale;
    strip.appendChild(why);
  }
  return strip;
}

function evalClass(v) {
  if (v >= .7) return 'ok';
  if (v >= .5) return 'warn';
  return 'risk';
}

function showThinking(status = {}) {
  const hasRealPct = typeof status.pct === 'number';
  const text = normalizeProgressText(status.text || '思考中...', status.step);
  const pct = Math.max(0, Math.min(100, Number(status.pct ?? nextLocalProgressPct())));
  if (hasRealPct && progressTimer) {
    clearInterval(progressTimer);
    progressTimer = null;
  }
  if (!thinkingEl) {
    progressSteps = [];
    const wrap = document.getElementById('messages');
    const row  = mk('div','msg assistant'); row.id = 'think-row';
    const av   = mk('div','av'); av.textContent = 'AI';
    const body = mk('div','msg-body');
    const bub  = mk('div','bubble');
    bub.innerHTML = `
      <div class="progress-box">
        <div class="progress-head">
          <div class="progress-title" id="progress-title"></div>
          <div class="progress-pct" id="progress-pct"></div>
        </div>
        <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
        <div class="progress-steps" id="progress-steps"></div>
      </div>`;
    body.appendChild(bub); row.appendChild(av); row.appendChild(body);
    wrap.appendChild(row);
    thinkingEl = row;
  }
  const last = progressSteps[progressSteps.length - 1];
  if (!last || last.text !== text) {
    progressSteps.push({step: status.step || '', text, pct});
    progressSteps = progressSteps.slice(-5);
  }
  const title = document.getElementById('progress-title');
  const pctEl = document.getElementById('progress-pct');
  const fill = document.getElementById('progress-fill');
  const steps = document.getElementById('progress-steps');
  if (title) title.textContent = text;
  if (pctEl) pctEl.textContent = `${pct}%`;
  if (fill) fill.style.width = `${pct}%`;
  if (steps) {
    steps.innerHTML = progressSteps.map((s, i) => `
      <div class="progress-step${i === progressSteps.length - 1 ? ' active' : ''}">
        <span class="progress-dot"></span><span>${esc(s.text)}</span>
      </div>`).join('');
  }
  const wrap = document.getElementById('messages');
  wrap.scrollTop = wrap.scrollHeight;
  if (!hasRealPct && !progressTimer) startLocalProgress();
}

function removeThinking() {
  if (thinkingEl) { thinkingEl.remove(); thinkingEl = null; }
  progressSteps = [];
  if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }
}

function normalizeProgressText(text, step) {
  if (text && text !== '思考中...') return text;
  const labels = {
    start: '接收问题，准备分析任务',
    intent: '识别用户意图和需要调用的 Agent',
    route: '确定执行路径',
    plan: '规划工具和 Agent 调用',
    evaluation: '进行回答质量评测',
    done: '完成',
  };
  return labels[step] || '正在分析任务';
}

function nextLocalProgressPct() {
  const last = progressSteps[progressSteps.length - 1]?.pct;
  if (typeof last === 'number') return Math.min(last + 7, 88);
  return 12;
}

function startLocalProgress() {
  const fallback = [
    ['intent', '识别用户意图和任务类型', 18],
    ['route', '选择合适的 Agent 和工具', 30],
    ['work', '检索上下文并组织中间结果', 48],
    ['answer', '生成回答并检查依据', 68],
    ['finalize', '整理回复内容', 82],
  ];
  let idx = 0;
  progressTimer = setInterval(() => {
    if (!thinkingEl || idx >= fallback.length) return;
    const [step, text, pct] = fallback[idx++];
    showThinking({step, text, pct});
  }, 1800);
}

async function stopGeneration() {
  if (!currentSid || !generating) return;
  try {
    await fetch('/api/stop', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({session_id: currentSid}),
    });
  } catch(e) {
    toast('鍋滄璇锋眰澶辫触');
  }
  removeThinking();
  setGenerating(false);
}

// 鈹€鈹€ Right panel 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
function updateFound(papers) {
  foundPapers = papers || [];
  const list = document.getElementById('found-list');
  const sec  = document.getElementById('sec-found');
  document.getElementById('st-found').textContent = foundPapers.length;
  list.innerHTML = '';
  if (!foundPapers.length) { sec.style.display='none'; return; }
  sec.style.display = '';
  renderFound();
}

function renderFound() {
  const list = document.getElementById('found-list');
  const sort = document.getElementById('found-sort')?.value || 'relevance';
  if (!list) return;
  const papers = foundPapers.map((p, idx) => ({...p, _idx: idx + 1}));
  papers.sort((a, b) => {
    if (sort === 'citations') return num(b.citations) - num(a.citations);
    if (sort === 'year') return num(b.year) - num(a.year);
    if (sort === 'relevance') return num(b.relevance_score) - num(a.relevance_score);
    return a._idx - b._idx;
  });
  list.innerHTML = '';
  papers.forEach(p => {
    const card = mk('div','rp-card');
    card.innerHTML = `
      <div class="rp-thumb">PDF</div>
      <div class="rp-info">
        <div class="rp-title">${esc(p.title||'Unknown')}</div>
        <div class="rp-meta">${p.year||''} ${p.citations?` · ${fmtCitations(p.citations)} cites`:''}
          ${p.relevance_score!=null?` · sim ${p.relevance_score.toFixed(2)}`:''}</div>
        <button class="rp-dl" onclick="downloadFoundPaper(${p._idx})">下载第${p._idx}篇</button>
      </div>`;
    list.appendChild(card);
  });
}

function downloadFoundPaper(index) {
  sendText(`下载第${index}篇`);
}

function num(v) {
  const n = Number(v);
  return Number.isFinite(n) ? n : 0;
}

function fmtCitations(v) {
  const n = num(v);
  return n >= 1000 ? `${(n/1000).toFixed(1)}k` : String(n);
}

function updateDownloaded(papers) {
  storedPapers = papers;
  const list = document.getElementById('dl-list');
  const sec  = document.getElementById('sec-dl');
  document.getElementById('st-dl').textContent = papers.length;
  list.innerHTML = '';
  if (!papers.length) { sec.style.display='none'; return; }
  sec.style.display = '';
  papers.forEach((p, idx) => {
    const item  = mk('div','dl-item');
    const title = p.title || 'Unknown';
    item.innerHTML = `
      <span style="font-size:14px">馃搫</span>
      <span class="dl-title" title="${esc(title)}">${esc(title)}</span>
      <div class="dl-acts">
        <button class="sm-btn pri" onclick="draftQuestion('${js(title)}')">鎻愰棶</button>
        <button class="sm-btn" onclick="addStoredPaperToLibrary(${idx}, this)">瀛樺簱</button>
      </div>`;
    list.appendChild(item);
  });
}

async function addStoredPaperToLibrary(index, btn) {
  if (!currentSid) return;
  const oldText = btn?.textContent || '存入库';
  if (btn) {
    btn.disabled = true;
    btn.textContent = '存入中...';
  }
  try {
    const r = await fetch(`/api/sessions/${encodeURIComponent(currentSid)}/library/add`, {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({index, lib_id: activeLibId || 'lt_docs'}),
    });
    const d = await r.json();
    if (!r.ok || !d.success) throw new Error(d.detail || d.message || '存库失败');
    updateStored(d.stored_papers || storedPapers);
    loadLibraries();
    toast(`已加入知识库：${d.added?.[0]?.title || '论文'}`);
  } catch(e) {
    toast(e.message || '存库失败');
    if (btn) {
      btn.disabled = false;
      btn.textContent = oldText;
    }
  }
}

// 鈹€鈹€ Library management 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
let libraries  = [];       // [{lib_id, name, doc_count}]
let activeLibId = 'lt_docs';
let managerLibId = 'all';
let allLibraryDocs = [];
let currentReaderUrl = '';
let currentChunks = [];
let currentFigurePaperId = '';
let currentFigureDownloadUrl = '';
let currentFigureImageUrl = '';
const FIGURE_HISTORY_KEY = 'research_assistant_figure_history_v1';
const FIGURE_BRIEF_HIDDEN_PROMPT = [
  'Interpret the user figure requirement as a scientific illustration request.',
  'If the user is vague, infer a useful paper figure goal from the uploaded paper context.',
  'Prefer concrete visual instructions: layout, modules, arrows, labels, visual hierarchy, and what to avoid.',
  'Keep the final generated prompt faithful to the paper and suitable for academic publication.'
].join('\n');
let currentProfile = {display_name:'研究者', avatar:'', self_description:''};
let llmConfig = {};
let llmOptions = {providers:['ollama','openai','anthropic','qwen','doubao','gemini'], defaults:{}, agents:[]};
let notes = [];
let selectedNoteId = '';
let editingNewNote = false;
const AGENT_LABELS = {
  intent_agent: '意图识别',
  literature_agent: '文献检索',
  reading_agent: '论文阅读',
  note_agent: '科研笔记',
  summary_agent: '总结报告',
  chat_agent: '通用对话',
};

AGENT_LABELS.writing_agent = '论文写作';

async function loadLibraries() {
  try {
    const r = await fetch('/api/libraries');
    const d = await r.json();
    libraries = d.libraries || [];
    const total = libraries.reduce((s, l) => s + (l.doc_count || 0), 0);
    document.getElementById('st-lib').textContent = total;
    renderLibTabs();
    await loadLibDocs(activeLibId);
    await loadPaperManagerDocs();
  } catch(e) { console.warn('loadLibraries', e); }
}

function renderLibTabs() {
  const el = document.getElementById('lib-tabs');
  el.innerHTML = libraries.map(lib => `
    <button class="lib-tab${lib.lib_id === activeLibId ? ' active' : ''}"
            onclick="switchLib('${esc(lib.lib_id)}')">
      ${esc(lib.name)}${lib.lib_id !== 'lt_docs'
        ? `<span class="lib-tab-del" onclick="deleteLib('${esc(lib.lib_id)}',event)">鉁?/span>`
        : ''}
    </button>`
  ).join('');
}

async function switchLib(lib_id) {
  activeLibId = lib_id;
  renderLibTabs();
  await loadLibDocs(lib_id);
}

async function loadLibDocs(lib_id) {
  const el = document.getElementById('lib-doc-list');
  try {
    const r = await fetch(`/api/libraries/${lib_id}/documents`);
    const d = await r.json();
    const docs = d.documents || (d.titles || []).map(t => ({title:t, file_exists:false}));
    el.innerHTML = '';
    if (!docs.length) {
      el.innerHTML = '<div class="empty-tip">姝ょ煡璇嗗簱鏆傛棤鏂囨。</div>';
      return;
    }
    docs.forEach(doc => {
      const t = doc.title || 'Unknown';
      const item = mk('div', 'lib-doc-item');
      item.innerHTML = `
        <span style="font-size:13px">馃搫</span>
        <span class="lib-doc-title" title="${esc(t)}">${esc(t)}</span>
        ${doc.file_exists ? `<button class="sm-btn" onclick="openLibraryDoc('${js(lib_id)}','${js(t)}')">闃呰</button>` : ''}
        <button class="sm-btn pri" onclick="draftLibraryQuestion('${js(t)}')">鎻愰棶</button>
        <button class="lib-doc-del" title="绉婚櫎" onclick="removeLibDoc('${js(lib_id)}','${js(t)}',this)">鉁?/button>`;
      el.appendChild(item);
    });
  } catch(e) {
    el.innerHTML = '<div class="empty-tip">鍔犺浇澶辫触</div>';
  }
}

async function removeLibDoc(lib_id, title, btn) {
  if (!confirm(`浠庣煡璇嗗簱绉婚櫎銆?{title}銆嶏紵`)) return;
  btn.disabled = true;
  try {
    await fetch(`/api/libraries/${lib_id}/documents`,
      {method:'DELETE', headers:{'Content-Type':'application/json'},
       body: JSON.stringify({title})});
    await loadLibDocs(lib_id);
    await loadLibraries();
  } catch(e) { toast('绉婚櫎澶辫触'); btn.disabled = false; }
}

function showCreateLib() {
  document.getElementById('lib-create').style.display = '';
  document.getElementById('lib-name-inp').focus();
}
function cancelCreateLib() {
  document.getElementById('lib-create').style.display = 'none';
  document.getElementById('lib-name-inp').value = '';
}
async function confirmCreateLib() {
  const name = document.getElementById('lib-name-inp').value.trim();
  if (!name) return;
  try {
    const r = await fetch('/api/libraries',
      {method:'POST', headers:{'Content-Type':'application/json'},
       body: JSON.stringify({name})});
    const d = await r.json();
    cancelCreateLib();
    await loadLibraries();
    switchLib(d.lib_id);
  } catch(e) { toast('鍒涘缓澶辫触'); }
}

async function deleteLib(lib_id, ev) {
  ev.stopPropagation();
  const lib = libraries.find(l => l.lib_id === lib_id);
  if (!confirm(`删除知识库「${lib?.name || lib_id}」及其所有文档？`)) return;
  try {
    await fetch(`/api/libraries/${lib_id}`, {method:'DELETE'});
    if (activeLibId === lib_id) activeLibId = 'lt_docs';
    await loadLibraries();
  } catch(e) { toast('删除失败'); }
}

async function uploadToLibrary(input) {
  const file = input.files[0];
  if (!file || !currentSid) return;
  input.value = '';
  const chunkSize = parseInt(document.getElementById('lib-chunk-size')?.value || '2000', 10);
  const chunkOverlap = parseInt(document.getElementById('lib-chunk-overlap')?.value || '200', 10);
  if (!Number.isFinite(chunkSize) || chunkSize < 200 || chunkSize > 4000) {
    toast('chunk size 需要在 200 到 4000 之间');
    return;
  }
  if (!Number.isFinite(chunkOverlap) || chunkOverlap < 0 || chunkOverlap >= chunkSize) {
    toast('overlap 需要大于等于 0 且小于 chunk size');
    return;
  }
  toast(`正在上传并嵌入 ${file.name}...`);
  const form = new FormData();
  form.append('file', file);
  try {
    const url = `/api/upload?session_id=${encodeURIComponent(currentSid)}&lib_id=${encodeURIComponent(activeLibId)}&chunk_size=${encodeURIComponent(chunkSize)}&chunk_overlap=${encodeURIComponent(chunkOverlap)}`;
    const r   = await fetch(url, {method:'POST', body:form});
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`上传失败：${e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    if (d.embed_error) {
      toast(`涓婁紶鎴愬姛浣嗗祵鍏ュけ璐ワ細${d.embed_error}`);
    } else {
      toast(`已嵌入 ${d.chunks_indexed} 个片段`);
    }
    await loadLibraries();
    await loadLibDocs(activeLibId);
    updateDownloaded(d.stored_papers || []);
    renderPaperManager();
  } catch(err) {
    toast(`上传出错：${err.message}`);
  }
}

async function loadPaperManagerDocs() {
  const batches = await Promise.all(libraries.map(async lib => {
    try {
      const r = await fetch(`/api/libraries/${encodeURIComponent(lib.lib_id)}/documents`);
      const d = await r.json();
      return (d.documents || []).map(doc => ({...doc, lib_name: lib.name, lib_id: lib.lib_id}));
    } catch(e) {
      return [];
    }
  }));
  allLibraryDocs = batches.flat();
  renderPaperManagerTabs();
  renderPaperManager();
}

function renderPaperManagerTabs() {
  const el = document.getElementById('paper-lib-tabs');
  if (!el) return;
  const tabs = [{lib_id:'all', name:'鍏ㄩ儴'}, ...libraries];
  el.innerHTML = tabs.map(lib => `
    <button class="lib-tab${lib.lib_id === managerLibId ? ' active' : ''}"
            onclick="switchPaperManagerLib('${js(lib.lib_id)}')">${esc(lib.name)}</button>`
  ).join('');
}

function switchPaperManagerLib(lib_id) {
  managerLibId = lib_id;
  renderPaperManagerTabs();
  renderPaperManager();
}

function updatePaperManagerStats(visibleDocs) {
  const allDocs = allLibraryDocs || [];
  const visible = visibleDocs || [];
  const totalEl = document.getElementById('paper-stat-total');
  const visibleEl = document.getElementById('paper-stat-visible');
  const chunksEl = document.getElementById('paper-stat-chunks');
  const missingEl = document.getElementById('paper-stat-missing');
  const chunks = visible.reduce((sum, d) => sum + Number(d.chunk_count || 0), 0);
  const missing = visible.filter(d => !d.file_exists).length;
  if (totalEl) totalEl.textContent = allDocs.length;
  if (visibleEl) visibleEl.textContent = visible.length;
  if (chunksEl) chunksEl.textContent = chunks;
  if (missingEl) missingEl.textContent = missing;
}

function renderPaperManager() {
  const body = document.getElementById('paper-manager-body');
  if (!body) return;
  const q = (document.getElementById('paper-search')?.value || '').trim().toLowerCase();
  const sort = document.getElementById('paper-sort')?.value || 'newest';
  let docs = allLibraryDocs;
  if (managerLibId !== 'all') docs = docs.filter(d => d.lib_id === managerLibId);
  if (q) {
    docs = docs.filter(d =>
      `${d.title || ''} ${d.lib_name || ''} ${d.file_ext || ''}`.toLowerCase().includes(q)
    );
  }
  docs = [...docs].sort((a, b) => {
    if (sort === 'title') return (a.title || '').localeCompare(b.title || '');
    const at = Date.parse(a.indexed_at || '') || 0;
    const bt = Date.parse(b.indexed_at || '') || 0;
    return sort === 'oldest' ? at - bt : bt - at;
  });
  updatePaperManagerStats(docs);
  if (!docs.length) {
    body.innerHTML = '<tr><td colspan="6"><div class="paper-empty">暂无匹配文献</div></td></tr>';
    return;
  }
  body.innerHTML = docs.map(d => {
    const title = d.title || 'Unknown';
    const ext = d.file_ext ? d.file_ext.replace('.', '').toUpperCase() : '未知';
    const canRead = !!d.file_exists;
    const indexedAt = fmtTime(d.indexed_at);
    return `
      <tr>
        <td>
          <div class="paper-name" title="${esc(title)}">${esc(title)}</div>
          <div class="paper-meta">${esc((d.sections || []).slice(0,3).join(' / ') || '已索引文献')}</div>
        </td>
        <td><span class="chip">${esc(d.lib_name || d.lib_id || '')}</span></td>
        <td><span class="paper-meta">${esc(indexedAt)}</span></td>
        <td><button class="sm-btn" onclick="openChunkViewer('${js(d.lib_id)}','${js(title)}')">${d.chunk_count || 0}</button></td>
        <td>${canRead ? esc(ext) : '<span class="paper-meta">文件缺失</span>'}</td>
        <td>
          <div class="paper-actions">
            <button class="sm-btn pri" ${canRead ? '' : 'disabled'} onclick="openLibraryDoc('${js(d.lib_id)}','${js(title)}')">阅读</button>
            <button class="sm-btn" onclick="draftLibraryQuestion('${js(title)}')">提问</button>
          </div>
        </td>
      </tr>`;
  }).join('');
}

function openLibraryDoc(lib_id, title) {
  const url = `/api/libraries/${encodeURIComponent(lib_id)}/documents/file?title=${encodeURIComponent(title)}`;
  currentReaderUrl = url;
  document.getElementById('reader-title').textContent = title;
  document.getElementById('reader-frame').src = url;
  document.getElementById('reader-fallback').classList.remove('on');
  document.getElementById('reader-overlay').classList.add('on');
  setTimeout(() => document.getElementById('reader-fallback').classList.add('on'), 1800);
}

async function openChunkViewer(lib_id, title) {
  const overlay = document.getElementById('chunk-overlay');
  const list = document.getElementById('chunk-list');
  document.getElementById('chunk-title').textContent = title;
  document.getElementById('chunk-filter').value = '';
  document.getElementById('chunk-stat').textContent = 'Loading...';
  currentChunks = [];
  list.innerHTML = '<div class="paper-empty">Loading chunks...</div>';
  overlay.classList.add('on');
  try {
    const url = `/api/libraries/${encodeURIComponent(lib_id)}/documents/chunks?title=${encodeURIComponent(title)}`;
    const r = await fetch(url);
    if (!r.ok) throw new Error(await r.text());
    const d = await r.json();
    currentChunks = d.chunks || [];
    renderChunks();
  } catch (e) {
    document.getElementById('chunk-stat').textContent = '';
    list.innerHTML = `<div class="paper-empty">鍔犺浇 chunk 澶辫触锛?{esc(e.message || e)}</div>`;
  }
}

function renderChunks() {
  const list = document.getElementById('chunk-list');
  const stat = document.getElementById('chunk-stat');
  const q = (document.getElementById('chunk-filter')?.value || '').trim().toLowerCase();
  let chunks = currentChunks;
  if (q) {
    chunks = chunks.filter(c => {
      const meta = c.metadata || {};
      return `${c.text || ''} ${c.section || ''} ${c.chunk_type || ''} ${meta.parser || ''}`.toLowerCase().includes(q);
    });
  }
  stat.textContent = `${chunks.length} / ${currentChunks.length} chunks`;
  if (!chunks.length) {
    list.innerHTML = '<div class="paper-empty">娌℃湁鍖归厤鐨?chunk</div>';
    return;
  }
  list.innerHTML = chunks.map((c, i) => {
    const meta = c.metadata || {};
    const bits = [
      `section: ${c.section || '-'}`,
      `type: ${c.chunk_type || 'text'}`,
      `page: ${c.page || '-'}`,
      `len: ${c.length || 0}`,
      meta.chunk_size ? `size: ${meta.chunk_size}` : '',
      meta.chunk_overlap !== undefined ? `overlap: ${meta.chunk_overlap}` : '',
      meta.parser ? `parser: ${meta.parser}` : '',
      c.id || '',
    ].filter(Boolean);
    return `
      <div class="chunk-card">
        <div class="chunk-card-head">
          <span class="chunk-no">#${c.global_chunk ?? i}</span>
          ${bits.map(b => `<span>${esc(String(b))}</span>`).join('')}
        </div>
        <div class="chunk-text">${esc(c.text || '')}</div>
      </div>`;
  }).join('');
}

function closeChunkViewer(event) {
  if (event && event.target !== document.getElementById('chunk-overlay')) return;
  document.getElementById('chunk-overlay').classList.remove('on');
  currentChunks = [];
}

function closeReader(event) {
  if (event && event.target !== document.getElementById('reader-overlay')) return;
  document.getElementById('reader-overlay').classList.remove('on');
  document.getElementById('reader-frame').src = 'about:blank';
  document.getElementById('reader-fallback').classList.remove('on');
}

function openReaderInNewWindow() {
  if (currentReaderUrl) window.open(currentReaderUrl, '_blank', 'noopener');
}

function draftQuestion(title) {
  draftText(`关于《${title}》，`);
  toast('已填入输入框，可补充问题后发送');
}

function draftLibraryQuestion(title) {
  draftText(`请从我的知识库中，关于《${title}》，`);
  toast('已填入知识库提问草稿，可补充问题后发送');
}

function draftText(text) {
  showChatView(document.getElementById('nav-chat'));
  if (!chatStarted) startChat();
  const inp = document.getElementById('user-input');
  inp.value = text;
  autoResize(inp);
  setSend(true);
  inp.focus();
  inp.setSelectionRange(inp.value.length, inp.value.length);
}

let toolCalendarDate = new Date();
let dateTimeTimer = null;

const calendarHolidayRules = {
  rest: new Set([
    '2026-01-01','2026-01-02','2026-01-03',
    '2026-02-15','2026-02-16','2026-02-17','2026-02-18','2026-02-19','2026-02-20','2026-02-21','2026-02-22','2026-02-23',
    '2026-04-04','2026-04-05','2026-04-06',
    '2026-05-01','2026-05-02','2026-05-03','2026-05-04','2026-05-05',
    '2026-06-19','2026-06-20','2026-06-21',
    '2026-09-25','2026-09-26','2026-09-27',
    '2026-10-01','2026-10-02','2026-10-03','2026-10-04','2026-10-05','2026-10-06','2026-10-07',
  ]),
  work: new Set([
    '2026-01-04',
    '2026-02-14','2026-02-28',
    '2026-05-09',
    '2026-09-20','2026-10-10',
  ]),
};

function formatLocalDate(date) {
  return `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
}

function getCalendarDayType(date) {
  const iso = formatLocalDate(date);
  if (calendarHolidayRules.work.has(iso)) return 'workday';
  if (calendarHolidayRules.rest.has(iso)) return 'restday';
  const weekday = date.getDay();
  return (weekday === 0 || weekday === 6) ? 'restday' : 'workday';
}

function openToolModal(title, sub, html) {
  stopDateTimeTicker();
  const modal = document.getElementById('tool-modal');
  document.getElementById('tool-modal-title').textContent = title;
  document.getElementById('tool-modal-sub').textContent = sub || '鏈湴灏忓伐鍏凤紝涓嶅崰鐢?Agent 浠诲姟';
  document.getElementById('tool-modal-body').innerHTML = html;
  modal.classList.add('on');
}

function closeToolModal(event) {
  if (event && event.target !== document.getElementById('tool-modal')) return;
  stopDateTimeTicker();
  document.getElementById('tool-modal')?.classList.remove('on');
}

function openCalculator() {
  openToolModal('计算器', '支持根号、对数、指数、幂和括号', `
    <input id="calc-input" class="tool-input" placeholder="例如：sqrt(16)+log(100)+2^8+exp(1)" onkeydown="if(event.key==='Enter') calcRun()">
    <div class="tool-row">
      <button class="sm-btn pri" onclick="calcRun()">计算</button>
      <button class="sm-btn" onclick="document.getElementById('calc-input').value='';document.getElementById('calc-result').innerHTML='等待输入表达式'">清空</button>
      <button class="sm-btn" onclick="draftText('请帮我计算：' + (document.getElementById('calc-input').value || ''))">放入对话框</button>
    </div>
    <div class="paper-meta" style="margin-top:8px">函数：sqrt(x)、log(x)、ln(x)、exp(x)、pow(a,b)、sin/cos/tan；常量：pi、e；幂可写 2^8。</div>
    <div id="calc-result" class="tool-result">等待输入表达式</div>
  `);
  setTimeout(() => document.getElementById('calc-input')?.focus(), 0);
}

function normalizeCalcExpression(expr) {
  let s = expr.toLowerCase().replace(/π/g, 'pi').replace(/√/g, 'sqrt');
  if (!/^[0-9a-z_+\-*/().,%\s^]+$/.test(s)) throw new Error('unsupported chars');
  const allowed = new Set(['sqrt','log','ln','exp','pow','sin','cos','tan','abs','floor','ceil','round','pi','e']);
  const names = s.match(/[a-z_]+/g) || [];
  for (const name of names) {
    if (!allowed.has(name)) throw new Error(`unsupported function: ${name}`);
  }
  s = s.replace(/\^/g, '**');
  s = s.replace(/\bpi\b/g, 'Math.PI').replace(/\be\b/g, 'Math.E');
  const fnMap = {
    sqrt:'Math.sqrt',
    log:'Math.log10',
    ln:'Math.log',
    exp:'Math.exp',
    pow:'Math.pow',
    sin:'Math.sin',
    cos:'Math.cos',
    tan:'Math.tan',
    abs:'Math.abs',
    floor:'Math.floor',
    ceil:'Math.ceil',
    round:'Math.round',
  };
  return s.replace(/\b(sqrt|log|ln|exp|pow|sin|cos|tan|abs|floor|ceil|round)\s*\(/g, (_, fn) => `${fnMap[fn]}(`);
}

function formatCalcResult(value) {
  const normalized = Math.abs(value) < 1e-12 ? 0 : value;
  return String(normalized);
}

function calcRun() {
  const input = document.getElementById('calc-input');
  const result = document.getElementById('calc-result');
  const expr = (input?.value || '').trim();
  if (!expr) { result.textContent = '请输入表达式'; return; }
  try {
    const normalized = normalizeCalcExpression(expr);
    const value = Function(`"use strict"; return (${normalized})`)();
    if (!Number.isFinite(value)) throw new Error('invalid result');
    result.innerHTML = `<span>结果</span><br><strong>${esc(formatCalcResult(value))}</strong><div class="paper-meta">表达式：${esc(expr)}</div>`;
  } catch(e) {
    result.textContent = '表达式无法计算，请检查函数名、括号或运算符';
  }
}

function openCalendarTool() {
  toolCalendarDate = new Date();
  openToolModal('日历', '点击日期可放入对话框', '<div id="calendar-body"></div>');
  renderCalendarTool();
}

function shiftCalendarMonth(delta) {
  toolCalendarDate = new Date(toolCalendarDate.getFullYear(), toolCalendarDate.getMonth() + delta, 1);
  renderCalendarTool();
}

function renderCalendarTool() {
  const box = document.getElementById('calendar-body');
  if (!box) return;
  const year = toolCalendarDate.getFullYear();
  const month = toolCalendarDate.getMonth();
  const today = new Date();
  const firstDay = new Date(year, month, 1).getDay();
  const days = new Date(year, month + 1, 0).getDate();
  const prevDays = new Date(year, month, 0).getDate();
  const cells = [];
  for (let i = firstDay - 1; i >= 0; i--) cells.push({day: prevDays - i, muted:true});
  for (let d = 1; d <= days; d++) cells.push({day:d, date:new Date(year, month, d)});
  let nextDay = 1;
  while (cells.length % 7) cells.push({day: nextDay++, muted:true});
  const weeks = ['日','一','二','三','四','五','六'];
  box.innerHTML = `
    <div class="calendar-head">
      <button class="sm-btn" onclick="shiftCalendarMonth(-1)">上月</button>
      <div class="calendar-title">${year} 年 ${month + 1} 月</div>
      <button class="sm-btn" onclick="shiftCalendarMonth(1)">下月</button>
    </div>
    <div class="calendar-grid">
      ${weeks.map(w => `<div class="calendar-cell head">${w}</div>`).join('')}
      ${cells.map(c => {
        const isToday = c.date && c.date.toDateString() === today.toDateString();
        const iso = c.date ? formatLocalDate(c.date) : '';
        const dayType = c.date ? getCalendarDayType(c.date) : 'workday';
        const tag = c.date ? (dayType === 'restday' ? '休' : '班') : '';
        return `<button class="calendar-cell${c.muted ? ' muted' : ''}${isToday ? ' today' : ''} ${dayType}" ${c.date ? `onclick="draftText('请帮我安排 ${iso} 的科研计划：')"` : ''}><span class="calendar-day">${c.day}</span>${tag ? `<span class="calendar-tag">${tag}</span>` : ''}</button>`;
      }).join('')}
    </div>
    <div class="calendar-legend">
      <span><i></i>工作日</span>
      <span class="rest"><i></i>休息日</span>
    </div>
    <div class="calendar-note">2026 年按节假日安排显示调休；其他年份按周末规则显示。</div>
  `;
}

function openWordCounter() {
  openToolModal('字数统计', '统计字符、中文字数、英文词数和段落', `
    <textarea id="word-counter-input" class="tool-textarea" placeholder="粘贴文本..." oninput="updateWordCounter()"></textarea>
    <div class="tool-stat-grid">
      <div class="tool-stat"><strong id="wc-chars">0</strong><span>字符</span></div>
      <div class="tool-stat"><strong id="wc-zh">0</strong><span>中文字符</span></div>
      <div class="tool-stat"><strong id="wc-words">0</strong><span>英文词</span></div>
      <div class="tool-stat"><strong id="wc-lines">0</strong><span>行数</span></div>
      <div class="tool-stat"><strong id="wc-paras">0</strong><span>段落</span></div>
      <div class="tool-stat"><strong id="wc-reading">0</strong><span>分钟阅读</span></div>
    </div>
  `);
  setTimeout(() => document.getElementById('word-counter-input')?.focus(), 0);
}

function updateWordCounter() {
  const text = document.getElementById('word-counter-input')?.value || '';
  const zh = (text.match(/[\u4e00-\u9fff]/g) || []).length;
  const words = (text.match(/[A-Za-z0-9]+(?:[-'][A-Za-z0-9]+)*/g) || []).length;
  const lines = text ? text.split(/\n/).length : 0;
  const paras = text.trim() ? text.trim().split(/\n\s*\n/).length : 0;
  const minutes = text.trim() ? Math.max(1, Math.ceil((zh + words) / 450)) : 0;
  document.getElementById('wc-chars').textContent = text.length;
  document.getElementById('wc-zh').textContent = zh;
  document.getElementById('wc-words').textContent = words;
  document.getElementById('wc-lines').textContent = lines;
  document.getElementById('wc-paras').textContent = paras;
  document.getElementById('wc-reading').textContent = minutes;
}

function stopDateTimeTicker() {
  if (dateTimeTimer) {
    clearTimeout(dateTimeTimer);
    dateTimeTimer = null;
  }
}

function currentDateTimeParts() {
  const now = new Date();
  return {
    date: now.toLocaleDateString('zh-CN', {year:'numeric', month:'2-digit', day:'2-digit', weekday:'long'}),
    time: now.toLocaleTimeString('zh-CN', {hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:false}),
  };
}

function updateDateTimeTool() {
  const parts = currentDateTimeParts();
  const dateEl = document.getElementById('datetime-date');
  const timeEl = document.getElementById('datetime-time');
  const dateBtn = document.getElementById('datetime-insert-date');
  const fullBtn = document.getElementById('datetime-insert-full');
  if (dateEl) dateEl.textContent = parts.date;
  if (timeEl) timeEl.textContent = parts.time;
  if (dateBtn) dateBtn.onclick = () => draftText(parts.date);
  if (fullBtn) fullBtn.onclick = () => draftText(`${parts.date} ${parts.time}`);
}

function startDateTimeTicker() {
  stopDateTimeTicker();
  const tick = () => {
    updateDateTimeTool();
    dateTimeTimer = setTimeout(tick, Math.max(250, 1000 - new Date().getMilliseconds()));
  };
  tick();
}

function openDateTimeTool() {
  openToolModal('鏃ユ湡鏃堕棿', '蹇€熸彃鍏ユ棩鏈熸垨鏃堕棿', `
    <div class="tool-result">
      <div>褰撳墠鏃ユ湡</div>
      <div id="datetime-date" class="datetime-date"></div>
      <div style="margin-top:10px">褰撳墠鏃堕棿</div>
      <div id="datetime-time" class="datetime-clock"></div>
    </div>
    <div class="tool-row">
      <button id="datetime-insert-date" class="sm-btn pri">鎻掑叆鏃ユ湡</button>
      <button id="datetime-insert-full" class="sm-btn">鎻掑叆鏃ユ湡鏃堕棿</button>
    </div>
  `);
  startDateTimeTicker();
}

function writingPick(btn, groupId) {
  const group = document.getElementById(groupId);
  if (!group) return;
  group.querySelectorAll('.write-chip-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}
function writingVal(groupId) {
  return document.querySelector(`#${groupId} .write-chip-btn.active`)?.dataset.value || '';
}
function writingPickSource(btn) {
  if (!btn || btn.dataset.value === 'current') return;
  document.querySelectorAll('#writing-source-options .write-source-card').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const input = document.getElementById('writing-source');
  if (input) input.value = btn.dataset.value || 'upload';
}
function writingTemplate(kind) {
  const task = document.getElementById('writing-task');
  const brief = document.getElementById('writing-brief');
  const topic = document.getElementById('writing-topic');
  if (!brief || !task) return;
  const t = topic?.value.trim() || '当前研究主题';
  const templates = {
    related: ['related_work', `请根据我的知识库，围绕“${t}”写一段 related work。要求概括已有方法的主要脉络、关键挑战和不足，保留引用线索，避免虚构论文和实验结果。`],
    intro: ['introduction', `请围绕“${t}”写 introduction 初稿。结构包括研究背景、核心问题、现有方法局限、本研究动机。语气正式，逻辑连贯。`],
    rewrite: ['academic_rewrite', '请将下方素材中的文字改写为更学术、更凝练的论文表达。保持原意，不新增未经素材支持的事实。']
  };
  const item = templates[kind] || templates.related;
  task.value = item[0];
  brief.value = item[1];
}
function writingInsertCitationRule() {
  const brief = document.getElementById('writing-brief');
  if (!brief) return;
  const rule = '请保留引用线索；只能引用检索素材或我粘贴素材中真实存在的信息，不要编造作者、年份、指标或实验结果。';
  brief.value = brief.value.trim() ? `${brief.value.trim()}\n\n${rule}` : rule;
  brief.focus();
}
function writingBuildPrompt() {
  const task = document.getElementById('writing-task')?.value || 'related_work';
  const topic = document.getElementById('writing-topic')?.value.trim();
  const brief = document.getElementById('writing-brief')?.value.trim();
  const material = document.getElementById('writing-material')?.value.trim();
  const rawSource = document.getElementById('writing-source')?.value || 'upload';
  const source = rawSource === 'current' ? 'upload' : rawSource;
  const lang = writingVal('writing-lang') || 'zh';
  const style = writingVal('writing-style') || 'academic';
  const length = writingVal('writing-length') || 'medium';
  const sourceText = {
    upload: '请优先使用我在写作助手中上传的文件素材。',
    library: '请优先从我的文献库检索相关素材后再写作。',
    rewrite: '请只基于我在下方提供的文本进行改写或扩写。'
  }[source] || '';
  const materialPaths = writingUploadedFiles.map(f => f.paper?.local_path).filter(Boolean);
  return [
    `WRITING_SOURCE=${source}`,
    materialPaths.length ? `WRITING_MATERIAL_PATHS=${materialPaths.join('|')}` : '',
    '请调用 Writing Agent 完成论文写作任务。',
    `任务类型：${task}`,
    topic ? `主题：${topic}` : '',
    `约束：language=${lang}, style=${style}, length=${length}, citation_required=true`,
    sourceText,
    writingUploadedFiles.length ? `写作素材文件路径：${writingUploadedFiles.map(f => f.paper?.local_path).filter(Boolean).join('；')}` : '',
    writingUploadedFiles.length ? `已上传写作素材：${writingUploadedFiles.map(f => f.name).join('；')}` : '',
    brief ? `写作说明：\n${brief}` : '',
    material ? `我提供的素材：\n${material}` : ''
  ].filter(Boolean).join('\n\n');
}
let writingUploadedFiles = [];
function renderWritingUploads() {
  const box = document.getElementById('writing-upload-list');
  if (!box) return;
  box.innerHTML = writingUploadedFiles.map((f, i) => `
    <div class="write-file-pill ok">
      <span title="${esc(f.name)}">${esc(f.name)}</span>
      <button class="write-file-del" title="绉婚櫎" onclick="removeWritingFile(${i})">脳</button>
    </div>
  `).join('');
}
function removeWritingFile(index) {
  const item = writingUploadedFiles[index];
  writingUploadedFiles.splice(index, 1);
  renderWritingUploads();
  if (item) toast(`宸蹭粠鍐欎綔绱犳潗涓Щ闄わ細${item.name}`);
}
async function uploadWritingFiles(input) {
  const files = [...(input.files || [])];
  input.value = '';
  if (!files.length || !currentSid) return;
  const uploadSource = document.querySelector('#writing-source-options .write-source-card[data-value="upload"]');
  if (uploadSource) writingPickSource(uploadSource);
  const box = document.getElementById('writing-upload-list');
  for (const file of files) {
    if (box) box.insertAdjacentHTML('beforeend', `<div class="write-file-pill"><span>${esc(file.name)} 涓婁紶涓?..</span></div>`);
    const form = new FormData();
    form.append('file', file);
    try {
      const r = await fetch(`/api/upload?session_id=${encodeURIComponent(currentSid)}`, {method:'POST', body:form});
      if (!r.ok) {
        const e = await r.json().catch(() => ({}));
        if (box) box.insertAdjacentHTML('beforeend', `<div class="write-file-pill err"><span>${esc(file.name)} 涓婁紶澶辫触</span></div>`);
        toast(`涓婁紶澶辫触锛?{e.detail || file.name}`);
        continue;
      }
      const d = await r.json();
      writingUploadedFiles.push({name:file.name, paper:d.paper});
      updateDownloaded(d.stored_papers || []);
      renderWritingUploads();
      toast(`宸蹭笂浼犲啓浣滅礌鏉愶細${file.name}`);
    } catch(err) {
      if (box) box.insertAdjacentHTML('beforeend', `<div class="write-file-pill err"><span>${esc(file.name)} 涓婁紶鍑洪敊</span></div>`);
      toast(`涓婁紶鍑洪敊锛?{err.message}`);
    }
  }
}
function writingDraftToChat() {
  draftText(writingBuildPrompt());
}
function writingSubmit() {
  const msg = writingBuildPrompt();
  if (!msg.trim()) return;
  showChatView(document.getElementById('nav-chat'));
  sendText(msg);
}
function writingClear() {
  ['writing-topic','writing-brief','writing-material'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
}
function writingReset() {
  document.getElementById('writing-task').value = 'related_work';
  document.getElementById('writing-source').value = 'upload';
  const uploadSource = document.querySelector('#writing-source-options .write-source-card[data-value="upload"]');
  if (uploadSource) writingPickSource(uploadSource);
  writingClear();
  [['writing-lang','zh'],['writing-style','academic'],['writing-length','medium']].forEach(([id,val]) => {
    document.querySelectorAll(`#${id} .write-chip-btn`).forEach(b => b.classList.remove('active'));
    document.querySelector(`#${id} .write-chip-btn[data-value="${val}"]`)?.classList.add('active');
  });
}
function initWritingNav() {
  const item = [...document.querySelectorAll('#nav .nav-item')]
    .find(n => n.textContent.includes('写作') || n.textContent.includes('Writing'));
  if (!item) return;
  item.id = 'nav-writing';
  item.onclick = () => showWritingView(item);
}
function initWritingSourceLabels() {
  const library = document.querySelector('#writing-source-options .write-source-card[data-value="library"]');
  if (!library) return;
  const title = library.querySelector('.write-source-title');
  const desc = library.querySelector('.write-source-desc');
  if (title) title.textContent = '知识库';
  if (desc) desc.textContent = '检索长期知识库';
}
document.addEventListener('DOMContentLoaded', initWritingNav);
document.addEventListener('DOMContentLoaded', initWritingSourceLabels);

async function loadProfile() {
  try {
    const r = await fetch('/api/profile');
    const d = await r.json();
    currentProfile = {...currentProfile, ...(d.profile || {})};
    renderProfile();
  } catch(e) {
    console.warn('loadProfile failed', e);
  }
}

function renderProfile() {
  const name = currentProfile.display_name || '研究者';
  document.getElementById('user-name').textContent = name;
  renderAvatar(document.getElementById('user-avatar'), currentProfile.avatar, name);
  const nameInput = document.getElementById('profile-name-input');
  if (nameInput) nameInput.value = name;
  const descInput = document.getElementById('profile-desc-input');
  if (descInput) descInput.value = currentProfile.self_description || '';
  const preview = document.getElementById('profile-avatar-preview');
  if (preview) renderAvatar(preview, currentProfile.avatar, name);
  document.querySelectorAll('.user-msg-av').forEach(el => renderAvatar(el, currentProfile.avatar, name));
}

function renderAvatar(el, avatar, name) {
  if (!el) return;
  if (avatar) {
    el.innerHTML = `<img src="${esc(avatar)}" alt="">`;
  } else {
    el.textContent = (name || 'R').trim().slice(0, 1).toUpperCase() || 'R';
  }
}

function pickAvatar(input) {
  const file = input.files[0];
  if (!file) return;
  input.value = '';
  if (file.size > 300000) {
    toast('头像图片不能超过 300KB');
    return;
  }
  const reader = new FileReader();
  reader.onload = () => {
    currentProfile.avatar = String(reader.result || '');
    renderProfile();
  };
  reader.readAsDataURL(file);
}

function clearAvatar() {
  currentProfile.avatar = '';
  renderProfile();
}

async function saveProfile() {
  const body = {
    display_name: document.getElementById('profile-name-input').value.trim(),
    avatar: currentProfile.avatar || '',
    self_description: document.getElementById('profile-desc-input').value.trim(),
  };
  try {
    const r = await fetch('/api/profile', {
      method:'PUT',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(body),
    });
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`保存失败：${e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    currentProfile = {...currentProfile, ...(d.profile || {})};
    renderProfile();
    toast('设置已保存');
  } catch(err) {
    toast(`保存出错：${err.message}`);
  }
}

async function loadLlmConfig() {
  try {
    const r = await fetch('/api/llm-config');
    const d = await r.json();
    llmConfig = d.config || {};
    llmOptions = d.options || llmOptions;
    renderLlmConfig();
  } catch(e) {
    console.warn('loadLlmConfig failed', e);
  }
}

function renderLlmConfig() {
  const grid = document.getElementById('llm-config-grid');
  if (!grid) return;
  const providers = llmOptions.providers || [];
  const agents = llmOptions.agents || Object.keys(llmConfig);
  const rows = agents.map(name => {
    const item = llmConfig[name] || {};
    const env = (llmOptions.env_vars || {})[name] || {};
    const provider = item.provider || providers[0] || 'ollama';
    const model = item.model || (llmOptions.defaults || {})[provider] || '';
    return `
      <div class="agent-name">${esc(AGENT_LABELS[name] || name)}</div>
      <select class="form-select" id="llm-provider-${esc(name)}" onchange="fillDefaultModel('${js(name)}')">
        ${providers.map(p => `<option value="${esc(p)}"${p === provider ? ' selected' : ''}>${esc(p)}</option>`).join('')}
      </select>
      <input class="form-input" id="llm-model-${esc(name)}" value="${esc(model)}" placeholder="model name">
      <div class="env-hint">${esc(env.provider || '')}<br>${esc(env.model || '')}</div>
      <div>
        <button class="sm-btn" id="llm-test-btn-${esc(name)}" onclick="testLlmConfig('${js(name)}')">娴嬭瘯</button>
        <div class="test-result" id="llm-test-${esc(name)}"></div>
      </div>`;
  }).join('');
  grid.innerHTML = `
    <div class="llm-grid-head">Agent</div>
    <div class="llm-grid-head">Provider</div>
    <div class="llm-grid-head">Model</div>
    <div class="llm-grid-head">.env 閰嶇疆椤?/div>
    <div class="llm-grid-head">娴嬭瘯</div>
    ${rows}`;
}

function fillDefaultModel(agentName) {
  const provider = document.getElementById(`llm-provider-${agentName}`)?.value;
  const modelInput = document.getElementById(`llm-model-${agentName}`);
  if (provider && modelInput && !modelInput.value.trim()) {
    modelInput.value = (llmOptions.defaults || {})[provider] || '';
  }
}

async function saveLlmConfig() {
  const agents = llmOptions.agents || Object.keys(llmConfig);
  const config = {};
  agents.forEach(name => {
    config[name] = {
      provider: document.getElementById(`llm-provider-${name}`)?.value || 'ollama',
      model: document.getElementById(`llm-model-${name}`)?.value.trim() || '',
    };
  });
  try {
    const r = await fetch('/api/llm-config', {
      method:'PUT',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({config}),
    });
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`淇濆瓨澶辫触锛?{e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    llmConfig = d.config || config;
    renderLlmConfig();
    toast('LLM 閰嶇疆宸蹭繚瀛樺苟鐢熸晥');
  } catch(err) {
    toast(`淇濆瓨鍑洪敊锛?{err.message}`);
  }
}

async function testLlmConfig(agentName) {
  const provider = document.getElementById(`llm-provider-${agentName}`)?.value || '';
  const model = document.getElementById(`llm-model-${agentName}`)?.value.trim() || '';
  const out = document.getElementById(`llm-test-${agentName}`);
  const btn = document.getElementById(`llm-test-btn-${agentName}`);
  if (!provider || !model) {
    if (out) { out.className = 'test-result err'; out.textContent = '璇峰厛濉啓 provider 鍜?model'; }
    return;
  }
  if (out) { out.className = 'test-result'; out.textContent = '娴嬭瘯涓?..'; }
  if (btn) btn.disabled = true;
  try {
    const r = await fetch('/api/llm-config/test', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({agent_name: agentName, provider, model}),
    });
    const d = await r.json();
    if (d.success) {
      if (out) {
        out.className = 'test-result ok';
        out.textContent = `鎴愬姛 ${d.latency_ms}ms 路 ${d.model}`;
      }
    } else {
      if (out) {
        out.className = 'test-result err';
        out.textContent = d.error || '娴嬭瘯澶辫触';
      }
    }
  } catch(err) {
    if (out) {
      out.className = 'test-result err';
      out.textContent = err.message;
    }
  } finally {
    if (btn) btn.disabled = false;
  }
}

async function loadNotes() {
  const q = document.getElementById('note-search')?.value || '';
  try {
    const r = await fetch(`/api/notes?q=${encodeURIComponent(q)}`);
    const d = await r.json();
    notes = d.notes || [];
    renderNotesList();
    if (selectedNoteId && !notes.some(n => n.id === selectedNoteId)) selectedNoteId = '';
  } catch(e) {
    document.getElementById('notes-list').innerHTML = '<div class="paper-empty">鍔犺浇绗旇澶辫触</div>';
  }
}

// 鈹€鈹€ Notes redesign helpers 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
const _TC_DARK = [
  {bg:'rgba(124,58,237,.3)',color:'#c4b5fd'},{bg:'rgba(16,185,129,.2)',color:'#6ee7b7'},
  {bg:'rgba(245,158,11,.2)',color:'#fcd34d'},{bg:'rgba(239,68,68,.2)',color:'#fca5a5'},
  {bg:'rgba(59,130,246,.2)',color:'#93c5fd'},{bg:'rgba(236,72,153,.2)',color:'#f9a8d4'},
];
const _TC_LIGHT = [
  {bg:'#ede9fe',color:'#6d28d9'},{bg:'#d1fae5',color:'#065f46'},
  {bg:'#fef3c7',color:'#92400e'},{bg:'#fee2e2',color:'#991b1b'},
  {bg:'#dbeafe',color:'#1e40af'},{bg:'#fce7f3',color:'#9d174d'},
];
function _tcd(tag){const i=tag.split('').reduce((a,c)=>a+c.charCodeAt(0),0)%_TC_DARK.length;return _TC_DARK[i];}
function _tcl(tag){const i=tag.split('').reduce((a,c)=>a+c.charCodeAt(0),0)%_TC_LIGHT.length;return _TC_LIGHT[i];}

function renderNotesList() {
  const list = document.getElementById('notes-list');
  const pinnedEl = document.getElementById('nv-pinned-list');
  const pinnedLbl = document.getElementById('nv-pinned-label');
  const footer = document.getElementById('nv-total-footer');
  if (!list) return;

  const q = (document.getElementById('note-search')?.value || '').toLowerCase();
  const filtered = q ? notes.filter(n =>
    (n.title||'').toLowerCase().includes(q) ||
    (n.content_markdown||'').toLowerCase().includes(q) ||
    (n.tags||[]).some(t=>t.toLowerCase().includes(q))
  ) : notes;

  const pinned = filtered.filter(n=>n.metadata?.pinned);
  const recent = filtered.filter(n=>!n.metadata?.pinned);

  if (pinnedLbl) pinnedLbl.style.display = pinned.length ? '' : 'none';
  if (pinnedEl) {
    pinnedEl.innerHTML = pinned.map(n => {
      const preview = (n.content_markdown||'').replace(/^#+\s+/gm,'').replace(/\*\*/g,'').slice(0,80);
      const tagHtml = (n.tags||[]).slice(0,3).map(t=>{const c=_tcl(t);return `<span class="ntag-l" style="background:${c.bg};color:${c.color}">${esc(t)}</span>`;}).join('');
      return `<div class="nv-note-card${n.id===selectedNoteId?' active':''}" onclick="selectNote('${js(n.id)}')">
        <div class="nv-note-card-title">${esc(n.title||'无标题')}</div>
        ${tagHtml?`<div class="nv-note-card-tags">${tagHtml}</div>`:''}
        ${preview?`<div class="nv-note-card-preview">${esc(preview)}</div>`:''}
        <div class="nv-note-card-footer">
          <span class="nv-note-card-time">${fmtTime(n.updated_at)}</span>
          <span class="nv-note-card-star" onclick="event.stopPropagation();_nvPin('${js(n.id)}')">★</span>
        </div></div>`;
    }).join('');
  }

  if (!recent.length) {
    list.innerHTML = '<div style="color:#7d70a8;padding:20px 14px;font-size:12px">暂无笔记</div>';
  } else {
    list.innerHTML = recent.map(n => {
      const tagHtml = (n.tags||[]).slice(0,3).map(t=>{const c=_tcd(t);return `<span class="ntag-d" style="background:${c.bg};color:${c.color}">${esc(t)}</span>`;}).join('');
      return `<div class="nv-note-item${n.id===selectedNoteId?' active':''}" onclick="selectNote('${js(n.id)}')">
        <div class="nv-note-item-title">${esc(n.title||'无标题')}</div>
        <div class="nv-note-item-row"><div class="nv-note-item-tags">${tagHtml}</div>
          <span class="nv-note-item-date">${fmtTime(n.updated_at)}</span></div></div>`;
    }).join('');
  }
  if (footer) footer.innerHTML = `<span>鏌ョ湅鍏ㄩ儴绗旇 (${filtered.length})</span><span>鈫?/span>`;
}

function _nvRefreshProps() {
  const note = notes.find(n=>n.id===selectedNoteId);
  const content = document.getElementById('note-content-input')?.value || '';
  const chars = content.length;
  const words = content.trim() ? content.trim().split(/[\s\u4e00-\u9fff]+/).filter(Boolean).length : 0;
  _q('#nv-p-created').textContent = note ? fmtTime(note.created_at) : '-';
  _q('#nv-p-updated').textContent = note ? fmtTime(note.updated_at) : '-';
  _q('#nv-p-words').textContent = `${words} 词`;
  _q('#nv-p-chars').textContent = `${chars} 字符`;
  _q('#nv-p-embed').textContent = note?.embedding_status || '-';
  _q('#nv-wc').textContent = `${chars} 字符`;
  const tags = (document.getElementById('note-tags-input')?.value||'').split(',').map(t=>t.trim()).filter(Boolean);
  const ptagEl = document.getElementById('nv-p-tags');
  if (ptagEl) ptagEl.innerHTML = tags.map(t=>{const c=_tcd(t);return `<span class="ntag-d" style="background:${c.bg};color:${c.color}">${esc(t)}</span>`;}).join('');
}
function _q(sel){return document.querySelector(sel)||{textContent:''};}

function _nvRenderTagPills() {
  const tags = (document.getElementById('note-tags-input')?.value||'').split(',').map(t=>t.trim()).filter(Boolean);
  const el = document.getElementById('nv-tag-pills');
  if (!el) return;
  el.innerHTML = tags.map((t,i)=>{const c=_tcl(t);return `<span class="ntag-editor" style="background:${c.bg};color:${c.color}">${esc(t)}<span class="ntag-x" onclick="_nvRmTag(${i})">×</span></span>`;}).join('');
}
function _nvRmTag(idx) {
  const inp = document.getElementById('note-tags-input');
  if (!inp) return;
  const tags = inp.value.split(',').map(t=>t.trim()).filter(Boolean);
  tags.splice(idx,1);
  inp.value = tags.join(', ');
  _nvRenderTagPills(); _nvRefreshProps();
}
function _nvTagKey(e) {
  if (e.key==='Enter'||e.key===',') {
    e.preventDefault();
    const v = e.target.value.trim().replace(/,$/,'');
    if (!v) return;
    const inp = document.getElementById('note-tags-input');
    const tags = inp.value.split(',').map(t=>t.trim()).filter(Boolean);
    if (!tags.includes(v)) tags.push(v);
    inp.value = tags.join(', ');
    e.target.value = '';
    _nvRenderTagPills(); _nvRefreshProps(); _nvChange();
  }
}

let _notePreviewMode = false, _nvAutoTimer = null;

function _nvChange() {
  updateSaveBtnText(); _nvRefreshProps();
  clearTimeout(_nvAutoTimer);
  _nvAutoTimer = setTimeout(async ()=>{
    if (selectedNoteId && !editingNewNote) await _nvAutoSave();
  }, 2000);
}

async function _nvAutoSave() {
  if (!selectedNoteId || editingNewNote) return;
  const title = document.getElementById('note-title-input').value.trim()||'新笔记';
  const content_markdown = document.getElementById('note-content-input').value;
  const tags = document.getElementById('note-tags-input').value.split(',').map(s=>s.trim()).filter(Boolean);
  const note_status = document.getElementById('nv-status-sel')?.value||'active';
  const note = notes.find(n=>n.id===selectedNoteId);
  const r = await fetch(`/api/notes/${encodeURIComponent(selectedNoteId)}`,{
    method:'PUT',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({title,content_markdown,tags,source_type:'manual',metadata:{...(note?.metadata||{}),note_status}})
  });
  if (r.ok) {
    const badge = document.getElementById('nv-autosave-badge');
    if (badge){badge.classList.add('show');setTimeout(()=>badge.classList.remove('show'),2500);}
    await loadNotes();
  }
}

function toggleNotePreview() {
  _notePreviewMode = !_notePreviewMode;
  const ta = document.getElementById('note-content-input');
  const pv = document.getElementById('note-preview');
  const btn = document.getElementById('preview-toggle-btn');
  if (!_notePreviewMode) {
    ta.style.display = ''; pv.style.display = 'none'; btn.textContent = '预览'; return;
  }
  pv.innerHTML = _mdToHtml(ta.value);
  ta.style.display = 'none'; pv.style.display = 'block'; btn.textContent = '编辑';
}

function updateSaveBtnText() {
  const btn = document.getElementById('save-note-btn');
  if (!btn) return;
  btn.textContent = (editingNewNote||!selectedNoteId) ? '保存新笔记' : '更新笔记';
}

function _exitPreviewMode() {
  if (_notePreviewMode) {
    _notePreviewMode = false;
    document.getElementById('note-content-input').style.display = '';
    document.getElementById('note-preview').style.display = 'none';
    const btn = document.getElementById('preview-toggle-btn');
    if (btn) btn.textContent = '预览';
  }
}

function selectNote(noteId) {
  selectedNoteId = noteId; editingNewNote = false;
  _exitPreviewMode();
  const note = notes.find(n=>n.id===noteId);
  if (!note) return;
  document.getElementById('note-title-input').value = note.title||'';
  document.getElementById('note-tags-input').value = (note.tags||[]).join(', ');
  document.getElementById('note-content-input').value = note.content_markdown||'';
  document.getElementById('note-status').textContent = `${note.embedding_status} · ${fmtTime(note.updated_at)}`;
  const pinBtn = document.getElementById('nv-pin-btn');
  if (pinBtn) {pinBtn.textContent = note.metadata?.pinned?'★':'☆'; pinBtn.classList.toggle('pinned',!!note.metadata?.pinned); pinBtn.style.color = note.metadata?.pinned ? '#f59e0b' : '';}
  const sel = document.getElementById('nv-status-sel');
  if (sel) sel.value = note.metadata?.note_status||'active';
  updateSaveBtnText(); renderNotesList(); _nvRenderTagPills(); _nvRefreshProps();
}

function newNoteDraft() {
  selectedNoteId = ''; editingNewNote = true;
  _exitPreviewMode();
  document.getElementById('note-title-input').value = '';
  document.getElementById('note-tags-input').value = '';
  document.getElementById('note-content-input').value = '';
  document.getElementById('note-status').textContent = '新笔记';
  const pinBtn = document.getElementById('nv-pin-btn');
  if (pinBtn){pinBtn.textContent='☆';pinBtn.classList.remove('pinned');pinBtn.style.color='';}
  const sel = document.getElementById('nv-status-sel');
  if (sel) sel.value = 'active';
  updateSaveBtnText(); renderNotesList(); _nvRenderTagPills(); _nvRefreshProps();
}

async function saveSelectedNote() {
  const title = document.getElementById('note-title-input').value.trim()||'新笔记';
  const content_markdown = document.getElementById('note-content-input').value;
  const tags = document.getElementById('note-tags-input').value.split(',').map(s=>s.trim()).filter(Boolean);
  const note_status = document.getElementById('nv-status-sel')?.value||'active';
  const note = selectedNoteId ? notes.find(n=>n.id===selectedNoteId) : null;
  const body = {title,content_markdown,tags,source_type:'manual',metadata:{...(note?.metadata||{}),note_status}};
  const shouldCreate = editingNewNote||!selectedNoteId;
  const url = shouldCreate ? '/api/notes' : `/api/notes/${encodeURIComponent(selectedNoteId)}`;
  const r = await fetch(url,{method:shouldCreate?'POST':'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  if (!r.ok){toast('保存笔记失败');return;}
  const d = await r.json();
  toast('笔记已保存');
  await loadNotes();
  selectedNoteId = d.note.id; editingNewNote = false;
  updateSaveBtnText(); selectNote(selectedNoteId);
}

async function deleteSelectedNote() {
  if (!selectedNoteId) return;
  const note = notes.find(n=>n.id===selectedNoteId);
  if (!confirm(`删除笔记《${note?.title||selectedNoteId}》？`)) return;
  const r = await fetch(`/api/notes/${encodeURIComponent(selectedNoteId)}`,{method:'DELETE'});
  if (!r.ok){toast('删除失败');return;}
  selectedNoteId = ''; newNoteDraft(); await loadNotes();
}

async function embedSelectedNote() {
  if (!selectedNoteId){toast('请先选择或保存笔记');return;}
  const r = await fetch(`/api/notes/${encodeURIComponent(selectedNoteId)}/embed`,{method:'POST'});
  if (!r.ok){toast('向量化失败');return;}
  const d = await r.json();
  toast(`已写入 ${d.chunks_indexed||0} 个片段`);
  await loadNotes(); selectNote(selectedNoteId);
}

function exportSelectedNotePdf() {
  if (!selectedNoteId || editingNewNote) {
    toast('请先保存笔记，再导出 PDF');
    return;
  }
  window.location.href = `/api/notes/${encodeURIComponent(selectedNoteId)}/export.pdf`;
}

function _nvToggleProps() {
  const panel = document.getElementById('nv-props-panel');
  const btn = document.getElementById('nv-props-toggle');
  if (!panel) return;
  panel.classList.toggle('hidden');
  if (btn) btn.classList.toggle('active', !panel.classList.contains('hidden'));
}

async function toggleNotePin() {
  if (!selectedNoteId) return;
  await _nvPin(selectedNoteId);
}
async function _nvPin(noteId) {
  const note = notes.find(n=>n.id===noteId);
  if (!note) return;
  const pinned = !(note.metadata?.pinned);
  await fetch(`/api/notes/${encodeURIComponent(noteId)}`,{
    method:'PUT',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({title:note.title,content_markdown:note.content_markdown,
      tags:note.tags,source_type:note.source_type,metadata:{...(note.metadata||{}),pinned}})
  });
  await loadNotes();
  if (noteId===selectedNoteId) selectNote(selectedNoteId);
}

function _nvTab(tab) {
  document.getElementById('nv-tab-props').classList.toggle('active',tab==='props');
  document.getElementById('nv-tab-outline').classList.toggle('active',tab==='outline');
  document.getElementById('nv-panel-props').style.display = tab==='props'?'':'none';
  document.getElementById('nv-panel-outline').style.display = tab==='outline'?'':'none';
  if (tab==='outline') _nvOutline();
}
function _nvOutline() {
  const content = document.getElementById('note-content-input')?.value||'';
  const el = document.getElementById('nv-outline');
  if (!el) return;
  const headings = [...content.matchAll(/^(#{1,3})\s+(.+)/gm)].map(m=>({l:m[1].length,t:m[2]}));
  el.innerHTML = headings.length
    ? headings.map(h=>`<div class="nv-outline-item nv-outline-h${h.l}" onclick="_nvScrollTo(${JSON.stringify(h.t)})">${esc(h.t)}</div>`).join('')
    : '<div style="color:#7d70a8;font-size:12px;padding:4px">鏆傛棤鏍囬</div>';
}
function _nvScrollTo(text) {
  // Focus textarea and find the heading
  const ta = document.getElementById('note-content-input');
  if (!ta) return;
  const idx = ta.value.indexOf(text);
  if (idx>=0){ta.focus();ta.setSelectionRange(idx,idx+text.length);}
}

function _nvAI(action) {
  const title = document.getElementById('note-title-input')?.value||'这篇笔记';
  const msgs = {
    summarize:`请帮我总结笔记《${title}》的核心内容`,
    explain_formula:`请解释笔记《${title}》中的数学公式`,
    expand:`请帮我扩展笔记《${title}》的相关内容和背景知识`,
    mindmap:`请为笔记《${title}》生成一个思维导图（用 Markdown 列表格式）`
  };
  const chatNavEl = document.querySelector('.nav-item[onclick*="showChatView"]');
  if (chatNavEl) showChatView(chatNavEl);
  setTimeout(()=>sendText(msgs[action]||`帮我分析笔记《${title}》`),150);
}
function _nvAIAsk() {
  const inp = document.getElementById('nv-ai-q');
  if (!inp?.value.trim()) return;
  const msg = inp.value.trim(); inp.value = '';
  const chatNavEl = document.querySelector('.nav-item[onclick*="showChatView"]');
  if (chatNavEl) showChatView(chatNavEl);
  setTimeout(()=>sendText(msg),150);
}

// Toolbar formatting helpers
function _nfmt(before, after) {
  const ta = document.getElementById('note-content-input');
  if (!ta) return;
  const s=ta.selectionStart, e=ta.selectionEnd, sel=ta.value.slice(s,e)||'文本';
  ta.value = ta.value.slice(0,s)+before+sel+after+ta.value.slice(e);
  ta.setSelectionRange(s+before.length, s+before.length+sel.length);
  ta.focus(); _nvChange();
}
function _nfmtLine(prefix) {
  const ta = document.getElementById('note-content-input');
  if (!ta) return;
  const s=ta.selectionStart;
  const ls = ta.value.lastIndexOf('\n',s-1)+1;
  const has = ta.value.slice(ls).startsWith(prefix);
  if (has){ta.value=ta.value.slice(0,ls)+ta.value.slice(ls+prefix.length);ta.setSelectionRange(s-prefix.length,s-prefix.length);}
  else{ta.value=ta.value.slice(0,ls)+prefix+ta.value.slice(ls);ta.setSelectionRange(s+prefix.length,s+prefix.length);}
  ta.focus(); _nvChange();
}
function _nfmtBlock(before, after) {
  const ta = document.getElementById('note-content-input');
  if (!ta) return;
  const s=ta.selectionStart, e=ta.selectionEnd, sel=ta.value.slice(s,e);
  ta.value = ta.value.slice(0,s)+before+sel+after+ta.value.slice(e);
  ta.setSelectionRange(s+before.length, s+before.length+sel.length);
  ta.focus(); _nvChange();
}

function updateLibrary(_ignored) {
  // Kept for API compatibility 鈥?library state is now fully managed by loadLibraries()
  loadLibraries();
}

async function figPickPaper(input) {
  const file = input.files?.[0];
  if (!file || !currentSid) return;
  currentFigurePaperId = '';
  currentFigureDownloadUrl = '';
  document.getElementById('fig-paper-name').textContent = `${file.name} · 上传中...`;
  const form = new FormData();
  form.append('file', file);
  try {
    const r = await fetch(`/api/figure/upload?session_id=${encodeURIComponent(currentSid)}`, {method:'POST', body:form});
    if (!r.ok) throw new Error((await r.json().catch(() => ({}))).detail || r.statusText);
    const d = await r.json();
    currentFigurePaperId = d.paper_id || '';
    document.getElementById('fig-paper-name').textContent =
      `${d.filename || file.name} · ${d.char_count || 0} chars · ${(d.sections || []).slice(0, 4).join(' / ')}`;
    toast('论文已解析，可以生成 prompt');
  } catch(e) {
    document.getElementById('fig-paper-name').textContent = `${file.name} · 解析失败`;
    toast(`论文解析失败：${e.message || e}`);
  }
}

async function figGeneratePrompt() {
  const type = document.getElementById('fig-type')?.value || 'method';
  const style = document.getElementById('fig-style')?.value || 'paper';
  const brief = document.getElementById('fig-brief')?.value.trim() || '';
  const promptBox = document.getElementById('fig-prompt');
  promptBox.value = 'Generating prompt...';
  try {
    const r = await fetch('/api/figure/prompt', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        paper_id: currentFigurePaperId,
        brief,
        hidden_brief_prompt: FIGURE_BRIEF_HIDDEN_PROMPT,
        figure_type:type,
        style
      })
    });
    if (!r.ok) throw new Error((await r.json().catch(() => ({}))).detail || r.statusText);
    const d = await r.json();
    promptBox.value = d.prompt || '';
  } catch(e) {
    promptBox.value = brief || '';
    toast(`生成 prompt 失败：${e.message || e}`);
  }
}

function figAppendPrompt() {
  const extra = prompt('追加 prompt 要求');
  if (!extra) return;
  const el = document.getElementById('fig-prompt');
  el.value = `${el.value.trim()}\n${extra}`.trim();
}

function figClearPrompt() {
  document.getElementById('fig-prompt').value = '';
}

async function figGenerateImage() {
  const promptText = document.getElementById('fig-prompt')?.value.trim();
  if (!promptText) {
    toast('请先填写或生成 prompt');
    return;
  }
  const ratio = document.getElementById('fig-ratio')?.value || '4:3';
  const negative = document.getElementById('fig-negative')?.value.trim() || '';
  const canvas = document.getElementById('fig-canvas');
  canvas.classList.add('is-loading');
  canvas.textContent = 'Generating image...';
  currentFigureDownloadUrl = '';
  currentFigureImageUrl = '';
  try {
    const r = await fetch('/api/figure/generate', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({prompt: promptText, negative, ratio})
    });
    if (!r.ok) throw new Error((await r.json().catch(() => ({}))).detail || r.statusText);
    const d = await r.json();
    currentFigureDownloadUrl = d.download_url || '';
    currentFigureImageUrl = d.image_url || currentFigureDownloadUrl;
    if (d.image_url) {
      canvas.classList.remove('is-loading');
      canvas.innerHTML = '';
      const img = document.createElement('img');
      img.src = d.image_url;
      img.alt = 'Generated figure';
      canvas.appendChild(img);
      figAddHistory({
        prompt: promptText,
        negative,
        ratio,
        image_url: d.image_url,
        download_url: d.download_url || d.image_url,
        model: d.model || '',
        media_type: d.media_type || 'image/png'
      });
    } else {
      canvas.classList.remove('is-loading');
      canvas.innerHTML = '<div>图像模型没有返回图片。</div>';
    }
  } catch(e) {
    canvas.classList.remove('is-loading');
    canvas.innerHTML = `<div>生成失败：${esc(e.message || e)}</div>`;
  }
}

function figSaveMock(showToast=true) {
  const promptText = document.getElementById('fig-prompt')?.value.trim();
  if (currentFigureDownloadUrl) {
    const a = document.createElement('a');
    a.href = currentFigureDownloadUrl;
    a.download = currentFigureDownloadUrl.split('/').pop() || 'figure.png';
    document.body.appendChild(a);
    a.click();
    a.remove();
    if (showToast) toast('图片已开始下载');
    return;
  }
  if (!promptText || !showToast) return;
  toast('请先生成图片，再下载。');
}

function figLoadHistory() {
  try {
    const raw = localStorage.getItem(FIGURE_HISTORY_KEY);
    const items = raw ? JSON.parse(raw) : [];
    return Array.isArray(items) ? items : [];
  } catch(e) {
    console.warn('figure history load failed', e);
    return [];
  }
}

function figSaveHistory(items) {
  localStorage.setItem(FIGURE_HISTORY_KEY, JSON.stringify(items.slice(0, 60)));
}

function figAddHistory(entry) {
  const items = figLoadHistory();
  const item = {
    id: `fig_${Date.now()}_${Math.random().toString(16).slice(2)}`,
    created_at: new Date().toISOString(),
    ...entry
  };
  figSaveHistory([item, ...items]);
  figRenderHistory();
}

function figRenderHistory() {
  const box = document.getElementById('fig-history');
  if (!box) return;
  const items = figLoadHistory();
  box.innerHTML = '';
  if (!items.length) {
    const empty = mk('div', 'fig-thumb');
    empty.innerHTML = '<div class="fig-thumb-body">No generated figures yet.</div>';
    box.appendChild(empty);
    return;
  }
  items.forEach(item => box.appendChild(figHistoryNode(item)));
}

function figHistoryNode(item) {
  const card = mk('div', 'fig-thumb');
  const imgBox = mk('div', 'fig-thumb-img');
  if (item.image_url) {
    const img = document.createElement('img');
    img.src = item.image_url;
    img.alt = 'Generated figure history item';
    imgBox.appendChild(img);
  } else {
    imgBox.textContent = 'No image';
  }
  const body = mk('div', 'fig-thumb-body');
  const prompt = mk('div', 'fig-thumb-prompt');
  prompt.textContent = item.prompt || 'Untitled figure';
  const meta = mk('div', 'fig-thumb-meta');
  meta.textContent = `${figFormatTime(item.created_at)} · ${item.ratio || '4:3'}`;
  const actions = mk('div', 'fig-thumb-actions');
  const loadBtn = mk('button', 'sm-btn');
  loadBtn.textContent = '载入';
  loadBtn.onclick = () => figRestoreHistory(item.id);
  const dlBtn = mk('button', 'sm-btn');
  dlBtn.textContent = '下载';
  dlBtn.onclick = () => figDownloadHistory(item.id);
  const delBtn = mk('button', 'sm-btn');
  delBtn.textContent = '删除';
  delBtn.onclick = () => figDeleteHistory(item.id);
  actions.append(loadBtn, dlBtn, delBtn);
  body.append(prompt, meta, actions);
  card.append(imgBox, body);
  return card;
}

function figRestoreHistory(id) {
  const item = figLoadHistory().find(x => x.id === id);
  if (!item) return;
  document.getElementById('fig-prompt').value = item.prompt || '';
  document.getElementById('fig-negative').value = item.negative || '';
  document.getElementById('fig-ratio').value = item.ratio || '4:3';
  currentFigureDownloadUrl = item.download_url || item.image_url || '';
  currentFigureImageUrl = item.image_url || currentFigureDownloadUrl;
  const canvas = document.getElementById('fig-canvas');
  if (currentFigureImageUrl) {
    canvas.classList.remove('is-loading');
    canvas.innerHTML = '';
    const img = document.createElement('img');
    img.src = currentFigureImageUrl;
    img.alt = 'Generated figure';
    canvas.appendChild(img);
  }
}

function figDownloadHistory(id) {
  const item = figLoadHistory().find(x => x.id === id);
  const url = item?.download_url || item?.image_url;
  if (!url) return;
  const a = document.createElement('a');
  a.href = url;
  a.download = url.split('/').pop() || 'figure.png';
  document.body.appendChild(a);
  a.click();
  a.remove();
}

function figDeleteHistory(id) {
  figSaveHistory(figLoadHistory().filter(x => x.id !== id));
  figRenderHistory();
}

function figFormatTime(value) {
  if (!value) return '';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleString([], {month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit'});
}

function clearPanels() {
  updateFound([]); updateDownloaded([]); updateLibrary([]);
}

function updateCompression(state) {
  compressionState = state;
  const bar = document.getElementById('compress-bar');
  const txt = document.getElementById('compress-text');
  if (!bar || !txt || !state || !state.near_limit) {
    if (bar) bar.classList.remove('on');
    return;
  }
  const left = Math.max((state.max_recent || 100) - (state.recent_count || 0), 0);
  txt.textContent = `当前对话已保留 ${state.recent_count}/${state.max_recent} 条原始消息，剩余 ${left} 条后将自动压缩。`;
  bar.classList.add('on');
}

async function compressCurrentSession() {
  if (!currentSid) return;
  const bar = document.getElementById('compress-bar');
  try {
    const r = await fetch(`/api/sessions/${encodeURIComponent(currentSid)}/compress`, {method:'POST'});
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`压缩失败：${e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    updateCompression(d.compression || null);
    if (bar) bar.classList.remove('on');
    toast('对话已压缩');
  } catch(err) {
    toast(`压缩出错：${err.message}`);
  }
}

// 鈹€鈹€ UI helpers 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
function setDot(cls) { document.getElementById('ws-dot').className = cls; }
function setSend(on)  { document.getElementById('send-btn').disabled = !on; }
function setGenerating(on) {
  generating = on;
  setSend(!on);
  document.getElementById('stop-btn').classList.toggle('on', on);
}
function navClick(el) {
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  el.classList.add('active');
  if (el?.id) localStorage.setItem(ACTIVE_VIEW_KEY, el.id);
}
function restoreActiveView() {
  const id = localStorage.getItem(ACTIVE_VIEW_KEY) || 'nav-chat';
  const el = document.getElementById(id) || document.getElementById('nav-chat');
  if (!el) return;
  if (id === 'nav-library') return showLibraryManager(el);
  if (id === 'nav-notes') return showNotesView(el);
  if (id === 'nav-figure') return showFigureView(el);
  if (id === 'nav-writing') return showWritingView(el);
  if (id === 'nav-settings') return showSettingsView(el);
  showChatView(el);
}
function hideMainViews() {
  document.getElementById('welcome').classList.add('gone');
  document.getElementById('chat-view').classList.remove('on');
  document.getElementById('library-view').classList.remove('on');
  document.getElementById('figure-view').classList.remove('on');
  document.getElementById('writing-view')?.classList.remove('on');
  document.getElementById('settings-view').classList.remove('on');
  document.getElementById('notes-view').classList.remove('on');
}
function showChatView(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('input-wrap').style.display = '';
  if (chatStarted) {
    document.getElementById('chat-view').classList.add('on');
  } else {
    document.getElementById('welcome').classList.remove('gone');
  }
}
function showLibraryManager(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('library-view').classList.add('on');
  document.getElementById('input-wrap').style.display = 'none';
  loadLibraries();
}
function showFigureView(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('figure-view').classList.add('on');
  document.getElementById('input-wrap').style.display = 'none';
}
function showWritingView(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('writing-view').classList.add('on');
  document.getElementById('input-wrap').style.display = 'none';
}
function showSettingsView(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('settings-view').classList.add('on');
  document.getElementById('input-wrap').style.display = 'none';
  renderProfile();
  renderLlmConfig();
}
function showNotesView(el) {
  navClick(el);
  hideMainViews();
  document.getElementById('notes-view').classList.add('on');
  document.getElementById('input-wrap').style.display = 'none';
  loadNotes();
}
function updateUsage() {
  document.getElementById('usage-txt').textContent = `${turnCount} 次`;
  document.getElementById('usage-fill').style.width = Math.min(turnCount*3,100)+'%';
}
function autoResize(ta) {
  ta.style.height = 'auto';
  ta.style.height = Math.min(ta.scrollHeight,120)+'px';
}
function mk(tag, cls='') {
  const e = document.createElement(tag);
  if (cls) e.className = cls;
  return e;
}
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function js(s) {
  return esc(String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,' '));
}
function fmtTime(s) {
  if (!s) return '未知';
  const d = new Date(s);
  if (Number.isNaN(d.getTime())) return s;
  const pad = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
}
function toast(msg) {
  const t = document.createElement('div');
  t.className = 'toast'; t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2200);
}

let woodfishAudioCtx = null;
function playWoodfishSound() {
  const AudioCtx = window.AudioContext || window.webkitAudioContext;
  if (!AudioCtx) return;
  woodfishAudioCtx = woodfishAudioCtx || new AudioCtx();
  const ctx = woodfishAudioCtx;
  if (ctx.state === 'suspended') ctx.resume();
  const now = ctx.currentTime;

  const makeTap = (offset, level) => {
    const t = now + offset;
    const length = Math.floor(ctx.sampleRate * .055);
    const buffer = ctx.createBuffer(1, length, ctx.sampleRate);
    const data = buffer.getChannelData(0);
    for (let i = 0; i < length; i++) {
      const decay = Math.pow(1 - i / length, 3.2);
      data[i] = (Math.random() * 2 - 1) * decay;
    }

    const noise = ctx.createBufferSource();
    const band = ctx.createBiquadFilter();
    const clickGain = ctx.createGain();
    noise.buffer = buffer;
    band.type = 'bandpass';
    band.frequency.setValueAtTime(920, t);
    band.Q.setValueAtTime(5.8, t);
    clickGain.gain.setValueAtTime(.0001, t);
    clickGain.gain.exponentialRampToValueAtTime(level, t + .004);
    clickGain.gain.exponentialRampToValueAtTime(.0001, t + .052);
    noise.connect(band).connect(clickGain).connect(ctx.destination);
    noise.start(t);
    noise.stop(t + .06);

    const body = ctx.createOscillator();
    const bodyGain = ctx.createGain();
    const lowpass = ctx.createBiquadFilter();
    body.type = 'square';
    body.frequency.setValueAtTime(185, t);
    body.frequency.exponentialRampToValueAtTime(92, t + .045);
    lowpass.type = 'lowpass';
    lowpass.frequency.setValueAtTime(430, t);
    bodyGain.gain.setValueAtTime(.0001, t);
    bodyGain.gain.exponentialRampToValueAtTime(level * .42, t + .005);
    bodyGain.gain.exponentialRampToValueAtTime(.0001, t + .075);
    body.connect(lowpass).connect(bodyGain).connect(ctx.destination);
    body.start(t);
    body.stop(t + .08);
  };

  makeTap(0, .34);
  makeTap(.075, .22);
}

function knockWoodfish() {
  const el = document.getElementById('woodfish-widget');
  if (!el) return;
  el.classList.remove('knock');
  void el.offsetWidth;
  el.classList.add('knock');
  showWoodfishMerit(el);
  playWoodfishSound();
}

function showWoodfishMerit(el) {
  const merit = document.createElement('span');
  merit.className = 'woodfish-merit';
  merit.textContent = '鍔熷痉 +1';
  merit.style.marginLeft = `${Math.random() * 22 - 11}px`;
  el.appendChild(merit);
  setTimeout(() => merit.remove(), 900);
}

function clampWoodfishPosition(el) {
  const pad = 8;
  const rect = el.getBoundingClientRect();
  const maxLeft = Math.max(pad, window.innerWidth - rect.width - pad);
  const maxTop = Math.max(pad, window.innerHeight - rect.height - pad);
  const left = Math.min(Math.max(rect.left, pad), maxLeft);
  const top = Math.min(Math.max(rect.top, pad), maxTop);
  el.style.left = `${left}px`;
  el.style.top = `${top}px`;
  el.style.right = 'auto';
  el.style.bottom = 'auto';
  localStorage.setItem('woodfish-position', JSON.stringify({left, top}));
}

function initWoodfish() {
  const el = document.getElementById('woodfish-widget');
  if (!el) return;
  try {
    const saved = JSON.parse(localStorage.getItem('woodfish-position') || 'null');
    if (saved && Number.isFinite(saved.left) && Number.isFinite(saved.top)) {
      el.style.left = `${saved.left}px`;
      el.style.top = `${saved.top}px`;
      el.style.right = 'auto';
      el.style.bottom = 'auto';
      requestAnimationFrame(() => clampWoodfishPosition(el));
    }
  } catch(e) {
    localStorage.removeItem('woodfish-position');
  }

  let startX = 0, startY = 0, originX = 0, originY = 0, moved = false;
  el.addEventListener('pointerdown', e => {
    if (e.pointerType === 'mouse' && e.button !== 0) return;
    const rect = el.getBoundingClientRect();
    startX = e.clientX;
    startY = e.clientY;
    originX = rect.left;
    originY = rect.top;
    moved = false;
    el.classList.add('dragging');
    el.setPointerCapture(e.pointerId);
  });
  el.addEventListener('pointermove', e => {
    if (!el.classList.contains('dragging')) return;
    const dx = e.clientX - startX;
    const dy = e.clientY - startY;
    if (Math.abs(dx) + Math.abs(dy) > 4) moved = true;
    const pad = 8;
    const maxLeft = Math.max(pad, window.innerWidth - el.offsetWidth - pad);
    const maxTop = Math.max(pad, window.innerHeight - el.offsetHeight - pad);
    el.style.left = `${Math.min(Math.max(originX + dx, pad), maxLeft)}px`;
    el.style.top = `${Math.min(Math.max(originY + dy, pad), maxTop)}px`;
    el.style.right = 'auto';
    el.style.bottom = 'auto';
  });
  el.addEventListener('pointerup', e => {
    if (!el.classList.contains('dragging')) return;
    el.classList.remove('dragging');
    try { el.releasePointerCapture(e.pointerId); } catch(_e) {}
    if (moved) {
      clampWoodfishPosition(el);
      return;
    }
    knockWoodfish();
  });
  el.addEventListener('pointercancel', () => el.classList.remove('dragging'));
  el.addEventListener('keydown', e => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    e.preventDefault();
    knockWoodfish();
  });
  window.addEventListener('resize', () => clampWoodfishPosition(el));
}

// 鈹€鈹€ File upload 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
async function uploadFile(input) {
  const file = input.files[0];
  if (!file || !currentSid) return;
  input.value = '';

  toast(`正在上传 ${file.name}...`);
  const form = new FormData();
  form.append('file', file);

  try {
    const r = await fetch(`/api/upload?session_id=${encodeURIComponent(currentSid)}`,
                          {method:'POST', body:form});
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`上传失败：${e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    updateDownloaded(d.stored_papers || []);
    if (!chatStarted) startChat();
    toast(`已上传：${file.name}`);
    addMsg('assistant', `文档 **${file.name}** 已上传，可以直接提问了。`, 'general_chat');
  } catch(err) {
    toast(`上传出错：${err.message}`);
  }
}

async function uploadImage(input) {
  const file = input.files[0];
  if (!file || !currentSid) return;
  input.value = '';

  toast(`正在上传图片 ${file.name}...`);
  const form = new FormData();
  form.append('file', file);

  try {
    const r = await fetch(`/api/image/upload?session_id=${encodeURIComponent(currentSid)}`,
                          {method:'POST', body:form});
    if (!r.ok) {
      const e = await r.json().catch(() => ({}));
      toast(`图片上传失败：${e.detail || r.statusText}`);
      return;
    }
    const d = await r.json();
    pendingImage = d;
    if (!chatStarted) startChat();
    toast(`已上传图片：${file.name}`);
    addMsg('assistant', `图片 **${file.name}** 已上传。请发送你想问的问题，我会先解析图片内容。`, 'general_chat');
  } catch(err) {
    toast(`图片上传出错：${err.message}`);
  }
}

// 鈹€鈹€ Quote 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
const q = QUOTES[new Date().getDate() % QUOTES.length];
document.getElementById('q-text').textContent = q.t;
document.getElementById('q-by').textContent   = q.by;

// 鈹€鈹€ Boot 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€
document.addEventListener('DOMContentLoaded', () => {
  const inp = document.getElementById('user-input');
  inp.addEventListener('keydown', e => { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();send();} });
  inp.addEventListener('input', () => autoResize(inp));
  document.getElementById('send-btn').addEventListener('click', send);
  connect();
  loadProfile();
  loadLlmConfig();
  initSessions().then(restoreActiveView);
  loadLibraries();
  figRenderHistory();
  initWoodfish();
});
</script>
</body>
</html>
