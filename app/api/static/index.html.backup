<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ResearchAgent</title>
<script src="https://cdn.jsdelivr.net/npm/marked@9/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"
  onload="renderMathInElement(document.body,{delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],throwOnError:false})"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --p:#6c5ce7;--p2:#5849be;--pl:#a29bfe;--ps:#f0eeff;
  --bg:#f4f5fb;--white:#fff;
  --text:#1e1f2e;--muted:#6b7280;--light:#b0b8c8;
  --border:#e8eaf0;
  --sh:0 2px 12px rgba(0,0,0,.06);
  --sh2:0 4px 24px rgba(108,92,231,.14);
  --r:12px;--r2:16px;
}
html,body{height:100%;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC',sans-serif;
  background:var(--bg);color:var(--text);font-size:14px;line-height:1.6;overflow:hidden}

/* 鈹€鈹€ Layout 鈹€鈹€ */
#app{display:flex;height:100vh}

/* 鈹€鈹€ Left nav 鈹€鈹€ */
#nav{width:220px;min-width:220px;background:var(--white);border-right:1px solid var(--border);
  display:flex;flex-direction:column;padding:18px 12px 14px;gap:2px}

.logo{display:flex;align-items:center;gap:10px;padding:2px 8px 14px}
.logo-icon{width:36px;height:36px;background:var(--p);border-radius:10px;
  display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.logo-name{font-weight:800;font-size:15px;color:var(--text)}
.logo-beta{font-size:10px;color:var(--p);background:var(--ps);padding:1px 6px;border-radius:4px;margin-left:2px}

#new-btn{display:flex;align-items:center;justify-content:space-between;
  background:var(--p);color:#fff;border:none;border-radius:var(--r);
  padding:10px 14px;font-size:13px;font-weight:600;cursor:pointer;margin-bottom:6px}
#new-btn:hover{background:var(--p2)}
.kbd{font-size:10px;opacity:.65;background:rgba(255,255,255,.2);padding:1px 5px;border-radius:4px}

.nav-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;
  font-size:13.5px;color:var(--muted);cursor:pointer;transition:all .15s;user-select:none}
.nav-item:hover{background:var(--ps);color:var(--p)}
.nav-item.active{background:var(--ps);color:var(--p);font-weight:600}
.nav-icon{width:18px;text-align:center;font-size:15px}
.nav-icon.fig-icon{height:18px;border-radius:5px;position:relative;display:inline-block;flex:0 0 18px;
  background:linear-gradient(135deg,#f5f3ff,#ede9fe);box-shadow:inset 0 0 0 1px rgba(108,92,231,.18)}
.nav-icon.fig-icon::before{content:"";position:absolute;left:3px;right:3px;bottom:3px;height:8px;
  background:linear-gradient(135deg,#7c6df0,#5f4fd8);clip-path:polygon(0 100%,34% 40%,55% 68%,77% 25%,100% 100%)}
.nav-icon.fig-icon::after{content:"";position:absolute;right:4px;top:4px;width:4px;height:4px;border-radius:50%;background:#7c6df0}

.nav-label{font-size:10.5px;color:var(--light);padding:10px 10px 4px;
  font-weight:600;letter-spacing:.5px;text-transform:uppercase}

.recent-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.recent-item{display:flex;align-items:center;gap:6px;padding:7px 10px;border-radius:8px;
  font-size:12.5px;color:var(--muted);cursor:pointer;transition:all .12s}
.recent-item:hover{background:var(--ps);color:var(--p)}
.recent-item.active{background:var(--ps);color:var(--p);font-weight:600}
.recent-title{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.recent-del{flex-shrink:0;width:16px;height:16px;border-radius:4px;border:none;
  background:transparent;font-size:11px;color:var(--light);cursor:pointer;
  display:none;align-items:center;justify-content:center;padding:0;line-height:1}
.recent-item:hover .recent-del{display:flex}
.recent-del:hover{background:#fee2e2;color:#ef4444}
.recent-empty{font-size:12px;color:var(--light);padding:4px 10px;font-style:italic}

.nav-bottom{margin-top:auto;border-top:1px solid var(--border);padding-top:10px;display:flex;flex-direction:column;gap:4px}
.usage-wrap{padding:2px 10px 6px}
.usage-row{display:flex;justify-content:space-between;font-size:11.5px;color:var(--muted);margin-bottom:5px}
.usage-track{height:4px;background:var(--ps);border-radius:2px}
.usage-fill{height:100%;background:var(--p);border-radius:2px;transition:width .3s}

.user-row{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:10px;cursor:pointer}
.user-row:hover{background:var(--bg)}
.user-av{width:30px;height:30px;border-radius:50%;
  background:linear-gradient(135deg,var(--pl),var(--p));
  display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:700}
.user-name{font-size:13px;font-weight:600;flex:1}
#ws-dot{width:7px;height:7px;border-radius:50%;background:#22c55e;flex-shrink:0}
#ws-dot.conn{background:#f59e0b;animation:pulse .8s infinite}
#ws-dot.off{background:#ef4444}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* 鈹€鈹€ Main 鈹€鈹€ */
#main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--bg)}

/* Welcome */
#welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px;position:relative;overflow:hidden;text-align:center}
#welcome.gone{display:none}
.w-glow{position:absolute;top:-60px;right:-60px;width:320px;height:320px;
  background:radial-gradient(circle,var(--pl) 0%,transparent 65%);opacity:.08;border-radius:50%}
.w-glow2{position:absolute;bottom:-80px;left:-60px;width:280px;height:280px;
  background:radial-gradient(circle,#fd79a8 0%,transparent 65%);opacity:.05;border-radius:50%}
.w-dna{position:absolute;right:80px;top:30px;font-size:100px;opacity:.05;transform:rotate(-15deg)}
.w-title{font-size:34px;font-weight:800;margin-bottom:10px;color:var(--text)}
.w-sub{font-size:14px;color:var(--muted);margin-bottom:36px;max-width:500px}
.qa-grid{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;max-width:620px}
.qa-btn{display:flex;align-items:center;gap:7px;padding:10px 18px;border-radius:20px;
  border:1.5px solid var(--border);background:var(--white);font-size:13px;color:var(--muted);
  cursor:pointer;transition:all .15s;font-family:inherit}
.qa-btn:hover{border-color:var(--p);color:var(--p);background:var(--ps);transform:translateY(-1px)}

/* Chat view */
#chat-view{flex:1;display:none;flex-direction:column;overflow:hidden}
#chat-view.on{display:flex}

/* Literature manager */
#library-view{flex:1;display:none;flex-direction:column;overflow:hidden;padding:26px 34px}
#library-view.on{display:flex}
#figure-view{flex:1;display:none;flex-direction:column;overflow:hidden;padding:24px 30px 28px;background:
  linear-gradient(180deg,#f7f8fb 0%,#eef1f6 100%)}
#figure-view.on{display:flex}
.fig-workbench{flex:1;min-height:0;display:grid;grid-template-columns:minmax(360px,410px) minmax(0,1fr);gap:18px}
.fig-pane{min-height:0;background:rgba(255,255,255,.92);border:1px solid rgba(148,163,184,.22);
  border-radius:10px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 18px 45px rgba(15,23,42,.08)}
.fig-pane-head{height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;
  border-bottom:1px solid rgba(148,163,184,.18);background:rgba(255,255,255,.84);backdrop-filter:blur(14px)}
.fig-pane-title{font-size:13px;font-weight:800;color:#111827;letter-spacing:.01em}
.fig-body{flex:1;min-height:0;overflow:auto;padding:16px}
.fig-body::-webkit-scrollbar{width:8px}.fig-body::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:999px}
.fig-upload{border:1px solid rgba(148,163,184,.28);border-radius:10px;padding:14px;background:
  linear-gradient(180deg,#fff 0%,#f8fafc 100%);display:flex;align-items:center;gap:12px;box-shadow:inset 0 1px 0 rgba(255,255,255,.9)}
.fig-upload-icon{width:42px;height:42px;border-radius:9px;background:#111827;color:#fff;display:flex;align-items:center;
  justify-content:center;font-size:19px;flex-shrink:0;box-shadow:0 10px 22px rgba(17,24,39,.18)}
.fig-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;align-items:center;margin-top:12px}
.fig-field{margin-top:14px}
.fig-label{font-size:11px;font-weight:800;color:#64748b;margin-bottom:7px;text-transform:uppercase;letter-spacing:.04em}
.fig-input,.fig-select,.fig-textarea{width:100%;border:1px solid #d9dee8;border-radius:8px;background:#fff;
  font-family:inherit;font-size:13px;color:#111827;outline:none;transition:border-color .15s,box-shadow .15s,background .15s}
.fig-input,.fig-select{height:38px;padding:0 11px}
.fig-textarea{min-height:230px;resize:vertical;padding:12px 13px;line-height:1.58}
.fig-input:focus,.fig-select:focus,.fig-textarea:focus{border-color:#111827;box-shadow:0 0 0 3px rgba(17,24,39,.08)}
.fig-textarea::placeholder,.fig-input::placeholder{color:#9aa4b2}
.fig-prompt-actions{display:flex;gap:8px;margin-top:12px;flex-wrap:wrap}
.fig-preview{flex:1;min-height:0;display:flex;align-items:center;justify-content:center;background:
  radial-gradient(circle at 50% 36%,rgba(255,255,255,.1),transparent 34%),#111827;padding:26px;position:relative}
.fig-preview::before{content:"";position:absolute;inset:18px;border:1px solid rgba(255,255,255,.08);border-radius:10px;pointer-events:none}
.fig-canvas{width:min(100%,820px);aspect-ratio:4/3;border:1px solid rgba(255,255,255,.14);border-radius:8px;
  background:#fff;display:flex;align-items:center;justify-content:center;color:#8b95a5;font-size:13px;text-align:center;
  padding:24px;box-shadow:0 26px 70px rgba(0,0,0,.34)}
.fig-canvas.is-loading{position:relative;color:#475569;background:#f8fafc}
.fig-canvas.is-loading::after{content:"";width:28px;height:28px;border-radius:50%;border:3px solid #dbe2ea;
  border-top-color:#111827;animation:figSpin .8s linear infinite;margin-left:12px;flex:0 0 auto}
@keyframes figSpin{to{transform:rotate(360deg)}}
.fig-canvas svg{width:100%;height:100%;max-width:100%;max-height:100%;display:block}
.fig-canvas img{width:100%;height:100%;object-fit:contain;display:block}
.fig-placeholder{width:100%;height:100%;display:grid;grid-template-rows:auto 1fr auto;gap:18px;text-align:left;color:#334155}
.fig-ph-top{display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e2e8f0;padding-bottom:12px}
.fig-ph-title{font-size:13px;font-weight:800;color:#111827}.fig-ph-tag{font-size:10px;font-weight:800;color:#64748b;
  border:1px solid #dbe2ea;border-radius:999px;padding:3px 8px;text-transform:uppercase;letter-spacing:.08em}
.fig-ph-flow{display:grid;grid-template-columns:1fr 28px 1fr 28px 1fr;align-items:center;gap:10px}
.fig-ph-node{min-height:86px;border:1px solid #dbe2ea;border-radius:8px;background:#f8fafc;padding:12px;display:flex;flex-direction:column;gap:8px}
.fig-ph-line{height:6px;border-radius:999px;background:#cbd5e1}.fig-ph-line.short{width:64%}.fig-ph-arrow{height:2px;background:#94a3b8;position:relative}
.fig-ph-arrow::after{content:"";position:absolute;right:-1px;top:-4px;border-left:7px solid #94a3b8;border-top:5px solid transparent;border-bottom:5px solid transparent}
.fig-ph-foot{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.fig-ph-chip{height:26px;border-radius:6px;background:#eef2f7;border:1px solid #e2e8f0}
.fig-genbar{border-top:1px solid rgba(148,163,184,.2);padding:12px 16px;background:#fff;display:flex;gap:9px;align-items:center;flex-wrap:wrap}
.fig-history{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-top:10px}
.fig-thumb{border:1px solid rgba(148,163,184,.24);border-radius:8px;background:#fff;overflow:hidden;color:#64748b;font-size:11px;
  box-shadow:0 8px 22px rgba(15,23,42,.06)}
.fig-thumb-img{aspect-ratio:4/3;background:#f8fafc;display:flex;align-items:center;justify-content:center}
.fig-thumb-img img{width:100%;height:100%;object-fit:cover;display:block}
.fig-thumb-body{padding:9px}
.fig-thumb-prompt{color:#1f2937;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.fig-thumb-meta{margin-top:5px;color:#94a3b8}
.fig-thumb-actions{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
#figure-view .page-head{align-items:center;margin-bottom:16px;padding:2px 2px 0}
#figure-view .page-kicker{color:#475569;font-size:11px;letter-spacing:.09em;text-transform:uppercase}
#figure-view .page-title{font-size:25px;color:#0f172a;letter-spacing:0}
#figure-view .page-sub{max-width:760px;color:#64748b}
#figure-view .sm-btn{height:30px;padding:0 11px;border-radius:7px;border:1px solid #d8dee8;background:#fff;
  color:#334155;font-weight:700;font-size:12px;display:inline-flex;align-items:center;justify-content:center;gap:6px;
  box-shadow:0 1px 2px rgba(15,23,42,.04)}
#figure-view .sm-btn:hover{border-color:#111827;color:#111827;background:#f8fafc}
#figure-view .sm-btn.pri{background:#111827;border-color:#111827;color:#fff;box-shadow:0 10px 22px rgba(17,24,39,.18)}
#figure-view .sm-btn.pri:hover{background:#0b1220;border-color:#0b1220;color:#fff;transform:translateY(-1px)}
#figure-view .paper-meta{color:#64748b;font-size:12px;line-height:1.45}
@media(max-width:1100px){
  #figure-view{padding:20px}
  .fig-workbench{grid-template-columns:1fr}
  .fig-pane{min-height:520px}
}
@media(max-width:760px){
  #figure-view{padding:16px}
  #figure-view .page-head{align-items:flex-start;flex-direction:column}
  .fig-row{grid-template-columns:1fr}
  .fig-genbar{align-items:stretch}
  .fig-genbar .fig-select,.fig-genbar .fig-input,#figure-view .fig-genbar .sm-btn{width:100%!important}
}
.page-head{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:18px}
.page-kicker{font-size:12px;color:var(--muted);font-weight:600;margin-bottom:2px}
.page-title{font-size:24px;font-weight:800;color:var(--text)}
.page-sub{font-size:13px;color:var(--muted);margin-top:4px}
.paper-toolbar{display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.paper-search{min-width:220px;flex:1;border:1.5px solid var(--border);border-radius:10px;
  padding:8px 12px;font-size:13px;outline:none;background:var(--white);font-family:inherit}
.paper-search:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(108,92,231,.08)}
.paper-table-wrap{flex:1;overflow:auto;background:var(--white);border:1px solid var(--border);border-radius:12px}
.paper-table{width:100%;border-collapse:collapse;min-width:720px}
.paper-table th{position:sticky;top:0;background:#f8f9fe;color:var(--muted);font-size:12px;
  text-align:left;font-weight:700;padding:10px 12px;border-bottom:1px solid var(--border)}
.paper-table td{padding:11px 12px;border-bottom:1px solid var(--border);vertical-align:middle;font-size:13px}
.paper-table tr:last-child td{border-bottom:none}
.paper-name{font-weight:650;color:var(--text);max-width:360px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.paper-meta{color:var(--muted);font-size:12px}
.paper-actions{display:flex;gap:6px;justify-content:flex-end}
.paper-empty{padding:38px;text-align:center;color:var(--light);font-size:13px}
.chip{display:inline-flex;align-items:center;border-radius:999px;background:var(--ps);color:var(--p);
  padding:2px 8px;font-size:12px;white-space:nowrap}
.reader-overlay{position:fixed;inset:0;background:rgba(30,31,46,.42);z-index:900;
  display:none;align-items:stretch;justify-content:center;padding:22px}
.reader-overlay.on{display:flex}
.reader-shell{width:min(1180px,100%);height:100%;background:var(--white);border-radius:12px;
  box-shadow:0 18px 60px rgba(0,0,0,.24);display:flex;flex-direction:column;overflow:hidden}
.reader-head{height:48px;display:flex;align-items:center;gap:10px;padding:0 12px 0 16px;
  border-bottom:1px solid var(--border);background:#f8f9fe}
.reader-title{flex:1;min-width:0;font-size:13px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.reader-frame{flex:1;width:100%;border:0;background:#f1f3f8}
.reader-fallback{display:none;padding:12px;font-size:12px;color:var(--muted);border-top:1px solid var(--border)}
.reader-fallback.on{display:block}
.chunk-toolbar{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);
  background:#fff;flex-wrap:wrap}
.chunk-stat{font-size:12px;color:var(--muted)}
.chunk-list{flex:1;overflow:auto;background:#f6f7fb;padding:14px}
.chunk-card{background:#fff;border:1px solid var(--border);border-radius:8px;margin-bottom:10px;overflow:hidden}
.chunk-card-head{display:flex;align-items:center;gap:8px;padding:8px 10px;border-bottom:1px solid var(--border);
  background:#fbfbfe;font-size:12px;color:var(--muted);flex-wrap:wrap}
.chunk-no{font-weight:700;color:var(--p)}
.chunk-text{white-space:pre-wrap;font-family:ui-monospace,SFMono-Regular,Consolas,monospace;
  font-size:12px;line-height:1.55;color:var(--text);padding:10px;word-break:break-word}

/* Settings */
#settings-view{flex:1;display:none;flex-direction:column;overflow:auto;padding:26px 34px}
#settings-view.on{display:flex}
#notes-view{flex:1;display:none;flex-direction:column;overflow:hidden;padding:0}
#notes-view.on{display:flex}
/* 鈹€鈹€ Notes redesign 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€ */
.nv-layout{display:flex;flex:1;min-height:0;overflow:hidden}
/* Left sidebar */
.nv-sidebar{width:260px;flex-shrink:0;background:#16122a;display:flex;flex-direction:column;overflow:hidden}
.nv-sidebar-head{padding:20px 16px 14px;background:linear-gradient(160deg,#2d1f5e 0%,#16122a 100%)}
.nv-brand{display:flex;align-items:flex-start;gap:10px}
.nv-brand-icon{font-size:26px;line-height:1}
.nv-brand-title{font-size:15px;font-weight:800;color:#fff;margin-bottom:2px}
.nv-brand-sub{font-size:11px;color:#9e8fd8;line-height:1.4}
.nv-search-row{display:flex;gap:6px;padding:10px 12px 0}
.nv-search{flex:1;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);
  border-radius:8px;padding:7px 10px;font-size:12.5px;color:#e0d9f7;outline:none;font-family:inherit}
.nv-search::placeholder{color:#7d70a8}.nv-search:focus{border-color:#a29bfe}
.nv-filter-btn{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);
  border-radius:8px;width:32px;color:#9e8fd8;cursor:pointer;font-size:13px;transition:all .12s}
.nv-filter-btn:hover{background:rgba(255,255,255,.15)}
.nv-new-btn{margin:10px 12px 4px;background:linear-gradient(135deg,#7c3aed,#6c5ce7);
  color:#fff;border:none;border-radius:9px;padding:9px 12px;font-size:13px;font-weight:600;
  cursor:pointer;text-align:left;transition:all .15s}
.nv-new-btn:hover{background:linear-gradient(135deg,#6d28d9,#5849be)}
.nv-section-label{padding:14px 14px 6px;font-size:10.5px;font-weight:700;color:#7d70a8;
  letter-spacing:.6px;text-transform:uppercase}
/* Pinned note cards */
.nv-note-card{background:#fff;border-radius:10px;padding:11px 13px;margin:0 10px 8px;cursor:pointer;
  border:1.5px solid transparent;transition:all .15s;position:relative}
.nv-note-card:hover{border-color:#a29bfe;box-shadow:0 3px 12px rgba(108,92,231,.2)}
.nv-note-card.active{border-color:#6c5ce7;box-shadow:0 3px 16px rgba(108,92,231,.3)}
.nv-note-card-title{font-size:13px;font-weight:700;color:#1e1f2e;margin-bottom:4px;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nv-note-card-tags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:5px}
.nv-note-card-preview{font-size:11.5px;color:#6b7280;line-height:1.5;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.nv-note-card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:6px}
.nv-note-card-time{font-size:10.5px;color:#b0aac4}
.nv-note-card-star{font-size:13px;cursor:pointer;color:#f59e0b}
/* Recent note list items */
.nv-list{flex:1;overflow-y:auto;padding:0 8px}
.nv-note-item{padding:9px 10px;border-radius:8px;cursor:pointer;border:1px solid transparent;
  margin-bottom:2px;transition:all .12s}
.nv-note-item:hover{background:rgba(255,255,255,.06)}
.nv-note-item.active{background:rgba(108,92,231,.18);border-color:rgba(108,92,231,.3)}
.nv-note-item-title{font-size:13px;font-weight:600;color:#e0d9f7;white-space:nowrap;
  overflow:hidden;text-overflow:ellipsis;margin-bottom:3px}
.nv-note-item-row{display:flex;justify-content:space-between;align-items:center}
.nv-note-item-tags{display:flex;gap:3px;flex:1;min-width:0;overflow:hidden}
.nv-note-item-date{font-size:10.5px;color:#7d70a8;flex-shrink:0;margin-left:6px}
.nv-sidebar-footer{padding:12px 14px;border-top:1px solid rgba(255,255,255,.07);font-size:12px;
  color:#7d70a8;cursor:pointer;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.nv-sidebar-footer:hover{color:#a29bfe}
/* Tag pills */
.ntag-d{padding:1px 7px;border-radius:10px;font-size:10.5px;font-weight:600;white-space:nowrap}
.ntag-l{padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;white-space:nowrap}
/* 鈹€鈹€ Center editor 鈹€鈹€ */
.nv-editor{flex:1;display:flex;flex-direction:column;min-width:0;background:#fff;
  border-left:1px solid #e8eaf0;border-right:1px solid #e8eaf0}
.nv-editor-head{display:flex;align-items:center;padding:18px 22px 0;gap:8px;flex-shrink:0;
  border-bottom:1px solid #f0eef8;padding-bottom:14px}
.nv-title-input{flex:1;font-size:20px;font-weight:700;color:#1e1f2e;border:none;outline:none;
  padding:0;background:transparent;font-family:inherit;min-width:0}
.nv-title-input::placeholder{color:#d0cce8}
.nv-pin-btn{background:none;border:none;font-size:18px;cursor:pointer;color:#d1d5db;
  transition:color .12s;padding:2px 4px;line-height:1;flex-shrink:0}
.nv-pin-btn:hover{color:#f59e0b}
.nv-pin-btn.pinned{color:#f59e0b}
.nv-tags-row{display:flex;align-items:center;padding:8px 22px;gap:6px;flex-wrap:wrap;
  flex-shrink:0;min-height:34px;border-bottom:1px solid #f5f4fb}
.nv-tag-pills{display:flex;gap:5px;flex-wrap:wrap}
.ntag-editor{display:flex;align-items:center;gap:4px;padding:2px 9px;border-radius:10px;
  font-size:12px;font-weight:600}
.ntag-x{cursor:pointer;font-size:9px;opacity:.7;line-height:1;margin-left:1px}
.ntag-x:hover{opacity:1}
.nv-tag-input{border:none;outline:none;font-size:12.5px;color:#1e1f2e;background:transparent;
  min-width:80px;padding:2px 4px;font-family:inherit}
.nv-tag-input::placeholder{color:#c4b5fd;font-size:12px}
/* Toolbar */
.nv-toolbar{display:flex;align-items:center;gap:1px;padding:6px 14px;
  border-bottom:1px solid #e8eaf0;flex-shrink:0;overflow-x:auto;
  scrollbar-width:none;white-space:nowrap}
.nv-toolbar::-webkit-scrollbar{display:none}
.nv-tb-end{margin-left:auto;display:flex;align-items:center;gap:4px;padding-left:8px;border-left:1px solid #e8eaf0;flex-shrink:0}
.nv-save-btn{background:#6c5ce7;color:#fff;border:none;border-radius:7px;padding:5px 13px;
  font-size:12.5px;font-weight:600;cursor:pointer;transition:all .12s;white-space:nowrap}
.nv-save-btn:hover{background:#5849be}
.nv-tb-action{background:none;border:1px solid #e8eaf0;border-radius:6px;padding:4px 8px;
  font-size:13px;cursor:pointer;color:#6b7280;transition:all .12s;line-height:1;white-space:nowrap}
.nv-tb-action:hover{background:#f0eeff;border-color:#a29bfe;color:#6c5ce7}
.nv-autosave-status{font-size:11px;color:#16a34a;white-space:nowrap;opacity:0;transition:opacity .3s;padding:0 4px}
.nv-autosave-status.show{opacity:1}
.nv-tb-btn{background:none;border:none;border-radius:6px;padding:5px 8px;font-size:12.5px;
  font-weight:700;color:#6b7280;cursor:pointer;transition:all .12s;font-family:inherit;line-height:1}
.nv-tb-btn:hover{background:#f0eeff;color:#6c5ce7}
.nv-tb-btn.italic{font-style:italic}.nv-tb-btn.strike{text-decoration:line-through}
.nv-tb-btn.mono{font-family:monospace;font-size:11px;font-weight:400}
.nv-tb-sep{width:1px;height:16px;background:#e8eaf0;margin:0 4px;flex-shrink:0}
.nv-textarea{flex:1;border:none;outline:none;padding:16px 22px;font-size:14.5px;
  line-height:1.85;color:#1e1f2e;resize:none;font-family:-apple-system,BlinkMacSystemFont,
  'Segoe UI','PingFang SC',sans-serif;background:#fff}
.nv-preview{flex:1;padding:16px 22px;overflow-y:auto;font-size:14.5px;line-height:1.85;
  color:#1e1f2e;background:#fff}
.nv-preview h1,.nv-preview h2,.nv-preview h3{margin:.7em 0 .35em;font-weight:700;color:#1e1f2e}
.nv-preview h1{font-size:1.55em;border-bottom:2px solid #f0eeff;padding-bottom:.3em}
.nv-preview h2{font-size:1.25em}.nv-preview h3{font-size:1.1em}
.nv-preview p{margin:.35em 0}.nv-preview ul,.nv-preview ol{padding-left:1.5em;margin:.35em 0}
.nv-preview li{margin:.15em 0}
.nv-preview blockquote{border-left:3px solid #a29bfe;padding:6px 12px;color:#6b7280;
  margin:.5em 0;background:#f7f5ff;border-radius:0 8px 8px 0}
.nv-preview code{background:#f0eeff;padding:1px 6px;border-radius:4px;font-size:13px;color:#5849be}
.nv-preview pre{background:#f0eeff;padding:12px;border-radius:8px;overflow-x:auto;margin:.5em 0}
.nv-preview pre code{background:none;padding:0}
.nv-preview .katex-display{margin:.7em 0}
.nv-preview table{border-collapse:collapse;width:100%;margin:.5em 0}
.nv-preview th,.nv-preview td{border:1px solid #e8eaf0;padding:7px 11px;font-size:13.5px}
.nv-preview th{background:#f0eeff;font-weight:700}
/* callout box: > [!NOTE] style */
.nv-callout{border-left:3px solid #3b82f6;background:#eff6ff;border-radius:0 8px 8px 0;padding:10px 14px;margin:.5em 0}
.nv-statusbar{display:flex;gap:0;padding:7px 22px;border-top:1px solid #e8eaf0;
  background:#fafafa;flex-shrink:0;align-items:center}
.nv-status-seg{font-size:11.5px;color:#6b7280;padding-right:12px}
.nv-status-seg+.nv-status-seg{border-left:1px solid #e8eaf0;padding-left:12px}
.nv-status-end{margin-left:auto;display:flex;align-items:center;gap:8px}
.nv-props-toggle{background:none;border:none;font-size:14px;cursor:pointer;color:#9ca3af;
  padding:2px 4px;transition:color .12s;line-height:1}
.nv-props-toggle:hover{color:#6c5ce7}
.nv-props-toggle.active{color:#6c5ce7}
/* 鈹€鈹€ Right properties panel 鈹€鈹€ */
.nv-props{width:260px;flex-shrink:0;background:#16122a;overflow-y:auto;display:flex;
  flex-direction:column;color:#e0d9f7;transition:width .2s}
.nv-props.hidden{width:0;overflow:hidden}
.nv-tabs{display:flex;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0}
.nv-tab{flex:1;padding:12px 10px;background:none;border:none;font-size:13px;font-weight:600;
  color:#7d70a8;cursor:pointer;transition:all .15s;border-bottom:2px solid transparent;margin-bottom:-1px}
.nv-tab.active{color:#a29bfe;border-bottom-color:#a29bfe;font-weight:700}
.nv-tab:hover:not(.active){color:#c4b5fd}
.nv-prop-section{padding:16px 16px 8px;border-bottom:1px solid rgba(255,255,255,.05)}
.nv-prop-title{font-size:11px;font-weight:700;color:#7d70a8;letter-spacing:.5px;text-transform:uppercase;margin-bottom:12px}
.nv-prop-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;gap:8px}
.nv-prop-label{font-size:12px;color:#9e8fd8;white-space:nowrap}
.nv-prop-val{font-size:12px;color:#e0d9f7;font-weight:500;text-align:right;word-break:break-all}
.nv-status-sel{background:rgba(108,92,231,.2);border:1px solid rgba(108,92,231,.3);border-radius:6px;color:#a29bfe;font-size:12px;padding:4px 8px;cursor:pointer;outline:none}
.nv-status-sel:focus{border-color:#6c5ce7}
.nv-prop-tags{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px}
/* AI assistant */
.nv-ai-panel{margin:16px;border:1px solid rgba(108,92,231,.25);border-radius:12px;background:rgba(108,92,231,.05);overflow:hidden;flex-shrink:0;box-shadow:0 4px 12px rgba(0,0,0,.15)}
.nv-ai-head{display:flex;align-items:center;gap:10px;padding:14px 14px 10px;border-bottom:1px solid rgba(255,255,255,.05)}
.nv-ai-icon{font-size:20px;flex-shrink:0;background:rgba(108,92,231,.2);width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.nv-ai-title-group{display:flex;flex-direction:column}
.nv-ai-title{font-size:13px;font-weight:700;color:#e0d9f7}
.nv-ai-sub{font-size:11px;color:#9e8fd8;margin-top:2px;line-height:1.3}
.nv-ai-actions{display:flex;flex-direction:column;gap:6px;padding:12px}
.nv-ai-btn{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:8px;padding:9px 12px;font-size:12.5px;color:#e0d9f7;cursor:pointer;text-align:left;transition:all .2s ease;display:flex;align-items:center;gap:8px}
.nv-ai-btn::before{content:"鉁?;font-size:14px;opacity:0.7;}
.nv-ai-btn:hover{background:rgba(108,92,231,.3);border-color:#a29bfe;transform:translateY(-1px);box-shadow:0 2px 8px rgba(108,92,231,.2)}
.nv-ai-btn:active{transform:translateY(0)}
.nv-ai-input-row{display:flex;gap:6px;padding:12px;border-top:1px solid rgba(255,255,255,.05);background:rgba(0,0,0,.1)}
.nv-ai-input{flex:1;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:8px 12px;font-size:12.5px;color:#e0d9f7;outline:none;font-family:inherit;transition:border-color .2s}
.nv-ai-input::placeholder{color:#7d70a8}.nv-ai-input:focus{border-color:#a29bfe;background:rgba(255,255,255,.1)}
.nv-ai-send{background:linear-gradient(135deg,#7c3aed,#6c5ce7);border:none;border-radius:8px;width:36px;color:#fff;font-size:15px;cursor:pointer;transition:all .2s;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.nv-ai-send:hover{background:linear-gradient(135deg,#6d28d9,#5849be);transform:scale(1.05)}
.nv-ai-send:active{transform:scale(0.95)}
/* Outline */
.nv-outline{padding:10px 14px;display:flex;flex-direction:column;gap:3px}
.nv-outline-item{font-size:12.5px;color:#9e8fd8;padding:4px 6px;border-radius:6px;
  cursor:pointer;transition:all .12s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nv-outline-item:hover{background:rgba(255,255,255,.08);color:#e0d9f7}
.nv-outline-h1{font-weight:700;color:#e0d9f7}
.nv-outline-h2{padding-left:14px}.nv-outline-h3{padding-left:24px;font-size:12px}

/* Notes workspace polish */
.nv-layout{display:flex;flex:1;min-height:0;overflow:hidden;background:#f6f7fb}
.nv-sidebar{width:300px;flex-shrink:0;background:#fbfcff;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.nv-sidebar-head{padding:20px 18px 12px;border-bottom:1px solid #eef0f5;background:#fff}
.nv-brand{display:flex;align-items:flex-start;gap:11px}
.nv-brand-icon{width:34px;height:34px;border-radius:9px;background:#ecfdf5;color:#047857;display:flex;align-items:center;justify-content:center;font-size:18px;line-height:1}
.nv-brand-title{font-size:16px;font-weight:800;color:var(--text);margin-bottom:1px}
.nv-brand-sub{font-size:12px;color:var(--muted);line-height:1.45}
.nv-search-row{display:flex;gap:8px;padding:12px 14px 0}
.nv-search{flex:1;background:#fff;border:1px solid var(--border);border-radius:8px;padding:8px 10px;font-size:13px;color:var(--text);outline:none;font-family:inherit;min-width:0}
.nv-search::placeholder{color:#9ca3af}
.nv-search:focus{border-color:#4f46e5;box-shadow:0 0 0 3px rgba(79,70,229,.08)}
.nv-filter-btn{background:#fff;border:1px solid var(--border);border-radius:8px;width:34px;color:#64748b;cursor:pointer;font-size:13px;transition:all .12s;flex-shrink:0}
.nv-filter-btn:hover{background:#f8fafc;border-color:#cbd5e1;color:#334155}
.nv-new-btn{margin:10px 14px 6px;background:#1f2937;color:#fff;border:none;border-radius:8px;padding:9px 12px;font-size:13px;font-weight:700;cursor:pointer;text-align:left;transition:all .12s}
.nv-new-btn:hover{background:#111827}
.nv-section-label{padding:14px 16px 7px;font-size:11px;font-weight:800;color:#94a3b8;letter-spacing:.04em;text-transform:uppercase}
.nv-note-card,.nv-note-item{cursor:pointer;transition:background .12s,border-color .12s,box-shadow .12s}
.nv-note-card{background:#fff;border-radius:8px;padding:12px 13px;margin:0 12px 8px;border:1px solid #e5e7eb;position:relative}
.nv-note-card:hover{border-color:#cbd5e1;box-shadow:0 6px 18px rgba(15,23,42,.06)}
.nv-note-card.active{border-color:#4f46e5;box-shadow:inset 3px 0 0 #4f46e5}
.nv-note-card-title{font-size:13.5px;font-weight:800;color:#111827;margin-bottom:5px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nv-note-card-tags{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:6px}
.nv-note-card-preview{font-size:12px;color:#64748b;line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.nv-note-card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:8px}
.nv-note-card-time{font-size:11px;color:#94a3b8}
.nv-note-card-star{font-size:13px;cursor:pointer;color:#d97706}
.nv-list{flex:1;overflow-y:auto;padding:0 10px 10px}
.nv-note-item{padding:10px 11px;border-radius:8px;border:1px solid transparent;margin-bottom:4px}
.nv-note-item:hover{background:#f1f5f9}
.nv-note-item.active{background:#eef2ff;border-color:#c7d2fe}
.nv-note-item-title{font-size:13px;font-weight:700;color:#1f2937;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:4px}
.nv-note-item-row{display:flex;justify-content:space-between;align-items:center;gap:8px}
.nv-note-item-tags{display:flex;gap:4px;flex:1;min-width:0;overflow:hidden}
.nv-note-item-date{font-size:11px;color:#94a3b8;flex-shrink:0}
.nv-sidebar-footer{padding:12px 16px;border-top:1px solid #eef0f5;font-size:12px;color:#64748b;cursor:pointer;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;background:#fff}
.nv-sidebar-footer:hover{color:#4f46e5}
.ntag-d,.ntag-l{border-radius:999px;font-size:11px;font-weight:700;white-space:nowrap}
.ntag-d{padding:1px 7px}.ntag-l{padding:2px 8px}
.nv-editor{flex:1;display:flex;flex-direction:column;min-width:0;background:#fff;border-left:none;border-right:none}
.nv-editor-head{display:flex;align-items:center;padding:22px 28px 14px;gap:10px;flex-shrink:0;border-bottom:none}
.nv-title-input{flex:1;font-size:24px;font-weight:800;color:#111827;border:none;outline:none;padding:0;background:transparent;font-family:inherit;min-width:0;line-height:1.25}
.nv-title-input::placeholder{color:#cbd5e1}
.nv-pin-btn{width:34px;height:34px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;font-size:17px;cursor:pointer;color:#cbd5e1;transition:all .12s;line-height:1;flex-shrink:0;padding:0}
.nv-pin-btn:hover,.nv-pin-btn.pinned{border-color:#fbbf24;color:#d97706;background:#fffbeb}
.nv-tags-row{display:flex;align-items:center;padding:0 28px 14px;gap:7px;flex-wrap:wrap;flex-shrink:0;min-height:auto;border-bottom:none}
.nv-tag-pills{display:flex;gap:6px;flex-wrap:wrap}
.ntag-editor{display:flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;font-size:12px;font-weight:700}
.ntag-x{cursor:pointer;font-size:10px;opacity:.65;line-height:1;margin-left:1px}
.ntag-x:hover{opacity:1}
.nv-tag-input{border:1px dashed #cbd5e1;border-radius:999px;outline:none;font-size:12.5px;color:#334155;background:#fff;min-width:92px;padding:3px 10px;font-family:inherit}
.nv-tag-input::placeholder{color:#94a3b8;font-size:12px}
.nv-toolbar{display:flex;align-items:center;gap:2px 3px;padding:8px 20px;border-top:1px solid #eef0f5;border-bottom:1px solid #eef0f5;flex-shrink:0;overflow:visible;scrollbar-width:none;white-space:normal;background:#fbfcff;flex-wrap:wrap}
.nv-toolbar::-webkit-scrollbar{display:none}
.nv-tb-end{margin-left:auto;display:flex;align-items:center;gap:6px;padding-left:10px;border-left:1px solid #e5e7eb;flex-shrink:0;min-width:max-content}
.nv-save-btn{background:#1f2937;color:#fff;border:none;border-radius:8px;padding:6px 14px;font-size:12.5px;font-weight:700;cursor:pointer;transition:all .12s;white-space:nowrap;min-width:88px}
.nv-save-btn:hover{background:#111827}
.nv-tb-action{background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:5px 9px;font-size:13px;cursor:pointer;color:#64748b;transition:all .12s;line-height:1;white-space:nowrap}
.nv-tb-action:hover{background:#f8fafc;border-color:#cbd5e1;color:#111827}
.nv-autosave-status{font-size:11px;color:#059669;white-space:nowrap;opacity:0;transition:opacity .3s;padding:0 4px}
.nv-autosave-status.show{opacity:1}
.nv-tb-btn{background:transparent;border:none;border-radius:7px;padding:6px 8px;font-size:12.5px;font-weight:800;color:#64748b;cursor:pointer;transition:all .12s;font-family:inherit;line-height:1}
.nv-tb-btn:hover{background:#eef2ff;color:#3730a3}
.nv-tb-btn.italic{font-style:italic}.nv-tb-btn.strike{text-decoration:line-through}
.nv-tb-btn.mono{font-family:monospace;font-size:11px;font-weight:500}
.nv-tb-sep{width:1px;height:18px;background:#e5e7eb;margin:0 5px;flex-shrink:0}
.nv-textarea{flex:1;border:none;outline:none;padding:24px 34px;font-size:15px;line-height:1.85;color:#111827;resize:none;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC',sans-serif;background:#fff}
.nv-preview{flex:1;padding:24px 34px;overflow-y:auto;font-size:15px;line-height:1.85;color:#111827;background:#fff}
.nv-preview h1,.nv-preview h2,.nv-preview h3{margin:.75em 0 .35em;font-weight:800;color:#111827}
.nv-preview h1{font-size:1.55em;border-bottom:1px solid #e5e7eb;padding-bottom:.35em}
.nv-preview h2{font-size:1.28em}.nv-preview h3{font-size:1.1em}
.nv-preview p{margin:.38em 0}.nv-preview ul,.nv-preview ol{padding-left:1.5em;margin:.38em 0}
.nv-preview li{margin:.18em 0}
.nv-preview blockquote{border-left:3px solid #4f46e5;padding:7px 12px;color:#475569;margin:.6em 0;background:#f8fafc;border-radius:0 8px 8px 0}
.nv-preview code{background:#f1f5f9;padding:1px 6px;border-radius:4px;font-size:13px;color:#334155}
.nv-preview pre{background:#0f172a;color:#e5e7eb;padding:13px;border-radius:8px;overflow-x:auto;margin:.6em 0}
.nv-preview pre code{background:none;padding:0;color:inherit}
.nv-preview .katex-display{margin:.75em 0}
.nv-preview table{border-collapse:collapse;width:100%;margin:.6em 0}
.nv-preview th,.nv-preview td{border:1px solid #e5e7eb;padding:7px 11px;font-size:13.5px}
.nv-preview th{background:#f8fafc;font-weight:800}
.nv-callout{border-left:3px solid #2563eb;background:#eff6ff;border-radius:0 8px 8px 0;padding:10px 14px;margin:.6em 0}
.nv-statusbar{display:flex;gap:0;padding:8px 28px;border-top:1px solid #eef0f5;background:#fbfcff;flex-shrink:0;align-items:center}
.nv-status-seg{font-size:11.5px;color:#64748b;padding-right:12px}
.nv-status-seg+.nv-status-seg{border-left:1px solid #e5e7eb;padding-left:12px}
.nv-status-end{margin-left:auto;display:flex;align-items:center;gap:8px}
.nv-props-toggle{width:28px;height:28px;border:1px solid #e5e7eb;border-radius:8px;background:#fff;font-size:13px;cursor:pointer;color:#64748b;transition:all .12s;line-height:1;padding:0}
.nv-props-toggle:hover,.nv-props-toggle.active{border-color:#c7d2fe;background:#eef2ff;color:#3730a3}
.nv-props{width:280px;flex-shrink:0;background:#fbfcff;border-left:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;color:#1f2937;transition:width .2s}
.nv-props.hidden{width:0;overflow:hidden;border-left:none}
.nv-tabs{display:flex;border-bottom:1px solid #eef0f5;flex-shrink:0;background:#fff;padding:8px}
.nv-tab{flex:1;padding:7px 8px;background:transparent;border:none;border-radius:7px;font-size:13px;font-weight:700;color:#64748b;cursor:pointer;transition:all .12s}
.nv-tab.active{color:#111827;background:#f1f5f9;border-bottom-color:transparent}
.nv-tab:hover:not(.active){background:#f8fafc;color:#334155}
.nv-prop-section{padding:16px 16px 8px;border-bottom:1px solid #eef0f5}
.nv-prop-title{font-size:11px;font-weight:800;color:#94a3b8;letter-spacing:.04em;text-transform:uppercase;margin-bottom:12px}
.nv-prop-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;gap:8px}
.nv-prop-label{font-size:12px;color:#64748b;white-space:nowrap}
.nv-prop-val{font-size:12px;color:#1f2937;font-weight:600;text-align:right;word-break:break-word}
.nv-status-sel{background:#fff;border:1px solid #e5e7eb;border-radius:8px;color:#334155;font-size:12px;padding:5px 8px;cursor:pointer;outline:none;transition:border-color .2s}
.nv-status-sel:focus{border-color:#4f46e5;box-shadow:0 0 0 3px rgba(79,70,229,.08)}
.nv-prop-tags{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px}
.nv-ai-panel{margin:16px;border:1px solid #e5e7eb;border-radius:10px;background:#fff;overflow:hidden;flex-shrink:0;box-shadow:0 4px 14px rgba(15,23,42,.04)}
.nv-ai-head{display:flex;align-items:center;gap:12px;padding:14px 14px 12px;border-bottom:1px solid #eef0f5}
.nv-ai-icon{width:32px;height:32px;border-radius:8px;background:#eef2ff;color:#4f46e5;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.nv-ai-title-group{display:flex;flex-direction:column}
.nv-ai-title{font-size:13.5px;font-weight:800;color:#111827}
.nv-ai-sub{font-size:11px;color:#64748b;margin-top:2px;line-height:1.4}
.nv-ai-actions{display:flex;flex-direction:column;gap:8px;padding:14px}
.nv-ai-btn{background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:9px 12px;font-size:12.5px;color:#334155;font-weight:600;cursor:pointer;text-align:left;transition:all .2s;display:flex;align-items:center;gap:8px;box-shadow:0 1px 2px rgba(15,23,42,.02)}
.nv-ai-btn::before{content:"鉁?;font-size:14px;opacity:0.8;}
.nv-ai-btn:hover{background:#eef2ff;border-color:#c7d2fe;color:#3730a3;transform:translateY(-1px);box-shadow:0 3px 8px rgba(79,70,229,.08)}
.nv-ai-btn:active{transform:translateY(0)}
.nv-ai-input-row{display:flex;gap:8px;padding:14px;border-top:1px solid #eef0f5;background:#fbfcff}
.nv-ai-input{flex:1;background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;font-size:12.5px;color:#111827;outline:none;font-family:inherit;min-width:0;transition:all .2s}
.nv-ai-input::placeholder{color:#94a3b8}.nv-ai-input:focus{border-color:#4f46e5;box-shadow:0 0 0 3px rgba(79,70,229,.08)}
.nv-ai-send{background:#1f2937;border:none;border-radius:8px;width:36px;color:#fff;font-size:14px;cursor:pointer;transition:all .2s;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.nv-ai-send:hover{background:#111827;transform:scale(1.05);box-shadow:0 2px 6px rgba(15,23,42,.15)}
.nv-ai-send:active{transform:scale(0.95)}
.nv-outline{padding:12px 16px;display:flex;flex-direction:column;gap:3px}
.nv-outline-item{font-size:12.5px;color:#64748b;padding:5px 7px;border-radius:7px;cursor:pointer;transition:all .12s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.nv-outline-item:hover{background:#f1f5f9;color:#111827}
.nv-outline-h1{font-weight:800;color:#1f2937}
.nv-outline-h2{padding-left:16px}.nv-outline-h3{padding-left:26px;font-size:12px}
@media (max-width:1100px){.nv-sidebar{width:260px}.nv-props{width:250px}.nv-title-input{font-size:21px}}
@media (max-width:860px){.nv-layout{flex-direction:column}.nv-sidebar{width:auto;max-height:230px;border-right:none;border-bottom:1px solid var(--border)}.nv-props{display:none}.nv-editor-head{padding:18px 18px 12px}.nv-tags-row{padding:0 18px 12px}.nv-textarea,.nv-preview{padding:18px}.nv-toolbar{padding:8px 12px}.nv-tb-end{width:100%;justify-content:flex-end;border-left:none;border-top:1px solid #e5e7eb;padding:8px 0 0;margin-top:4px}.nv-statusbar{padding:8px 18px}}

/* Notes refined surface */
#notes-view{
  background:
    linear-gradient(180deg,#f7f9fc 0%,#eef2f7 100%);
}
#notes-view .nv-layout{
  gap:14px;
  padding:16px;
  background:
    radial-gradient(circle at 18% 0%,rgba(20,184,166,.09),transparent 28%),
    radial-gradient(circle at 96% 8%,rgba(79,70,229,.08),transparent 30%),
    transparent;
}
#notes-view .nv-sidebar,
#notes-view .nv-editor,
#notes-view .nv-props{
  border:1px solid rgba(148,163,184,.28);
  box-shadow:0 18px 45px rgba(15,23,42,.07);
}
#notes-view .nv-sidebar{
  width:314px;
  border-radius:12px;
  background:#f8fafc;
}
#notes-view .nv-sidebar-head{
  padding:18px 18px 14px;
  background:linear-gradient(180deg,#ffffff 0%,#f8fafc 100%);
  border-bottom:1px solid rgba(226,232,240,.9);
}
#notes-view .nv-brand-icon{
  width:38px;
  height:38px;
  border-radius:10px;
  background:#0f172a;
  color:#fff;
  box-shadow:0 10px 24px rgba(15,23,42,.18);
}
#notes-view .nv-brand-title{
  color:#0f172a;
  font-size:17px;
  letter-spacing:0;
}
#notes-view .nv-brand-sub{
  max-width:220px;
  color:#64748b;
}
#notes-view .nv-search-row{
  padding:12px 14px 0;
}
#notes-view .nv-search{
  height:38px;
  border-color:#dbe3ee;
  border-radius:9px;
  background:#fff;
  box-shadow:0 1px 2px rgba(15,23,42,.03);
}
#notes-view .nv-search:focus{
  border-color:#0f172a;
  box-shadow:0 0 0 3px rgba(15,23,42,.08);
}
#notes-view .nv-filter-btn{
  width:38px;
  border-radius:9px;
}
#notes-view .nv-new-btn{
  height:38px;
  margin:10px 14px 8px;
  border-radius:9px;
  background:#0f172a;
  box-shadow:0 10px 22px rgba(15,23,42,.14);
  text-align:center;
}
#notes-view .nv-new-btn:hover{
  background:#020617;
  transform:translateY(-1px);
}
#notes-view .nv-section-label{
  color:#64748b;
  padding:13px 16px 8px;
}
#notes-view .nv-list{
  padding:0 10px 12px;
}
#notes-view .nv-note-card,
#notes-view .nv-note-item{
  border-radius:10px;
}
#notes-view .nv-note-card{
  margin:0 12px 9px;
  border-color:#dfe7f1;
  background:linear-gradient(180deg,#fff 0%,#fbfdff 100%);
  box-shadow:0 1px 2px rgba(15,23,42,.04);
}
#notes-view .nv-note-card:hover,
#notes-view .nv-note-item:hover{
  transform:translateY(-1px);
  border-color:#b8c3d1;
  box-shadow:0 10px 22px rgba(15,23,42,.08);
}
#notes-view .nv-note-card.active,
#notes-view .nv-note-item.active{
  background:#eef6ff;
  border-color:#38bdf8;
  box-shadow:inset 3px 0 0 #0ea5e9,0 10px 22px rgba(14,165,233,.12);
}
#notes-view .nv-note-item{
  background:#fff;
  border-color:transparent;
  margin-bottom:6px;
}
#notes-view .nv-note-item-title,
#notes-view .nv-note-card-title{
  color:#0f172a;
}
#notes-view .nv-note-card-preview{
  color:#64748b;
}
#notes-view .nv-sidebar-footer{
  background:#fff;
  border-top:1px solid #e2e8f0;
}
#notes-view .nv-editor{
  border-radius:12px;
  overflow:hidden;
  background:#fff;
}
#notes-view .nv-editor-head{
  padding:24px min(42px,4vw) 10px;
  background:#fff;
}
#notes-view .nv-title-input{
  font-size:26px;
  color:#0f172a;
  letter-spacing:0;
}
#notes-view .nv-pin-btn{
  border-color:#dbe3ee;
  border-radius:9px;
}
#notes-view .nv-tags-row{
  padding:0 min(42px,4vw) 18px;
}
#notes-view .nv-tag-input{
  border-color:#d8e0eb;
}
#notes-view .nv-toolbar{
  padding:9px 18px;
  background:#f8fafc;
  border-color:#e2e8f0;
}
#notes-view .nv-tb-btn{
  min-width:30px;
  height:30px;
  border:1px solid transparent;
  border-radius:8px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
}
#notes-view .nv-tb-btn:hover{
  background:#fff;
  border-color:#dbe3ee;
  color:#0f172a;
}
#notes-view .nv-tb-action{
  height:30px;
  border-radius:8px;
  background:#fff;
}
#notes-view .nv-save-btn{
  height:32px;
  border-radius:8px;
  background:#0f172a;
}
#notes-view .nv-save-btn:hover{
  background:#020617;
}
#notes-view .nv-textarea,
#notes-view .nv-preview{
  padding:28px min(56px,5vw);
  max-width:980px;
  width:100%;
  align-self:center;
  font-size:15.5px;
  line-height:1.9;
}
#notes-view .nv-textarea{
  background:
    linear-gradient(#fff 31px,#f1f5f9 32px);
  background-size:100% 32px;
  caret-color:#0f172a;
}
#notes-view .nv-textarea::placeholder{
  color:#a8b3c3;
}
#notes-view .nv-preview{
  background:#fff;
}
#notes-view .nv-statusbar{
  padding:9px min(42px,4vw);
  background:#f8fafc;
  border-top:1px solid #e2e8f0;
}
#notes-view .nv-status-seg{
  color:#64748b;
}
#notes-view .nv-props{
  width:292px;
  border-radius:12px;
  background:#f8fafc;
}
#notes-view .nv-props.hidden{
  width:0;
  border:0;
  box-shadow:none;
}
#notes-view .nv-tabs{
  border-radius:12px 12px 0 0;
}
#notes-view .nv-tab.active{
  background:#0f172a;
  color:#fff;
}
#notes-view .nv-prop-section,
#notes-view .nv-ai-input-row,
#notes-view .nv-ai-head{
  border-color:#e2e8f0;
}
#notes-view .nv-ai-panel{
  border-color:#dbe3ee;
  border-radius:11px;
  box-shadow:0 10px 24px rgba(15,23,42,.06);
}
#notes-view .nv-ai-icon{
  background:#ccfbf1;
  color:#0f766e;
}
#notes-view .nv-ai-btn:hover{
  background:#ecfeff;
  border-color:#67e8f9;
  color:#0f172a;
}
#notes-view .nv-ai-send{
  background:#0f172a;
}
#notes-view .nv-ai-send:hover{
  background:#020617;
}
@media (max-width:1100px){
  #notes-view .nv-layout{padding:10px;gap:10px}
  #notes-view .nv-sidebar{width:280px}
  #notes-view .nv-props{width:260px}
}
@media (max-width:860px){
  #notes-view .nv-layout{padding:0;gap:0}
  #notes-view .nv-sidebar,
  #notes-view .nv-editor,
  #notes-view .nv-props{
    border-radius:0;
    box-shadow:none;
  }
  #notes-view .nv-sidebar{width:auto}
  #notes-view .nv-textarea,
  #notes-view .nv-preview{padding:20px}
}
.settings-panel{max-width:760px;background:var(--white);border:1px solid var(--border);
  border-radius:12px;padding:18px;display:flex;flex-direction:column;gap:16px}
.form-row{display:flex;flex-direction:column;gap:6px}
.form-label{font-size:12px;font-weight:700;color:var(--muted)}
.form-input,.form-textarea{border:1.5px solid var(--border);border-radius:10px;padding:9px 11px;
  font-size:14px;font-family:inherit;outline:none;background:#fff;color:var(--text)}
.form-input:focus,.form-textarea:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(108,92,231,.08)}
.form-textarea{min-height:120px;resize:vertical;line-height:1.6}
.avatar-edit{display:flex;align-items:center;gap:14px}
.avatar-preview{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--pl),var(--p));
  color:#fff;font-size:24px;font-weight:800;display:flex;align-items:center;justify-content:center;
  overflow:hidden;flex-shrink:0}
.avatar-preview img,.user-av img,.av img{width:100%;height:100%;object-fit:cover;display:block}
.form-help{font-size:12px;color:var(--muted)}
.notes-layout{flex:1;display:grid;grid-template-columns:320px 1fr;gap:14px;min-height:0}
.notes-list{background:var(--white);border:1px solid var(--border);border-radius:12px;overflow-y:auto;padding:8px}
.note-item{padding:10px;border-radius:9px;cursor:pointer;border:1px solid transparent;margin-bottom:6px}
.note-item:hover,.note-item.active{background:var(--ps);border-color:var(--p)}
.note-title{font-weight:700;font-size:13px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.note-meta{font-size:11px;color:var(--muted);margin-top:3px}
.note-editor{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:14px;display:flex;flex-direction:column;gap:10px;min-width:0}
.note-content{flex:1;min-height:280px}
.note-preview{flex:1;min-height:280px;padding:12px 14px;border:1px solid var(--border);border-radius:8px;overflow-y:auto;font-size:14px;line-height:1.7;background:var(--bg)}
.note-preview h1,.note-preview h2,.note-preview h3{margin:.6em 0 .3em;font-weight:700}
.note-preview p{margin:.3em 0}
.note-preview code{background:#f0f0f0;padding:1px 4px;border-radius:4px;font-size:13px}
.note-preview pre{background:#f0f0f0;padding:10px;border-radius:6px;overflow-x:auto}
.note-preview blockquote{border-left:3px solid var(--accent);padding-left:10px;color:var(--muted);margin:.4em 0}
.note-preview .katex-display{margin:.6em 0}
.llm-grid{display:grid;grid-template-columns:1.1fr .9fr 1.4fr 1.6fr .9fr;gap:8px;align-items:center}
.llm-grid-head{font-size:12px;font-weight:700;color:var(--muted)}
.agent-name{font-size:13px;font-weight:700;color:var(--text)}
.env-hint{font-size:11px;color:var(--muted);line-height:1.5}
.test-result{font-size:11px;color:var(--muted);margin-top:4px;line-height:1.35;word-break:break-word}
.test-result.ok{color:#16a34a}
.test-result.err{color:#dc2626}
.form-select{border:1.5px solid var(--border);border-radius:10px;padding:8px 10px;
  font-size:13px;font-family:inherit;background:#fff;color:var(--text);outline:none}
.form-select:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(108,92,231,.08)}

#messages{flex:1;overflow-y:auto;padding:28px 40px;display:flex;flex-direction:column;gap:22px}
#messages::-webkit-scrollbar{width:5px}
#messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

.msg{display:flex;gap:12px;align-items:flex-start;animation:fadeup .2s ease}
.msg.user{flex-direction:row-reverse}
@keyframes fadeup{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.av{width:36px;height:36px;min-width:36px;max-width:36px;min-height:36px;max-height:36px;
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:16px;flex:0 0 36px;overflow:hidden}
.msg.user .av{background:var(--p);color:#fff}
.msg.assistant .av{background:var(--ps)}

.msg-body{max-width:72%;display:flex;flex-direction:column;gap:5px}
.msg.user .msg-body{align-items:flex-end}
.intent-lbl{font-size:11px;color:var(--p);background:var(--ps);
  padding:2px 10px;border-radius:10px;align-self:flex-start;font-weight:500}

.bubble{padding:13px 17px;border-radius:16px;line-height:1.7;font-size:14px}
.msg.user .bubble{background:var(--p);color:#fff;border-bottom-right-radius:4px}
.msg.assistant .bubble{background:var(--white);color:var(--text);
  border-bottom-left-radius:4px;box-shadow:var(--sh)}
.eval-strip{margin-top:10px;padding-top:8px;border-top:1px solid var(--border);display:flex;flex-wrap:wrap;gap:6px;align-items:center;justify-content:flex-end;font-size:11px;color:var(--muted)}
.eval-chip{border:1px solid #e5e7eb;border-radius:999px;padding:2px 7px;background:#f8fafc;white-space:nowrap}
.eval-chip.ok{color:#047857;background:#ecfdf5;border-color:#bbf7d0}
.eval-chip.warn{color:#92400e;background:#fffbeb;border-color:#fde68a}
.eval-chip.risk{color:#991b1b;background:#fef2f2;border-color:#fecaca}
.eval-warning{width:100%;text-align:right;color:#b45309;font-size:11px}

/* Markdown */
.bubble p{margin-bottom:.6em}.bubble p:last-child{margin-bottom:0}
.bubble ul,.bubble ol{padding-left:1.4em;margin-bottom:.6em}
.bubble li{margin-bottom:.25em}
.bubble h1,.bubble h2,.bubble h3{margin:.8em 0 .4em;font-weight:700}
.bubble h1{font-size:1.15em}.bubble h2{font-size:1.05em}.bubble h3{font-size:1em}
.bubble strong{font-weight:700}
.bubble code{background:#f0eeff;padding:1px 5px;border-radius:4px;font-size:.87em;font-family:monospace}
.msg.user .bubble code{background:rgba(255,255,255,.2)}
.bubble pre{background:#1e1f2e;padding:13px;border-radius:10px;overflow-x:auto;margin:.6em 0}
.bubble pre code{background:none;color:#e2e6f0;padding:0;font-size:.88em}
.bubble table{border-collapse:collapse;width:100%;margin:.6em 0;font-size:.9em}
.bubble th,.bubble td{border:1px solid var(--border);padding:6px 10px}
.bubble th{background:#f8f9fe;font-weight:600}
.bubble hr{border:none;border-top:1px solid var(--border);margin:.8em 0}
.bubble blockquote{border-left:3px solid var(--pl);padding-left:12px;color:var(--muted);margin:.6em 0}

/* Thinking */
.dots{display:flex;gap:5px;align-items:center;padding:2px 0}
.dots span{width:7px;height:7px;border-radius:50%;background:var(--pl);animation:bounce 1.2s infinite}
.dots span:nth-child(2){animation-delay:.2s}.dots span:nth-child(3){animation-delay:.4s}
@keyframes bounce{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-6px);opacity:1}}
.progress-box{min-width:260px;max-width:420px}
.progress-head{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:8px}
.progress-title{font-size:13px;font-weight:700;color:var(--text)}
.progress-pct{font-size:11px;color:var(--muted);font-variant-numeric:tabular-nums}
.progress-track{height:5px;background:#eef0f5;border-radius:999px;overflow:hidden;margin-bottom:9px}
.progress-fill{height:100%;width:5%;background:var(--p);border-radius:999px;transition:width .25s ease}
.progress-steps{display:flex;flex-direction:column;gap:4px}
.progress-step{display:flex;gap:7px;align-items:flex-start;font-size:12px;color:var(--muted);line-height:1.45}
.progress-dot{width:6px;height:6px;border-radius:50%;background:var(--pl);margin-top:6px;flex-shrink:0}
.progress-step.active{color:var(--text);font-weight:600}
.progress-step.active .progress-dot{background:var(--p)}

/* Input */
#input-wrap{padding:14px 40px 20px;background:var(--white);border-top:1px solid var(--border)}
.input-box{display:flex;align-items:flex-end;background:#f8f9fe;
  border:1.5px solid var(--border);border-radius:16px;padding:10px 10px 10px 16px;
  gap:8px;transition:border-color .2s}
.input-box:focus-within{border-color:var(--p);box-shadow:0 0 0 3px rgba(108,92,231,.08)}
#user-input{flex:1;border:none;background:transparent;outline:none;font-size:14px;
  color:var(--text);resize:none;max-height:120px;line-height:1.55;font-family:inherit}
#user-input::placeholder{color:var(--light)}
.itool{width:32px;height:32px;border-radius:8px;border:none;background:transparent;
  color:var(--muted);cursor:pointer;display:flex;align-items:center;justify-content:center;
  font-size:16px;transition:all .15s}
.itool:hover{background:var(--ps);color:var(--p)}
#send-btn{width:36px;height:36px;border-radius:10px;background:var(--p);border:none;
  color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:all .15s;flex-shrink:0}
#send-btn:hover{background:var(--p2)}
#send-btn:disabled{background:var(--border);cursor:not-allowed}
#stop-btn{width:36px;height:36px;border-radius:10px;background:#ef4444;border:none;
  color:#fff;cursor:pointer;display:none;align-items:center;justify-content:center;
  transition:all .15s;flex-shrink:0}
#stop-btn:hover{background:#dc2626}
#stop-btn.on{display:flex}
.input-foot{text-align:center;font-size:11.5px;color:var(--light);margin-top:8px}
.compress-bar{display:none;align-items:center;justify-content:space-between;gap:10px;
  margin-bottom:8px;padding:8px 10px;border:1px solid #fde68a;background:#fffbeb;
  color:#92400e;border-radius:10px;font-size:12px}
.compress-bar.on{display:flex}
.compress-bar .sm-btn{background:#fff}

/* 鈹€鈹€ Right panel 鈹€鈹€ */
#panel{width:272px;min-width:272px;background:var(--white);border-left:1px solid var(--border);
  display:flex;flex-direction:column;overflow-y:auto;padding:18px 14px;gap:20px}
#panel::-webkit-scrollbar{width:4px}
#panel::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

.ps-title{font-size:13.5px;font-weight:700;color:var(--text);
  display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.ps-more{font-size:12px;color:var(--p);cursor:pointer;font-weight:400}

/* Stats */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.stat{background:var(--bg);border-radius:10px;padding:12px 6px;text-align:center}
.stat-icon{font-size:18px;margin-bottom:4px}
.stat-n{font-size:20px;font-weight:800;color:var(--text)}
.stat-l{font-size:10.5px;color:var(--muted)}

/* Paper card in right panel */
.rp-card{display:flex;gap:9px;padding:9px 10px;border:1px solid var(--border);
  border-radius:10px;cursor:pointer;transition:all .15s;margin-bottom:8px}
.rp-card:hover{border-color:var(--p);background:var(--ps)}
.rp-thumb{width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,#dfe6e9,#b2bec3);
  flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:18px}
.rp-info{flex:1;min-width:0}
.rp-title{font-size:12px;font-weight:600;color:var(--text);line-height:1.4;margin-bottom:3px;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.rp-meta{font-size:11px;color:var(--muted)}
.rp-dl{font-size:11px;padding:2px 8px;border-radius:6px;background:var(--p);color:#fff;
  border:none;cursor:pointer;margin-top:4px;transition:background .15s}
.rp-dl:hover{background:var(--p2)}
#found-list{max-height:520px;overflow-y:auto;padding-right:2px}

/* Downloaded item */
.dl-item{display:flex;align-items:center;gap:8px;padding:8px 10px;
  border-radius:8px;background:var(--bg);margin-bottom:6px}
.dl-title{flex:1;font-size:12px;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.dl-acts{display:flex;gap:4px;flex-shrink:0}
.sm-btn{font-size:11px;padding:2px 7px;border-radius:6px;border:1px solid var(--border);
  background:var(--white);cursor:pointer;color:var(--muted);white-space:nowrap;transition:all .15s}
.sm-btn:hover{border-color:var(--p);color:var(--p)}
.sm-btn.pri{background:var(--p);color:#fff;border-color:var(--p)}
.sm-btn.pri:hover{background:var(--p2)}

/* Tools */
.tools{display:grid;grid-template-columns:repeat(3,1fr);gap:8px}
.tool{display:flex;flex-direction:column;align-items:center;gap:5px;padding:12px 6px;
  border-radius:10px;background:var(--bg);border:1px solid transparent;
  cursor:pointer;font-size:11px;color:var(--muted);transition:all .15s;font-family:inherit}
.tool:hover{border-color:var(--p);background:var(--ps);color:var(--p)}
.tool-i{font-size:20px}
.tool-modal-overlay{position:fixed;inset:0;background:rgba(15,23,42,.28);display:none;align-items:center;justify-content:center;z-index:80;padding:18px}
.tool-modal-overlay.on{display:flex}
.tool-modal{width:min(460px,100%);max-height:min(680px,90vh);overflow:hidden;background:#fff;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 24px 70px rgba(15,23,42,.22);display:flex;flex-direction:column}
.tool-modal-head{height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid #e2e8f0;background:#f8fafc}
.tool-modal-title{font-size:15px;font-weight:900;color:#0f172a}
.tool-modal-sub{font-size:11px;color:#64748b;margin-top:2px}
.tool-modal-close{width:30px;height:30px;border:1px solid #d8e0eb;border-radius:8px;background:#fff;color:#64748b;cursor:pointer;font-size:18px;line-height:1}
.tool-modal-close:hover{border-color:#0f172a;color:#0f172a}
.tool-modal-body{padding:16px;overflow:auto}
.tool-input,.tool-textarea{width:100%;border:1px solid #d8e0eb;border-radius:10px;background:#fff;color:#0f172a;font-family:inherit;font-size:13px;outline:none;box-sizing:border-box}
.tool-input{height:40px;padding:0 12px}
.tool-textarea{min-height:150px;padding:10px 12px;resize:vertical;line-height:1.55}
.tool-input:focus,.tool-textarea:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(108,92,231,.09)}
.tool-row{display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap}
.tool-result{margin-top:12px;border:1px solid #e2e8f0;border-radius:10px;background:#f8fafc;padding:12px;color:#0f172a;font-size:13px;line-height:1.6;word-break:break-word}
.tool-result strong{font-size:18px;font-variant-numeric:tabular-nums}
.calendar-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.calendar-title{font-weight:900;color:#0f172a}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
.calendar-cell{height:38px;border:1px solid #e2e8f0;border-radius:8px;background:#fff;color:#334155;font-size:12px;display:flex;align-items:center;justify-content:center}
.calendar-cell.head{height:24px;border:none;background:transparent;color:#64748b;font-weight:800}
.calendar-cell.muted{color:#cbd5e1;background:#f8fafc}
.calendar-cell.today{border-color:var(--p);background:var(--ps);color:var(--p);font-weight:900}
.calendar-cell.restday:not(.muted){background:#fff7ed;border-color:#fed7aa;color:#c2410c}
.calendar-cell.workday:not(.muted){background:#f8fafc}
.calendar-cell .calendar-day{font-weight:800}
.calendar-cell .calendar-tag{font-size:10px;opacity:.78;margin-left:2px}
.calendar-legend{display:flex;gap:8px;align-items:center;margin-top:10px;color:#64748b;font-size:11px}
.calendar-legend span{display:inline-flex;align-items:center;gap:4px}
.calendar-legend i{width:10px;height:10px;border-radius:3px;display:inline-block;border:1px solid #e2e8f0;background:#f8fafc}
.calendar-legend .rest i{background:#fff7ed;border-color:#fed7aa}
.calendar-note{margin-top:8px;color:#94a3b8;font-size:11px;line-height:1.5}
.datetime-clock{font-size:30px;font-weight:900;color:#0f172a;font-variant-numeric:tabular-nums;line-height:1.1}
.datetime-date{font-size:14px;color:#475569;margin-top:8px}
.tool-stat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px}
.tool-stat{border:1px solid #e2e8f0;border-radius:10px;background:#f8fafc;padding:10px;text-align:center}
.tool-stat strong{display:block;color:#0f172a;font-size:18px;font-variant-numeric:tabular-nums}
.tool-stat span{font-size:11px;color:#64748b}

/* Quote */
.quote-card{background:linear-gradient(135deg,var(--ps),#ede9fe);border-radius:12px;padding:14px}
.quote-text{font-size:12.5px;color:var(--text);font-style:italic;line-height:1.65;margin-bottom:8px}
.quote-by{font-size:11px;color:var(--muted)}

/* Library tabs */
.lib-tab{font-size:12px;padding:3px 10px;border-radius:12px;border:1.5px solid var(--border);
  background:var(--white);color:var(--muted);cursor:pointer;white-space:nowrap;
  transition:all .12s;font-family:inherit}
.lib-tab:hover{border-color:var(--p);color:var(--p)}
.lib-tab.active{background:var(--p);color:#fff;border-color:var(--p)}
.lib-tab-del{font-size:10px;margin-left:4px;opacity:.6}
.lib-tab-del:hover{opacity:1}

.lib-doc-item{display:flex;align-items:center;gap:6px;padding:6px 8px;
  border-radius:8px;background:var(--bg);margin-bottom:4px;font-size:12px}
.lib-doc-title{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text)}
.lib-doc-del{flex-shrink:0;width:18px;height:18px;border-radius:4px;border:none;
  background:transparent;font-size:11px;color:var(--light);cursor:pointer;padding:0}
.lib-doc-del:hover{background:#fee2e2;color:#ef4444}

/* Empty */
.empty-tip{font-size:12px;color:var(--light);padding:6px 2px;font-style:italic}

/* Toast */
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);
  background:#1e1f2e;color:#fff;padding:10px 22px;border-radius:20px;
  font-size:13px;z-index:999;animation:fadeup .2s ease}

/* Scrollbar global */
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

@media(max-width:1100px){#panel{display:none}}
@media(max-width:760px){#nav{display:none}#messages{padding:16px}}

/* Library manager refined surface */
#library-view{
  padding:24px 30px 28px;
  background:
    radial-gradient(circle at 18% 0%,rgba(14,165,233,.08),transparent 28%),
    radial-gradient(circle at 100% 8%,rgba(20,184,166,.08),transparent 30%),
    linear-gradient(180deg,#f7f9fc 0%,#eef2f7 100%);
}
#library-view .page-head{
  align-items:center;
  margin-bottom:16px;
  padding:2px 2px 0;
}
#library-view .page-kicker{
  color:#475569;
  font-size:11px;
  font-weight:800;
  letter-spacing:.09em;
  text-transform:uppercase;
}
#library-view .page-title{
  color:#0f172a;
  font-size:26px;
  letter-spacing:0;
}
#library-view .page-sub{
  max-width:720px;
  color:#64748b;
}
#library-view .sm-btn{
  min-height:31px;
  padding:5px 12px;
  border-radius:8px;
  border:1px solid #d8e0eb;
  background:#fff;
  color:#334155;
  font-size:12px;
  font-weight:800;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;
  box-shadow:0 1px 2px rgba(15,23,42,.04);
}
#library-view .sm-btn:hover{
  border-color:#0f172a;
  color:#0f172a;
  background:#f8fafc;
  transform:translateY(-1px);
}
#library-view .sm-btn.pri{
  background:#0f172a;
  border-color:#0f172a;
  color:#fff;
  box-shadow:0 10px 22px rgba(15,23,42,.16);
}
#library-view .sm-btn.pri:hover{
  background:#020617;
  border-color:#020617;
  color:#fff;
}
#library-view .paper-toolbar{
  margin-bottom:14px;
  padding:12px;
  border:1px solid rgba(148,163,184,.24);
  border-radius:12px;
  background:rgba(255,255,255,.86);
  box-shadow:0 10px 30px rgba(15,23,42,.05);
}
#library-view .paper-search{
  height:38px;
  min-width:260px;
  border:1px solid #d8e0eb;
  border-radius:9px;
  background:#fff;
  color:#0f172a;
  box-shadow:0 1px 2px rgba(15,23,42,.03);
}
#library-view .paper-search::placeholder{
  color:#94a3b8;
}
#library-view .paper-search:focus{
  border-color:#0f172a;
  box-shadow:0 0 0 3px rgba(15,23,42,.08);
}
#library-view .paper-table-wrap{
  border:1px solid rgba(148,163,184,.28);
  border-radius:12px;
  background:rgba(255,255,255,.94);
  box-shadow:0 18px 45px rgba(15,23,42,.07);
}
#library-view .paper-table{
  min-width:860px;
  border-collapse:separate;
  border-spacing:0;
}
#library-view .paper-table th{
  top:0;
  z-index:2;
  padding:12px 14px;
  background:linear-gradient(180deg,#fff 0%,#f8fafc 100%);
  color:#64748b;
  border-bottom:1px solid #e2e8f0;
  font-size:11px;
  font-weight:900;
  letter-spacing:.05em;
  text-transform:uppercase;
}
#library-view .paper-table td{
  padding:13px 14px;
  border-bottom:1px solid #eef2f7;
  color:#334155;
}
#library-view .paper-table tbody tr{
  transition:background .12s,box-shadow .12s,transform .12s;
}
#library-view .paper-table tbody tr:hover{
  background:#f8fbff;
  box-shadow:inset 3px 0 0 #0ea5e9;
}
#library-view .paper-table tbody tr:last-child td{
  border-bottom:none;
}
#library-view .paper-name{
  max-width:430px;
  color:#0f172a;
  font-size:13.5px;
  font-weight:800;
  letter-spacing:0;
}
#library-view .paper-meta{
  color:#64748b;
  font-size:12px;
  line-height:1.45;
}
#library-view .chip{
  background:#ecfeff;
  color:#0e7490;
  border:1px solid #a5f3fc;
  font-weight:800;
  padding:2px 9px;
}
#library-view .paper-actions{
  gap:7px;
}
#library-view .paper-empty{
  padding:56px 24px;
  color:#94a3b8;
}
#library-view .paper-empty::before{
  content:"";
  display:block;
  width:42px;
  height:42px;
  margin:0 auto 12px;
  border-radius:10px;
  background:
    linear-gradient(135deg,#e0f2fe,#ccfbf1);
  box-shadow:inset 0 0 0 1px rgba(14,165,233,.18);
}
@media(max-width:760px){
  #library-view{
    padding:16px;
  }
  #library-view .page-head{
    align-items:flex-start;
    flex-direction:column;
  }
  #library-view .paper-toolbar{
    align-items:stretch;
  }
  #library-view .paper-search,
  #library-view .paper-toolbar .sm-btn{
    width:100%;
    min-width:0;
  }
}

/* Library manager v2 */
#library-view{
  padding:22px 28px 26px;
  gap:12px;
  background:linear-gradient(180deg,#f8fafc 0%,#eef3f8 100%);
}
#library-view .page-head{
  min-height:54px;
  margin-bottom:4px;
  padding:0;
}
#library-view .page-title{
  font-size:25px;
  line-height:1.15;
}
#library-view .page-sub{
  margin-top:7px;
  font-size:13px;
  line-height:1.45;
}
.paper-stats{
  display:grid;
  grid-template-columns:repeat(4,minmax(0,1fr));
  gap:10px;
  margin-bottom:2px;
}
.paper-stat{
  min-width:0;
  min-height:68px;
  border:1px solid #dbe4ee;
  border-radius:10px;
  background:#fff;
  padding:11px 13px;
  box-shadow:0 8px 22px rgba(15,23,42,.045);
  position:relative;
  overflow:hidden;
}
.paper-stat::before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  bottom:0;
  width:4px;
  background:#2563eb;
}
.paper-stat:nth-child(2)::before{background:#0f766e}
.paper-stat:nth-child(3)::before{background:#7c3aed}
.paper-stat.warn::before{background:#d97706}
.paper-stat-label{
  display:block;
  color:#64748b;
  font-size:12px;
  font-weight:800;
  margin-bottom:7px;
}
.paper-stat strong{
  display:block;
  color:#0f172a;
  font-size:23px;
  line-height:1;
  font-weight:900;
  font-variant-numeric:tabular-nums;
}
#library-view .paper-toolbar{
  display:grid;
  grid-template-columns:minmax(260px,1fr) 150px;
  align-items:start;
  gap:10px;
  margin-bottom:0;
  padding:10px;
  border-radius:10px;
}
#library-view .paper-search{
  height:36px;
  min-width:0;
  font-size:13px;
}
#paper-lib-tabs{
  grid-column:1 / -1;
  display:flex;
  flex-wrap:wrap;
  gap:6px;
  max-height:72px;
  overflow:auto;
  padding-top:2px;
}
#library-view .lib-tab{
  min-height:27px;
  padding:4px 10px;
  border-radius:999px;
  border:1px solid #dbe4ee;
  background:#fff;
  color:#475569;
  font-size:12px;
  font-weight:800;
}
#library-view .lib-tab:hover{
  border-color:#2563eb;
  color:#1d4ed8;
  background:#eff6ff;
}
#library-view .lib-tab.active{
  border-color:#0f172a;
  background:#0f172a;
  color:#fff;
}
#library-view .paper-table-wrap{
  border-radius:10px;
  flex:1;
  min-height:0;
  overflow:auto;
}
#library-view .paper-table{
  table-layout:fixed;
  min-width:760px;
}
#library-view .paper-table th{
  padding:10px 14px;
  font-size:11px;
}
#library-view .paper-table td{
  padding:11px 14px;
  font-size:13px;
}
#library-view .paper-table th:nth-child(1),
#library-view .paper-table td:nth-child(1){
  width:38%;
}
#library-view .paper-table th:nth-child(2),
#library-view .paper-table td:nth-child(2){
  width:16%;
}
#library-view .paper-table th:nth-child(3),
#library-view .paper-table td:nth-child(3){
  width:15%;
}
#library-view .paper-table th:nth-child(4),
#library-view .paper-table td:nth-child(4),
#library-view .paper-table th:nth-child(5),
#library-view .paper-table td:nth-child(5){
  width:8%;
  text-align:center;
  white-space:nowrap;
}
#library-view .paper-table th:last-child,
#library-view .paper-table td:last-child{
  text-align:right;
  white-space:nowrap;
  width:74px;
  padding-left:8px;
  padding-right:8px;
}
#library-view .paper-name{
  max-width:100%;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
#library-view .chip{
  display:inline-flex;
  max-width:170px;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  vertical-align:middle;
}
#library-view .paper-actions{
  display:inline-flex;
  flex-direction:column;
  justify-content:flex-end;
  align-items:center;
  gap:5px;
  width:62px;
}
#library-view .paper-actions .sm-btn{
  width:62px;
  min-width:0;
  min-height:28px;
  padding:4px 0;
  font-size:12px;
}
#library-view .paper-empty{
  padding:42px 20px;
}
@media(max-width:1100px){
  .paper-stats{grid-template-columns:repeat(2,minmax(0,1fr))}
}
@media(max-width:760px){
  #library-view{
    padding:14px;
  }
  .paper-stats{
    grid-template-columns:1fr 1fr;
  }
  #library-view .paper-toolbar{
    grid-template-columns:1fr;
  }
  #paper-lib-tabs{
    max-height:96px;
  }
}

/* Writing assistant workspace */
#writing-view{flex:1;display:none;flex-direction:column;overflow:hidden;padding:24px 30px 28px;background:
  radial-gradient(circle at 14% 0%,rgba(45,212,191,.10),transparent 28%),
  radial-gradient(circle at 94% 4%,rgba(15,23,42,.08),transparent 30%),
  linear-gradient(180deg,#f8fafc 0%,#eef3f8 100%)}
#writing-view.on{display:flex}
#writing-view .page-head{align-items:center;margin-bottom:16px;padding:2px 2px 0}
#writing-view .page-kicker{color:#475569;font-size:11px;font-weight:900;letter-spacing:.09em;text-transform:uppercase}
#writing-view .page-title{font-size:26px;color:#0f172a;letter-spacing:0}
#writing-view .page-sub{max-width:760px;color:#64748b}
.write-workbench{flex:1;min-height:0;display:grid;grid-template-columns:300px minmax(0,1fr) 310px;gap:14px}
.write-pane{min-height:0;background:rgba(255,255,255,.94);border:1px solid rgba(148,163,184,.28);
  border-radius:12px;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 18px 45px rgba(15,23,42,.07)}
.write-pane-head{height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;
  border-bottom:1px solid #e2e8f0;background:linear-gradient(180deg,#fff 0%,#f8fafc 100%)}
.write-pane-title{font-size:13px;font-weight:900;color:#0f172a;letter-spacing:.01em}
.write-body{flex:1;min-height:0;overflow:auto;padding:16px}
.write-field{margin-bottom:14px}.write-label{font-size:11px;font-weight:900;color:#64748b;margin-bottom:7px;text-transform:uppercase;letter-spacing:.05em}
.write-input,.write-select,.write-textarea{width:100%;border:1px solid #d8e0eb;border-radius:9px;background:#fff;
  font-family:inherit;font-size:13px;color:#0f172a;outline:none;transition:border-color .15s,box-shadow .15s,background .15s}
.write-input,.write-select{height:38px;padding:0 11px}.write-textarea{min-height:120px;resize:vertical;padding:12px 13px;line-height:1.62}
.write-textarea.large{min-height:330px;flex:1;resize:none;font-size:14px;line-height:1.75}
.write-input:focus,.write-select:focus,.write-textarea:focus{border-color:#0f172a;box-shadow:0 0 0 3px rgba(15,23,42,.08)}
.write-input::placeholder,.write-textarea::placeholder{color:#94a3b8}
.write-seg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}.write-seg.three{grid-template-columns:repeat(3,1fr)}
.write-chip-btn{height:34px;border:1px solid #d8e0eb;border-radius:8px;background:#fff;color:#334155;
  font-size:12px;font-weight:800;cursor:pointer;transition:all .12s;font-family:inherit}
.write-chip-btn:hover{border-color:#0f172a;color:#0f172a;background:#f8fafc}
.write-chip-btn.active{background:#0f172a;border-color:#0f172a;color:#fff;box-shadow:0 10px 22px rgba(15,23,42,.14)}
.write-main{display:flex;flex-direction:column}.write-main .write-body{display:flex;flex-direction:column;gap:12px}
.write-paper{flex:1;min-height:0;display:flex;flex-direction:column;border:1px solid #e2e8f0;border-radius:11px;overflow:hidden;background:#fff}
.write-paper-top{height:42px;display:flex;align-items:center;gap:8px;padding:0 12px;border-bottom:1px solid #e2e8f0;background:#f8fafc;color:#64748b;font-size:12px}
.write-dot{width:8px;height:8px;border-radius:50%;background:#14b8a6;box-shadow:0 0 0 4px rgba(20,184,166,.12)}
.write-paper .write-textarea{border:0;border-radius:0;box-shadow:none;background:
  linear-gradient(#fff 31px,#f1f5f9 32px);background-size:100% 32px}
.write-actions{display:flex;align-items:center;gap:9px;padding:12px 16px;border-top:1px solid #e2e8f0;background:#f8fafc;flex-wrap:wrap}
.write-primary,.write-secondary{height:34px;border-radius:8px;padding:0 13px;font-size:12px;font-weight:900;cursor:pointer;font-family:inherit;transition:all .12s}
.write-primary{border:1px solid #0f172a;background:#0f172a;color:#fff;box-shadow:0 10px 22px rgba(15,23,42,.14)}
.write-primary:hover{background:#020617;transform:translateY(-1px)}
.write-secondary{border:1px solid #d8e0eb;background:#fff;color:#334155}.write-secondary:hover{border-color:#0f172a;color:#0f172a}
.write-hint{margin-left:auto;color:#64748b;font-size:12px}
.write-template{border:1px solid #e2e8f0;border-radius:10px;background:#fff;padding:11px;margin-bottom:9px;cursor:pointer;transition:all .12s}
.write-template:hover{border-color:#0f172a;box-shadow:0 10px 22px rgba(15,23,42,.07);transform:translateY(-1px)}
.write-template-title{font-size:13px;font-weight:900;color:#0f172a;margin-bottom:4px}
.write-template-desc{font-size:12px;color:#64748b;line-height:1.5}
.write-rule{display:flex;gap:10px;padding:11px;border-radius:10px;background:#f8fafc;border:1px solid #e2e8f0;margin-bottom:9px}
.write-rule-mark{width:26px;height:26px;border-radius:7px;background:#ccfbf1;color:#0f766e;font-size:12px;font-weight:900;display:flex;align-items:center;justify-content:center;flex:0 0 auto}
.write-rule-text{font-size:12px;color:#475569;line-height:1.5}.write-rule-text b{display:block;color:#0f172a;margin-bottom:2px}
.write-upload{border:1px dashed #aab7c6;border-radius:11px;background:#f8fafc;padding:13px;display:flex;align-items:center;gap:12px}
.write-upload-icon{width:38px;height:38px;border-radius:9px;background:#0f172a;color:#fff;display:flex;align-items:center;justify-content:center;font-size:17px;flex:0 0 auto}
.write-upload-title{font-size:13px;font-weight:900;color:#0f172a}
.write-upload-sub{font-size:12px;color:#64748b;margin-top:2px;line-height:1.45}
.write-upload-list{display:flex;flex-wrap:wrap;gap:7px}
.write-file-pill{display:inline-flex;align-items:center;gap:6px;max-width:260px;border:1px solid #d8e0eb;border-radius:999px;background:#fff;padding:5px 9px;font-size:12px;color:#334155}
.write-file-pill span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.write-file-pill.ok{border-color:#99f6e4;background:#ecfdf5;color:#0f766e}
.write-file-pill.err{border-color:#fecaca;background:#fef2f2;color:#991b1b}
.write-file-del{width:18px;height:18px;border:0;border-radius:50%;background:rgba(15,23,42,.08);color:inherit;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;font-size:13px;line-height:1;flex:0 0 auto}
.write-file-del:hover{background:#fee2e2;color:#991b1b}
.write-source-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
.write-source-card{min-height:58px;border:1px solid #d8e0eb;border-radius:10px;background:#fff;padding:9px 10px;text-align:left;cursor:pointer;font-family:inherit;transition:all .12s;color:#334155}
.write-source-card:hover{border-color:#0f172a;background:#f8fafc}
.write-source-card.active{border-color:#0f172a;background:#0f172a;color:#fff;box-shadow:0 10px 22px rgba(15,23,42,.14)}
.write-source-title{font-size:12px;font-weight:900;line-height:1.25}
.write-source-desc{font-size:11px;line-height:1.35;margin-top:4px;color:#64748b}
.write-source-card.active .write-source-desc{color:#cbd5e1}
@media(max-width:1180px){.write-workbench{grid-template-columns:280px 1fr}.write-side{display:none}}
@media(max-width:820px){#writing-view{padding:16px}.write-workbench{grid-template-columns:1fr}.write-pane{min-height:auto}.write-textarea.large{min-height:260px}.write-hint{width:100%;margin-left:0}}

/* Writing workspace spacious layout */
#writing-view .page-head{margin-bottom:18px}
.write-workbench{
  grid-template-columns:minmax(0,1fr) 330px;
  grid-template-rows:auto minmax(0,1fr);
  gap:16px;
}
.write-workbench>.write-pane:first-child{
  grid-column:1 / -1;
  min-height:auto;
  overflow:visible;
}
.write-workbench>.write-pane:first-child .write-pane-head{
  height:48px;
}
.write-workbench>.write-pane:first-child .write-body{
  display:grid;
  grid-template-columns:minmax(180px,1fr) minmax(160px,.8fr) minmax(240px,1.1fr) minmax(160px,.75fr) minmax(360px,1.35fr);
  gap:12px;
  overflow:visible;
  padding:14px 16px 16px;
}
.write-workbench>.write-pane:first-child .write-field{
  margin-bottom:0;
  min-width:0;
}
.write-workbench>.write-pane:first-child .write-select,
.write-workbench>.write-pane:first-child .write-input,
.write-workbench>.write-pane:first-child .write-seg{
  min-width:0;
}
.write-workbench>.write-pane:first-child .write-seg{
  gap:6px;
}
.write-workbench>.write-pane:first-child .write-chip-btn{
  height:38px;
}
.write-main{
  min-height:0;
}
.write-main .write-body{
  padding:18px;
}
.write-textarea.large{
  min-height:390px;
  font-size:14.5px;
}
.write-side .write-body{
  padding:14px;
}
.write-side .write-pane-head{
  background:#0f172a;
  border-bottom-color:#0f172a;
}
.write-side .write-pane-title{
  color:#fff;
}
.write-template{
  padding:13px;
  margin-bottom:10px;
}
.write-rule{
  padding:12px;
}
@media(max-width:1280px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}
@media(max-width:980px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:1fr;
  }
}
@media(max-width:1080px){
  .write-workbench{
    grid-template-columns:1fr;
    grid-template-rows:auto minmax(0,1fr) auto;
  }
  .write-side{
    display:flex;
    max-height:300px;
  }
  .write-side .write-body{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:10px;
  }
  .write-side .write-template,
  .write-side .write-rule{
    margin-bottom:0;
  }
}
@media(max-width:820px){
  .write-workbench{
    grid-template-columns:1fr;
    gap:12px;
  }
  .write-workbench>.write-pane:first-child .write-body,
  .write-side .write-body{
    grid-template-columns:1fr;
  }
  .write-side{
    max-height:none;
  }
}

/* Writing assistant v2, matched to compact card mockup */
#writing-view{
  padding:32px 34px 30px;
  background:linear-gradient(180deg,#f7f9ff 0%,#f2f5fb 100%);
}
#writing-view .page-head{
  align-items:flex-start;
  margin-bottom:28px;
}
#writing-view .page-kicker{
  display:none;
}
#writing-view .page-title{
  font-size:34px;
  font-weight:900;
  color:#0f172a;
  line-height:1.1;
}
#writing-view .page-title::after{
  content:"鉁?;
  color:#5b4ee6;
  font-size:25px;
  margin-left:12px;
  vertical-align:top;
}
#writing-view .page-sub{
  margin-top:12px;
  max-width:780px;
  color:#475569;
  font-size:15px;
}
#writing-view .page-head>.sm-btn.pri{
  height:54px;
  padding:0 28px;
  border-radius:10px;
  border-color:#5547e6;
  background:linear-gradient(135deg,#6f5cf4,#4438d5);
  box-shadow:0 16px 30px rgba(79,70,229,.24);
  font-size:14px;
}
#writing-view .page-head>.sm-btn.pri::before{
  content:"鉁?;
  margin-right:8px;
}
.write-workbench{
  grid-template-columns:minmax(0,1fr) 500px;
  grid-template-rows:auto minmax(0,1fr);
  gap:24px;
}
.write-pane{
  border:1px solid #dfe5ef;
  border-radius:16px;
  background:rgba(255,255,255,.94);
  box-shadow:0 18px 45px rgba(15,23,42,.07);
}
.write-pane-head{
  height:76px;
  padding:0 26px;
  border-bottom:1px solid #e3e8f2;
  background:rgba(255,255,255,.76);
}
.write-pane-title{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:20px;
  font-weight:900;
  color:#0f172a;
}
.write-pane-title::before{
  content:"鈿?;
  width:22px;
  height:22px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  color:#5648e8;
  font-size:18px;
}
.write-main .write-pane-title::before{
  content:"鉁?;
}
.write-side .write-pane-title::before{
  content:"鈯?;
}
.write-workbench>.write-pane:first-child{
  grid-column:1 / -1;
}
.write-workbench>.write-pane:first-child .write-pane-head{
  height:74px;
}
.write-workbench>.write-pane:first-child .write-body{
  grid-template-columns:minmax(200px,.95fr) minmax(180px,.82fr) minmax(300px,1.35fr) minmax(210px,.95fr) minmax(300px,1.15fr);
  gap:0;
  padding:24px 24px 26px;
}
.write-workbench>.write-pane:first-child .write-field{
  padding:0 22px;
  border-right:1px solid #e3e8f2;
}
.write-workbench>.write-pane:first-child .write-field:first-child{
  padding-left:0;
}
.write-workbench>.write-pane:first-child .write-field:last-child{
  padding-right:0;
  border-right:none;
}
.write-label{
  display:flex;
  align-items:center;
  gap:8px;
  margin-bottom:18px;
  font-size:15px;
  font-weight:900;
  letter-spacing:0;
  text-transform:none;
  color:#1e293b;
}
.write-label::before{
  content:"";
  width:23px;
  height:23px;
  border-radius:7px;
  background:#f0edff;
  box-shadow:inset 0 0 0 1px #ddd6fe;
}
.write-input,.write-select{
  height:46px;
  border-radius:9px;
  border-color:#dbe3ee;
  color:#334155;
  font-size:14px;
}
.write-chip-btn{
  height:46px;
  min-width:72px;
  border-radius:9px;
  color:#334155;
  background:#fff;
  font-size:14px;
}
.write-chip-btn.active{
  background:linear-gradient(135deg,#6656ec,#4438d5);
  border-color:#4f46e5;
  color:#fff;
  box-shadow:0 10px 22px rgba(79,70,229,.22);
}
.write-seg{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}
.write-seg.three{
  display:flex;
}
.write-source-grid{
  grid-template-columns:1fr;
  gap:12px;
}
.write-source-card{
  min-height:62px;
  border-radius:9px;
  text-align:center;
  padding:10px 12px;
}
.write-source-card[data-value="rewrite"]{
  display:none;
}
.write-source-title{
  font-size:14px;
}
.write-source-desc{
  font-size:12px;
}
.write-main .write-body{
  padding:24px;
  gap:18px;
}
.write-main{
  min-height:600px;
}
.write-paper{
  border-radius:10px;
}
.write-paper-top{
  display:none;
}
.write-textarea.large{
  min-height:235px;
  background:#fff;
  font-size:15px;
}
.write-main .write-input{
  height:48px;
}
.write-upload{
  min-height:98px;
  justify-content:center;
  border-color:#aeb4ff;
  background:#fbfbff;
  border-style:dashed;
  text-align:center;
}
.write-upload-icon{
  display:none;
}
.write-upload-title{
  color:#4f46e5;
}
.write-upload-title::before{
  content:"鈬?";
}
.write-upload-sub{
  color:#64748b;
}
.write-actions{
  padding:20px 24px 24px;
  background:#fff;
  border-top:0;
}
.write-primary{
  height:48px;
  padding:0 22px;
  background:linear-gradient(135deg,#5d4df0,#4338ca);
  border-color:#4338ca;
  border-radius:9px;
  box-shadow:0 14px 26px rgba(79,70,229,.24);
  font-size:14px;
}
.write-secondary{
  height:48px;
  padding:0 18px;
  border-radius:9px;
  background:#fff;
  font-size:14px;
  color:#4f46e5;
}
.write-hint{
  width:100%;
  margin-left:0;
  text-align:center;
  font-size:13px;
}
.write-side .write-pane-head{
  background:#fff;
  border-bottom:0;
}
.write-side .write-pane-title{
  color:#0f172a;
}
.write-side .write-body{
  padding:0 22px 22px;
}
.write-template{
  display:grid;
  grid-template-columns:58px 1fr;
  column-gap:16px;
  align-items:center;
  min-height:94px;
  padding:16px 18px;
  border-radius:13px;
  margin-bottom:12px;
}
.write-template::before{
  content:"";
  width:48px;
  height:48px;
  border-radius:12px;
  grid-row:1 / span 2;
  background:linear-gradient(135deg,#ede9fe,#ddd6fe);
}
.write-template:nth-of-type(2)::before{
  background:linear-gradient(135deg,#dbeafe,#bfdbfe);
}
.write-template:nth-of-type(3)::before{
  background:linear-gradient(135deg,#d1fae5,#a7f3d0);
}
.write-template-title{
  font-size:16px;
  margin-bottom:4px;
}
.write-template-desc{
  font-size:13px;
}
.write-rule{
  min-height:88px;
  align-items:center;
  border-radius:13px;
  background:#fff;
  padding:16px 18px;
}
.write-rule-mark{
  width:48px;
  height:48px;
  border-radius:12px;
  font-size:15px;
}
.write-rule-text{
  font-size:13px;
}
.write-rule-text b{
  font-size:16px;
}
@media(max-width:1320px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:18px;
  }
  .write-workbench>.write-pane:first-child .write-field{
    padding:0;
    border-right:none;
  }
}
@media(max-width:1080px){
  .write-workbench{
    grid-template-columns:1fr;
  }
  .write-side{
    max-height:none;
  }
}
@media(max-width:760px){
  #writing-view{
    padding:20px 16px;
  }
  #writing-view .page-head{
    flex-direction:column;
  }
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:1fr;
  }
}

/* Writing v2 density adjustment */
#writing-view{
  padding-top:24px;
}
#writing-view .page-head{
  margin-bottom:18px;
}
#writing-view .page-title{
  font-size:30px;
}
#writing-view .page-sub{
  margin-top:8px;
  font-size:14px;
}
#writing-view .page-head>.sm-btn.pri{
  height:46px;
  padding:0 22px;
}
.write-workbench{
  gap:18px;
}
.write-workbench>.write-pane:first-child .write-pane-head{
  height:52px;
}
.write-workbench>.write-pane:first-child .write-body{
  padding:14px 18px 16px;
  align-items:start;
}
.write-workbench>.write-pane:first-child .write-field{
  padding:0 16px;
}
.write-workbench>.write-pane:first-child .write-field:first-child{
  padding-left:0;
}
.write-workbench>.write-pane:first-child .write-field:last-child{
  padding-right:0;
}
.write-workbench>.write-pane:first-child .write-label{
  margin-bottom:10px;
  font-size:13px;
}
.write-workbench>.write-pane:first-child .write-label::before{
  width:18px;
  height:18px;
  border-radius:6px;
}
.write-workbench>.write-pane:first-child .write-select,
.write-workbench>.write-pane:first-child .write-chip-btn{
  height:36px;
  font-size:13px;
}
.write-workbench>.write-pane:first-child .write-seg{
  gap:7px;
}
.write-workbench>.write-pane:first-child .write-source-grid{
  grid-template-columns:1fr;
  gap:6px;
  width:100%;
  max-width:124px;
  justify-self:start;
}
.write-workbench>.write-pane:first-child .write-source-card{
  min-height:40px;
  padding:7px 10px;
}
.write-workbench>.write-pane:first-child .write-source-title{
  font-size:13px;
}
.write-workbench>.write-pane:first-child .write-source-desc{
  display:none;
}
.write-main{
  min-height:0;
}
.write-main .write-body{
  padding:20px 24px 14px;
}
.write-textarea.large{
  min-height:310px;
}
.write-upload{
  min-height:82px;
}
.write-actions{
  padding:14px 24px 18px;
}
.write-side .write-body{
  padding-bottom:18px;
}
.write-template{
  min-height:78px;
  padding:13px 16px;
}
.write-rule{
  min-height:74px;
  padding:13px 16px;
}

/* Writing ultra-compact top area */
#writing-view{
  padding-top:18px;
}
#writing-view .page-head{
  margin-bottom:12px;
  align-items:center;
}
#writing-view .page-title{
  font-size:26px;
}
#writing-view .page-title::after{
  font-size:19px;
  margin-left:8px;
}
#writing-view .page-sub{
  margin-top:5px;
  font-size:13px;
  line-height:1.35;
}
#writing-view .page-head>.sm-btn.pri{
  height:40px;
  padding:0 18px;
  font-size:13px;
}
.write-workbench{
  grid-template-rows:auto minmax(0,1fr);
  gap:14px;
}
.write-workbench>.write-pane:first-child{
  border-radius:13px;
}
.write-workbench>.write-pane:first-child .write-pane-head{
  height:0;
  min-height:0;
  padding:0;
  border:0;
  overflow:hidden;
}
.write-workbench>.write-pane:first-child .write-body{
  padding:12px 16px;
  grid-template-columns:minmax(170px,.95fr) minmax(150px,.75fr) minmax(230px,1.05fr) minmax(150px,.7fr) minmax(118px,126px);
}
.write-workbench>.write-pane:first-child .write-field{
  padding:0 12px;
}
.write-workbench>.write-pane:first-child .write-field:last-child{
  padding-left:6px;
  padding-right:0;
}
.write-workbench>.write-pane:first-child .write-label{
  margin-bottom:7px;
  font-size:12px;
  gap:6px;
}
.write-workbench>.write-pane:first-child .write-label::before{
  width:15px;
  height:15px;
  border-radius:5px;
}
.write-workbench>.write-pane:first-child .write-select,
.write-workbench>.write-pane:first-child .write-chip-btn{
  height:32px;
  border-radius:8px;
  font-size:12px;
}
.write-workbench>.write-pane:first-child .write-chip-btn{
  min-width:58px;
  padding:0 10px;
}
.write-workbench>.write-pane:first-child .write-seg{
  gap:6px;
}
.write-workbench>.write-pane:first-child .write-source-card{
  box-sizing:border-box;
  min-height:30px;
  padding:4px 6px;
  border-radius:8px;
  width:100%;
  max-width:124px;
  overflow:hidden;
}
.write-workbench>.write-pane:first-child .write-source-title{
  font-size:11.5px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.write-main .write-pane-head,
.write-side .write-pane-head{
  height:60px;
}
.write-main{
  min-height:620px;
}
.write-textarea.large{
  min-height:360px;
}
@media(max-width:1320px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:repeat(3,minmax(0,1fr));
  }
}
@media(max-width:980px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:repeat(2,minmax(0,1fr));
  }
}
@media(max-width:760px){
  .write-workbench>.write-pane:first-child .write-body{
    grid-template-columns:1fr;
  }
}
/* Writing action/button overflow fix */
#writing-view{
  overflow:auto;
  min-height:0;
}
.write-workbench{
  min-height:0;
}
.write-main{
  min-height:min(620px,calc(100vh - 230px));
}
.write-main .write-body{
  min-height:0;
}
.write-actions{
  flex-shrink:0;
}
#writing-view .page-head{
  flex-wrap:wrap;
}
#writing-view .page-head > div{
  min-width:0;
}
#writing-view .page-head > .sm-btn.pri{
  max-width:100%;
}
.write-actions{
  flex-wrap:wrap;
}
.write-actions > .write-primary,
.write-actions > .write-secondary{
  max-width:100%;
  min-width:0;
  white-space:normal;
}
@media(max-width:720px){
  #writing-view{
    padding:14px 14px 18px;
  }
  .write-main{
    min-height:0;
  }
  .write-textarea.large{
    min-height:220px;
  }
  .write-upload{
    align-items:stretch;
    flex-direction:column;
  }
  .write-upload .write-secondary{
    width:100%;
  }
  .write-actions > .write-primary,
  .write-actions > .write-secondary{
    flex:1 1 100%;
  }
}
/* Floating wooden fish */
#woodfish-widget{
  position:fixed;
  right:26px;
  bottom:96px;
  z-index:1200;
  width:88px;
  height:72px;
  border:0;
  border-radius:999px;
  background:transparent;
  box-shadow:none;
  cursor:grab;
  touch-action:none;
  user-select:none;
  display:flex;
  align-items:center;
  justify-content:center;
  transition:transform .12s ease;
}
#woodfish-widget:hover{
  transform:translateY(-2px);
}
#woodfish-widget.dragging{
  cursor:grabbing;
  transition:none;
}
#woodfish-widget.dragging:hover{
  transform:none;
}
#woodfish-widget.knock{
  animation:woodfishKnock .22s ease;
}
#woodfish-widget::before{
  content:"";
  position:absolute;
  left:17px;
  right:13px;
  bottom:7px;
  height:12px;
  border-radius:50%;
  background:rgba(55,30,14,.24);
  filter:blur(5px);
}
.woodfish-body{
  position:absolute;
  left:12px;
  bottom:14px;
  width:64px;
  height:44px;
  border-radius:49% 51% 48% 52% / 56% 54% 46% 44%;
  background:
    radial-gradient(ellipse at 31% 24%,rgba(255,221,155,.55) 0 8px,transparent 9px),
    radial-gradient(ellipse at 72% 41%,rgba(255,214,145,.38) 0 11px,transparent 12px),
    linear-gradient(150deg,#d19044 0%,#ad6429 42%,#743815 74%,#4b220d 100%);
  box-shadow:0 13px 18px rgba(58,29,12,.24),inset 8px 7px 9px rgba(255,226,168,.25),inset -13px -11px 18px rgba(48,22,8,.36);
  transform:rotate(-2deg);
}
.woodfish-body::before{
  content:"";
  position:absolute;
  left:8px;
  top:13px;
  width:32px;
  height:15px;
  border-radius:50%;
  border-top:5px solid rgba(64,31,14,.48);
  transform:rotate(-10deg);
}
.woodfish-body::after{
  content:"";
  position:absolute;
  right:6px;
  top:15px;
  width:19px;
  height:13px;
  border-radius:55% 45% 52% 48%;
  background:radial-gradient(ellipse at 36% 36%,#2b1308 0 42%,#120704 75%);
  box-shadow:inset 2px 2px 4px rgba(0,0,0,.55),0 0 0 4px rgba(255,213,141,.12);
}
.woodfish-stick{
  position:absolute;
  right:8px;
  top:4px;
  width:42px;
  height:7px;
  border-radius:999px;
  background:
    linear-gradient(180deg,rgba(255,242,202,.7) 0 22%,transparent 24%),
    repeating-linear-gradient(90deg,rgba(96,47,17,.18) 0 2px,transparent 2px 8px),
    linear-gradient(90deg,#f5d08b 0%,#c47a34 48%,#7a3d18 100%);
  transform:rotate(-32deg);
  transform-origin:right center;
  box-shadow:0 2px 5px rgba(44,22,10,.24),inset 0 -1px 2px rgba(77,35,12,.24);
}
.woodfish-stick::before{
  content:"";
  position:absolute;
  left:-9px;
  top:-5px;
  width:17px;
  height:17px;
  border-radius:50%;
  background:
    radial-gradient(circle at 33% 30%,#ffe2a4 0 18%,#d58b3d 42%,#8a461b 72%,#55270f 100%);
  box-shadow:0 2px 5px rgba(44,22,10,.25),inset -2px -2px 4px rgba(62,28,10,.3);
}
.woodfish-stick::after{
  content:"";
  position:absolute;
  right:1px;
  top:1px;
  width:10px;
  height:5px;
  border-radius:999px;
  background:rgba(255,230,177,.35);
}
#woodfish-widget.knock .woodfish-stick{
  animation:woodfishStick .22s ease;
}
.woodfish-ripple{
  position:absolute;
  left:22px;
  bottom:13px;
  width:58px;
  height:42px;
  border-radius:50%;
  border:2px solid rgba(139,82,34,.28);
  opacity:0;
  transform:scale(.88);
  pointer-events:none;
}
#woodfish-widget.knock .woodfish-ripple{
  animation:woodfishRipple .42s ease-out;
}
.woodfish-merit{
  position:absolute;
  left:50%;
  top:-10px;
  padding:4px 9px;
  border-radius:999px;
  background:rgba(255,255,255,.92);
  border:1px solid rgba(185,120,55,.28);
  box-shadow:0 8px 18px rgba(80,42,16,.18);
  color:#7b421c;
  font-size:13px;
  font-weight:900;
  line-height:1.2;
  white-space:nowrap;
  pointer-events:none;
  opacity:0;
  transform:translate(-50%,0) scale(.92);
  animation:woodfishMerit .86s ease-out forwards;
}
@keyframes woodfishKnock{
  0%{transform:scale(1)}
  40%{transform:scale(.94) rotate(-2deg)}
  100%{transform:scale(1)}
}
@keyframes woodfishStick{
  0%{transform:rotate(-32deg)}
  45%{transform:rotate(-57deg) translate(-4px,6px)}
  100%{transform:rotate(-32deg)}
}
@keyframes woodfishRipple{
  0%{opacity:.9;transform:scale(.85)}
  100%{opacity:0;transform:scale(1.28)}
}
@keyframes woodfishMerit{
  0%{opacity:0;transform:translate(-50%,6px) scale(.88)}
  18%{opacity:1;transform:translate(-50%,-4px) scale(1)}
  100%{opacity:0;transform:translate(-50%,-44px) scale(.96)}
}
@media(max-width:720px){
  #woodfish-widget{
    width:78px;
    height:64px;
    right:14px;
    bottom:82px;
  }
  .woodfish-body{transform:scale(.9) rotate(-2deg);transform-origin:left bottom}
  .woodfish-stick{transform:scale(.9) rotate(-32deg);transform-origin:right center}
}
</style>
</head>
<body>
<div id="app">

<button id="woodfish-widget" type="button" title="Wooden fish: click to knock, drag to move" aria-label="Wooden fish">
  <span class="woodfish-ripple"></span>
  <span class="woodfish-stick"></span>
  <span class="woodfish-body"></span>
</button>

<!-- 鈹€鈹€ Left nav 鈹€鈹€ -->
<aside id="nav">
