        <div class="nv-editor-head">
          <input id="note-title-input" class="nv-title-input" placeholder="鏈懡鍚嶇瑪璁? oninput="_nvChange()">
          <button class="nv-pin-btn" id="nv-pin-btn" onclick="toggleNotePin()" title="缃《/鍙栨秷缃《">鈽?/button>
        </div>
        <!-- Tags row -->
        <div class="nv-tags-row">
          <div id="nv-tag-pills" class="nv-tag-pills"></div>
          <input id="nv-tag-new" class="nv-tag-input" placeholder="+ 娣诲姞鏍囩" onkeydown="_nvTagKey(event)">
          <input id="note-tags-input" type="hidden">
        </div>
        <!-- Toolbar (single row, scrollable) -->
        <div class="nv-toolbar">
          <button class="nv-tb-btn" style="font-weight:900" onclick="_nfmt('**','**')" title="绮椾綋">B</button>
          <button class="nv-tb-btn italic" onclick="_nfmt('*','*')" title="鏂滀綋">I</button>
          <button class="nv-tb-btn strike" onclick="_nfmt('~~','~~')" title="鍒犻櫎绾?>S</button>
          <button class="nv-tb-btn mono" onclick="_nfmt('`','`')" title="琛屽唴浠ｇ爜">銆?銆?/button>
          <div class="nv-tb-sep"></div>
          <button class="nv-tb-btn" onclick="_nfmtLine('# ')" title="涓€绾ф爣棰?>H1</button>
          <button class="nv-tb-btn" onclick="_nfmtLine('## ')" title="浜岀骇鏍囬">H2</button>
          <button class="nv-tb-btn" onclick="_nfmtLine('### ')" title="涓夌骇鏍囬">H3</button>
          <div class="nv-tb-sep"></div>
          <button class="nv-tb-btn" onclick="_nfmt('$','$')" title="琛屽唴鍏紡">$</button>
          <button class="nv-tb-btn" style="font-size:15px" onclick="_nfmtBlock('$$\n','\n$$')" title="鍧楃骇鍏紡">鈭?/button>
          <div class="nv-tb-sep"></div>
          <button class="nv-tb-btn" onclick="_nfmtLine('- ')" title="鏃犲簭鍒楄〃">鈥⑩墶</button>
          <button class="nv-tb-btn" onclick="_nfmtLine('1. ')" title="鏈夊簭鍒楄〃">1鈮?/button>
          <button class="nv-tb-btn" onclick="_nfmtLine('> ')" title="寮曠敤">鉂?/button>
          <div class="nv-tb-sep"></div>
          <button class="nv-tb-btn" id="preview-toggle-btn" onclick="toggleNotePreview()" title="棰勮">闃?/button>
          <!-- Right-aligned actions -->
          <div class="nv-tb-end">
            <span id="nv-autosave-badge" class="nv-autosave-status">鉁?宸蹭繚瀛?/span>
            <button class="nv-tb-action" onclick="embedSelectedNote()" title="鍔犲叆鍚戦噺搴?>鍏ュ簱</button>
            <button class="nv-tb-action" onclick="exportSelectedNotePdf()" title="瀵煎嚭涓?PDF">瀵煎嚭PDF</button>
            <button class="nv-tb-action" onclick="deleteSelectedNote()" title="鍒犻櫎绗旇">鍒犻櫎</button>
            <button id="save-note-btn" class="nv-save-btn" onclick="saveSelectedNote()">淇濆瓨鏂扮瑪璁?/button>
          </div>
        </div>
        <!-- Content -->
        <textarea id="note-content-input" class="nv-textarea" placeholder="寮€濮嬪啓浣溾€?鏀寔 Markdown 鍜?$LaTeX$ 鍏紡" oninput="_nvChange()"></textarea>
        <div id="note-preview" class="nv-preview" style="display:none"></div>
