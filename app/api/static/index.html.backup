      <div class="user-av" id="user-avatar">R</div>
      <div class="user-name" id="user-name">鐮旂┒鑰?/div>
      <div id="ws-dot" class="conn"></div>
    </div>
  </div>
</aside>

<!-- 鈹€鈹€ Main 鈹€鈹€ -->
<main id="main">
  <!-- Welcome -->
  <div id="welcome">
    <div class="w-glow"></div>
    <div class="w-glow2"></div>
    <div class="w-dna">馃К</div>
    <div class="w-title">浣犲ソ锛岀爺绌惰€?馃憢</div>
    <div class="w-sub">鎴戝彲浠ュ府浣犳悳绱㈡枃鐚€佸垎鏋愰棶棰樸€佹€荤粨褰掔撼銆佹彁鍑哄亣璁俱€佽璁″疄楠屾柟妗堢瓑</div>
    <div class="qa-grid">
      <button class="qa-btn" onclick="sendText('甯垜缁艰堪杩戜簲骞存繁搴﹀涔犲湪璁＄畻鏈鸿瑙夐鍩熺殑鐮旂┒杩涘睍')">馃摎 鏂囩尞缁艰堪</button>
      <button class="qa-btn" onclick="sendText('甯垜鍒嗘瀽褰撳墠鐮旂┒涓瓨鍦ㄧ殑涓昏闂涓庢寫鎴?)">馃攳 鐮旂┒闂</button>
      <button class="qa-btn" onclick="sendText('甯垜璁捐涓€涓鐓у疄楠屾柟妗?)">馃И 瀹為獙璁捐</button>
      <button class="qa-btn" onclick="sendText('甯垜鍒嗘瀽鏁版嵁涓殑缁熻瑙勫緥')">馃搳 鏁版嵁鍒嗘瀽</button>
      <button class="qa-btn" onclick="sendText('甯垜娑﹁壊浠ヤ笅杩欐瀛︽湳鍐欎綔')">鉁嶏笍 娑﹁壊鍐欎綔</button>
      <button class="qa-btn" onclick="sendText('浣犺兘甯垜鍋氬摢浜涗簨鎯咃紵')">馃挕 鏇村鍔熻兘</button>
    </div>
  </div>

  <!-- Chat -->
  <div id="chat-view">
    <div id="messages"></div>
  </div>

  <!-- Literature manager -->
  <div id="library-view">
    <div class="page-head">
      <div>
        <div class="page-kicker">Library</div>
        <div class="page-title">鏂囩尞绠＄悊</div>
        <div class="page-sub">鏌ョ湅闀挎湡鐭ヨ瘑搴撲腑鐨勬枃鐚紝涓婁紶鏂版枃鐚紝鐐瑰嚮闃呰鍘熷鏂囦欢銆?/div>
      </div>
      <button class="sm-btn pri" onclick="document.getElementById('lib-file-input').click()">涓婁紶鏂囩尞</button>
    </div>
    <div class="paper-stats">
      <div class="paper-stat">
        <span class="paper-stat-label">鏂囩尞鎬绘暟</span>
        <strong id="paper-stat-total">0</strong>
      </div>
      <div class="paper-stat">
        <span class="paper-stat-label">褰撳墠鏄剧ず</span>
        <strong id="paper-stat-visible">0</strong>
      </div>
      <div class="paper-stat">
        <span class="paper-stat-label">绱㈠紩鍒嗗潡</span>
        <strong id="paper-stat-chunks">0</strong>
      </div>
      <div class="paper-stat warn">
        <span class="paper-stat-label">鏂囦欢缂哄け</span>
        <strong id="paper-stat-missing">0</strong>
      </div>
    </div>
    <div class="paper-toolbar">
      <input id="paper-search" class="paper-search" type="search" placeholder="鎼滅储鏍囬銆佺煡璇嗗簱鎴栨枃浠剁被鍨?
        oninput="renderPaperManager()">
      <select id="paper-sort" class="paper-search" style="min-width:150px;flex:0 0 auto" onchange="renderPaperManager()">
        <option value="newest">鏈€鏂板姞鍏?/option>
        <option value="oldest">鏈€鏃╁姞鍏?/option>
        <option value="title">鎸夋爣棰?/option>
      </select>
      <div id="paper-lib-tabs"></div>
    </div>
    <div class="paper-table-wrap">
      <table class="paper-table">
        <thead>
          <tr>
            <th>鏍囬</th>
            <th>鐭ヨ瘑搴?/th>
            <th>鍔犲叆鏃堕棿</th>
            <th>鍒嗗潡</th>
            <th>鏂囦欢</th>
            <th style="text-align:right">鎿嶄綔</th>
          </tr>
        </thead>
        <tbody id="paper-manager-body">
          <tr><td colspan="6"><div class="paper-empty">姝ｅ湪鍔犺浇鏂囩尞...</div></td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Paper figure generator -->
  <div id="figure-view">
    <div class="page-head">
      <div>
        <div class="page-kicker">Figure Agent</div>
        <div class="page-title">论文图像生成</div>
        <div class="page-sub">上传论文或直接填写图像需求，生成可编辑 prompt，再生成论文插图、方法图或实验示意图。</div>
      </div>
      <button class="sm-btn pri" onclick="document.getElementById('fig-paper-input').click()">上传论文</button>
    </div>
    <div class="fig-workbench">
      <section class="fig-pane">
        <div class="fig-pane-head">
          <div class="fig-pane-title">Prompt 构建</div>
          <button class="sm-btn" onclick="figGeneratePrompt()">生成 prompt</button>
        </div>
        <div class="fig-body">
          <div class="fig-upload">
            <div class="fig-upload-icon">PDF</div>
            <div style="min-width:0;flex:1">
              <div style="font-weight:700;font-size:13px;color:var(--text)">论文输入</div>
              <div id="fig-paper-name" class="paper-meta">尚未选择论文，可上传 PDF/TXT/MD，或直接填写图像需求。</div>
            </div>
            <input type="file" id="fig-paper-input" accept=".pdf,.txt,.md" style="display:none" onchange="figPickPaper(this)">
            <button class="sm-btn" onclick="document.getElementById('fig-paper-input').click()">选择</button>
          </div>
          <div class="fig-row">
            <select id="fig-type" class="fig-select" style="flex:1">
              <option value="method">方法流程图</option>
              <option value="architecture">模型结构图</option>
              <option value="experiment">实验设置图</option>
              <option value="result">结果可视化图</option>
              <option value="graphical_abstract">Graphical Abstract</option>
            </select>
            <select id="fig-style" class="fig-select" style="flex:1">
              <option value="paper">论文期刊风格</option>
              <option value="clean">简洁白底矢量风</option>
              <option value="sci">科研海报风</option>
              <option value="dark">深色演示风</option>
            </select>
          </div>
          <div class="fig-field">
            <div class="fig-label">图像需求</div>
            <textarea id="fig-brief" class="fig-textarea" style="min-height:110px" placeholder="例如：根据论文方法部分，画一个从输入图像、特征提取、扩散去噪到输出结果的流程图，突出关键模块和数据流。"></textarea>
          </div>
          <div class="fig-field">
            <div class="fig-label">Prompt（可编辑）</div>
            <textarea id="fig-prompt" class="fig-textarea" placeholder="点击“生成 prompt”自动生成，或直接在这里手动编写用于图像生成模型的 prompt。"></textarea>
          </div>
          <div class="fig-prompt-actions">
            <button class="sm-btn pri" onclick="figGeneratePrompt()">生成 prompt</button>
            <button class="sm-btn" onclick="figAppendPrompt()">追加要求</button>
            <button class="sm-btn" onclick="figClearPrompt()">清空</button>
          </div>
        </div>
      </section>
      <section class="fig-pane">
        <div class="fig-pane-head">
          <div class="fig-pane-title">图像生成</div>
          <button class="sm-btn pri" onclick="figGenerateImage()">生成图片</button>
        </div>
        <div class="fig-preview">
          <div id="fig-canvas" class="fig-canvas">
            <div class="fig-placeholder" aria-label="Figure preview placeholder">
              <div class="fig-ph-top">
                <div class="fig-ph-title">Scientific Figure Preview</div>
                <div class="fig-ph-tag">Ready</div>
              </div>
              <div class="fig-ph-flow">
                <div class="fig-ph-node">
                  <div class="fig-ph-line"></div>
                  <div class="fig-ph-line short"></div>
                </div>
                <div class="fig-ph-arrow"></div>
                <div class="fig-ph-node">
                  <div class="fig-ph-line"></div>
                  <div class="fig-ph-line short"></div>
                </div>
                <div class="fig-ph-arrow"></div>
                <div class="fig-ph-node">
                  <div class="fig-ph-line"></div>
                  <div class="fig-ph-line short"></div>
                </div>
              </div>
              <div class="fig-ph-foot">
                <div class="fig-ph-chip"></div>
                <div class="fig-ph-chip"></div>
                <div class="fig-ph-chip"></div>
                <div class="fig-ph-chip"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="fig-genbar">
          <select id="fig-ratio" class="fig-select" style="width:130px">
            <option value="4:3">4:3</option>
            <option value="16:9">16:9</option>
            <option value="1:1">1:1</option>
          </select>
          <input id="fig-negative" class="fig-input" style="flex:1" placeholder="负面 prompt：低清晰度、文字错误、杂乱布局">
          <button class="sm-btn" onclick="figSaveMock()">下载图片</button>
        </div>
        <div class="fig-body" style="flex:0 0 170px;border-top:1px solid var(--border)">
          <div class="fig-label">生成历史</div>
          <div id="fig-history" class="fig-history"></div>
        </div>
      </section>
    </div>
  </div>

  <!-- Writing assistant -->
  <div id="writing-view">
    <div class="page-head">
      <div>
        <div class="page-kicker">Writing Agent</div>
        <div class="page-title">璁烘枃鍐欎綔鍔╂墜</div>
        <div class="page-sub">鎶婂啓浣滀换鍔°€佺害鏉熷拰绱犳潗鏁寸悊鎴愭竻鏅拌姹傦紝浜ょ粰 Writing Agent 鐢熸垚鍙紩鐢ㄣ€佸彲缂栬緫鐨勫鏈钀姐€?/div>
      </div>
      <button class="sm-btn pri" onclick="writingSubmit()">鐢熸垚鍐欎綔鍐呭</button>
    </div>
    <div class="write-workbench">
      <section class="write-pane">
        <div class="write-pane-head">
          <div class="write-pane-title">鍐欎綔璁剧疆</div>
          <button class="write-secondary" onclick="writingReset()">閲嶇疆</button>
        </div>
        <div class="write-body">
          <div class="write-field">
            <div class="write-label">浠诲姟绫诲瀷</div>
            <select id="writing-task" class="write-select">
              <option value="related_work">Related Work</option>
              <option value="literature_review">鏂囩尞缁艰堪</option>
              <option value="abstract">鎽樿</option>
              <option value="introduction">寮曡█</option>
              <option value="background">鐮旂┒鑳屾櫙</option>
              <option value="method_description">鏂规硶鎻忚堪</option>
              <option value="experiment_analysis">瀹為獙鍒嗘瀽</option>
